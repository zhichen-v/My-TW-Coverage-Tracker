  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "上銀科技 (2049，HIWIN Technologies) 成立於 1989 年，總部位於台灣台中，以自有品牌「HIWIN」行銷全球，為全球第二大"
            },
            {
              "type": "wikilink",
              "text": "滾珠螺桿"
            },
            {
              "type": "text",
              "text": "製造商及全球前三大"
            },
            {
              "type": "wikilink",
              "text": "線性滑軌"
            },
            {
              "type": "text",
              "text": "製造商，與日商 "
            },
            {
              "type": "wikilink",
              "text": "THK"
            },
            {
              "type": "text",
              "text": " 及 "
            },
            {
              "type": "wikilink",
              "text": "NSK"
            },
            {
              "type": "text",
              "text": " 合計市佔率超過七成。核心產品包括"
            },
            {
              "type": "wikilink",
              "text": "線性滑軌"
            },
            {
              "type": "text",
              "text": " (佔營收約 63%)、"
            },
            {
              "type": "wikilink",
              "text": "滾珠螺桿"
            },
            {
              "type": "text",
              "text": " (約 21%)、"
            },
            {
              "type": "wikilink",
              "text": "工業機器人"
            },
            {
              "type": "text",
              "text": " (約 9%) 及其他產品 (精密軸承、"
            },
            {
              "type": "wikilink",
              "text": "諧波減速機"
            },
            {
              "type": "text",
              "text": "「DATORKER」、力矩馬達旋轉平台等)。產品廣泛應用於"
            },
            {
              "type": "wikilink",
              "text": "工具機"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "設備、"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "產線及"
            },
            {
              "type": "wikilink",
              "text": "工業機器人"
            },
            {
              "type": "text",
              "text": "，近年積極布局"
            },
            {
              "type": "wikilink",
              "text": "人形機器人"
            },
            {
              "type": "text",
              "text": "關節模組商機。海外據點遍及美國、德國、日本、瑞士、以色列等國。"
            }
          ]
        }
      ],
      "groups": []
    },
