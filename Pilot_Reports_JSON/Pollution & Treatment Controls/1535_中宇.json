  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "中宇環保工程股份有限公司成立於1993年，為"
            },
            {
              "type": "wikilink",
              "text": "中鋼"
            },
            {
              "type": "text",
              "text": "集團旗下環保工程公司，總部位於高雄。公司具備統包工程（EPC）能力，主要業務涵蓋：（1）"
            },
            {
              "type": "strong",
              "text": "環保工程："
            },
            {
              "type": "text",
              "text": " 水處理（"
            },
            {
              "type": "wikilink",
              "text": "超純水"
            },
            {
              "type": "text",
              "text": "、廢水處理/回收）、空污防治（集塵、"
            },
            {
              "type": "wikilink",
              "text": "脫硫脫硝"
            },
            {
              "type": "text",
              "text": "）；（2）"
            },
            {
              "type": "strong",
              "text": "機電工程："
            },
            {
              "type": "text",
              "text": " 汽電共生工程；（3）"
            },
            {
              "type": "strong",
              "text": "生技製藥廠房："
            },
            {
              "type": "text",
              "text": " 無塵室機電建置。並提供後續操作維護（O&M）服務。主要客戶以母集團"
            },
            {
              "type": "wikilink",
              "text": "中鋼"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "中龍鋼鐵"
            },
            {
              "type": "text",
              "text": "為核心，亦服務"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": "等半導體廠及公部門。"
            }
          ]
        }
      ],
      "groups": []
    },
