          "segments": [
            {
              "type": "text",
              "text": "公勝保險經紀人 (6028) 成立於1993年，為台灣保險經紀產業先驅，總部高雄。透過逾千名業務顧問代理銷售三十餘家壽險/產險商品，含"
            },
            {
              "type": "wikilink",
              "text": "富邦人壽"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "國泰人壽"
            },
            {
              "type": "text",
              "text": "、"
            },
