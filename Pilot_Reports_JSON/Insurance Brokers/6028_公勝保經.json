              "text": "新光人壽"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "台灣人壽"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "富邦產險"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "國泰產險"
            },
            {
              "type": "text",
              "text": "。2024年營收44.7億 (年增47%)。以"
