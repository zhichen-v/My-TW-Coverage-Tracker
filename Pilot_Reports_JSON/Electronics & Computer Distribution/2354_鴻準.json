    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "鴻準精密工業 (2354，"
            },
            {
              "type": "wikilink",
              "text": "鴻海"
            },
            {
              "type": "text",
              "text": " Technology) 成立於 1990 年，總部位於新北市，為"
            },
            {
              "type": "wikilink",
              "text": "鴻海"
            },
            {
              "type": "text",
              "text": "科技集團旗下子公司。公司為全球金屬機構件與散熱模組領導廠商，核心業務包括鎂鋁合金精密機殼、散熱模組及遊戲機組裝。主要客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "任天堂"
            },
            {
              "type": "text",
              "text": " (Nintendo Switch 組裝主力)、"
            },
            {
              "type": "wikilink",
              "text": "Apple"
            },
            {
              "type": "text",
              "text": " (鎂鋁合金機殼)、"
            },
            {
              "type": "wikilink",
              "text": "Sony"
            },
            {
              "type": "text",
              "text": " (PlayStation 零組件) 等國際大廠，其中日本市場佔營收約 75%。近年積極布局邊緣 "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": " 應用、"
            },
            {
              "type": "wikilink",
              "text": "機器人"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "零組件，並於美國肯塔基州設廠以分散地緣風險。"
            }
          ]
        }
      ],
      "groups": []
    },
