  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "訊達電腦股份有限公司 (6140) 是一家深耕多年的資訊系統整合服務商(SI)。公司從早期的個人電腦與週邊設備代理銷售，成功轉型為專注於企業私有雲、網路資安、虛擬化及儲存方案的全方位IT建置顧問。看準"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "與大數據趨勢，訊達積極為許多台灣高科技製造業及政府機關建構"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "訓練與推論的IT基礎架構，在"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "供應鏈中負責『最後一哩路』的硬體與應用整合服務。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 全球知名資訊設備原廠("
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "、儲存設備、網路設備)及企業級軟體開發商。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "訊達電腦"
            },
            {
              "type": "text",
              "text": " (企業IT系統建置、雲端資安架構規劃與軟硬體系統整合服務)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 各產業之大型企業用戶、高科技製造廠及政府公家機關。"
            }
