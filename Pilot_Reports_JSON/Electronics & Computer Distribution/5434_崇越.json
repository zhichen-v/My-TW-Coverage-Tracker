  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "崇越科技（5434）是台灣領先的"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "及光電材料通路商，長期深耕高科技產業。公司主要代理日本"
            },
            {
              "type": "wikilink",
              "text": "Shin-Etsu"
            },
            {
              "type": "text",
              "text": "化學（Shin-Etsu）的"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "材料（如矽晶圓、光阻液、研磨液等），並銷售LED、LCD等相關電子材料及設備。崇越亦積極拓展環保工程業務（廢水處理、無塵室工程）及大健康產業（安永鮮物）。作為"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": "等晶圓代工大廠的重要合作夥伴，崇越在先進製程材料供應上佔有重要地位，隨著台灣"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "產業的全球擴張，公司也積極佈局美國、日本及東南亞市場。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "崇越位於"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "產業鏈的上游材料及設備供應端，扮演原廠（如"
            },
            {
              "type": "wikilink",
              "text": "Shin-Etsu"
            },
            {
              "type": "text",
              "text": "化學）與製造廠之間的關鍵橋樑。"
            }
          ]
        },
        {
          "type": "list",
          "items": [
            {
              "segments": [
                {
                  "type": "strong",
                  "text": "上游:"
                },
                {
                  "type": "text",
                  "text": " "
                },
                {
                  "type": "wikilink",
                  "text": "Shin-Etsu"
                },
                {
                  "type": "text",
                  "text": "化學（矽晶圓、光阻）、"
                },
                {
                  "type": "wikilink",
                  "text": "Shin-Etsu"
                },
                {
                  "type": "text",
                  "text": "石英、及其他國內外材料/設備供應商。"
                }
              ]
            },
            {
              "segments": [
                {
                  "type": "strong",
                  "text": "中游:"
                },
                {
                  "type": "text",
                  "text": " 崇越科技（代理銷售、技術服務、整合方案）。"
                }
              ]
            },
            {
              "segments": [
                {
                  "type": "strong",
                  "text": "下游:"
                },
                {
                  "type": "text",
                  "text": " 晶圓代工廠（"
                },
                {
                  "type": "wikilink",
                  "text": "台積電"
                },
                {
                  "type": "text",
                  "text": "、"
                },
                {
                  "type": "wikilink",
                  "text": "聯電"
                },
                {
                  "type": "text",
                  "text": "、世界先進）、"
                },
                {
                  "type": "wikilink",
                  "text": "記憶體"
                },
                {
                  "type": "text",
                  "text": "廠（華亞科、南亞科）、封測廠（"
                },
                {
                  "type": "wikilink",
                  "text": "日月光投控"
                },
                {
                  "type": "text",
                  "text": "）、光電廠。"
                }
              ]
            }
          ]
        }
      ],
      "groups": []
    },
