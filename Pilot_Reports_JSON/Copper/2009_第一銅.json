              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "白銅"
            },
            {
              "type": "text",
              "text": "帶材專業廠。產品應用於半導體"
            },
            {
              "type": "wikilink",
              "text": "導線架"
            },
            {
              "type": "text",
              "text": "、汽車"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "端子、散熱片及3C電子。以「銅價+加工費」計價，與日系及車用客戶維持長約。下游含"
            },
            {
              "type": "wikilink",
              "text": "導線架"
            },
            {
              "type": "text",
              "text": "廠如"
            },
            {
              "type": "wikilink",
              "text": "長華電材"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "順德工業"
            },
            {
              "type": "text",
              "text": "及車用端子廠。銅價連動"
            },
            {
              "type": "wikilink",
              "text": "LME"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
