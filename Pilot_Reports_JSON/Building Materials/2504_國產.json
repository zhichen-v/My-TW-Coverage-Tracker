  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "國產建材實業股份有限公司 (Goldsun Building Materials Co., Ltd.) 成立於 1954 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "台北"
            },
            {
              "type": "text",
              "text": "。公司為台灣 "
            },
            {
              "type": "strong",
              "text": "預拌混凝土 (Ready-Mixed Concrete)"
            },
            {
              "type": "text",
              "text": " 龍頭，市占率全台第一。近年受惠於全台科技廠辦 (如 "
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": ") 建廠需求及房市熱絡，業績穩健。積極佈局「碳礦化」混凝土技術及資產活化 (如南港大型開發案)。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [],
      "groups": [
        {
          "title": "上游 (原料與料源掌握)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "核心材料:"
                    },
                    {
                      "type": "text",
                      "text": " 採購水泥 (來自 "
                    },
                    {
                      "type": "wikilink",
                      "text": "台灣水泥"
                    },
                    {
                      "type": "text",
                      "text": ", "
                    },
                    {
                      "type": "wikilink",
                      "text": "亞洲水泥"
                    },
                    {
                      "type": "text",
                      "text": ") 與飛灰。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "自有礦源與物流:"
                    },
                    {
                      "type": "text",
                      "text": " 利用自有砂石船隊及散裝碼頭營運，進口砂石；並設立附屬爐石粉研磨廠。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "中游 (核心製造與減碳技術)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "預拌混凝土:"
                    },
                    {
                      "type": "text",
                      "text": " "
                    },
                    {
                      "type": "strong",
                      "text": "國產建材實業"
                    },
                    {
                      "type": "text",
                      "text": " 於全台設立 28 處預拌廠，進行高強度混凝土拌合。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "碳封存合作:"
                    },
                    {
                      "type": "text",
                      "text": " 與加拿大新創 "
                    },
                    {
                      "type": "wikilink",
                      "text": "CarbonCure"
                    },
                    {
                      "type": "text",
                      "text": " 合作，導入碳礦化技術，將工業二氧化碳封存於混凝土中。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "新型建材:"
                    },
                    {
                      "type": "text",
                      "text": " 拓展矽酸鈣板、輕質隔間板與地板材。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "下游應用 (終端市場)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "科技廠辦:"
                    },
                    {
                      "type": "text",
                      "text": " 供應全台科技大廠建廠專案 (貢獻營收約20%)。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "公共與商辦:"
                    },
                    {
                      "type": "text",
                      "text": " 台北流行音樂中心、南港 CITYLINK 複合式大樓。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "房地產指標:"
                    },
                    {
                      "type": "text",
                      "text": " 南港「世界明珠」豪宅、以及各大建商之建案。"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
