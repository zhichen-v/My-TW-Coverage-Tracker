  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "嘉新水泥股份有限公司 (Chia Hsin Cement Corporation) 成立於 1954 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "台北"
            },
            {
              "type": "text",
              "text": "。嘉泥為台灣老牌水泥業者，近年積極推動轉型與資產活化，業務版圖已從單純之水泥產銷延伸至"
            },
            {
              "type": "wikilink",
              "text": "旅宿服務"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "健康照護"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "資產管理"
            },
            {
              "type": "text",
              "text": "。旗下擁有沖繩國際通地標飯店「"
            },
            {
              "type": "wikilink",
              "text": "Hotel Collective"
            },
            {
              "type": "text",
              "text": "」及頂級產後護理品牌「"
            },
            {
              "type": "wikilink",
              "text": "人之初"
            },
            {
              "type": "text",
              "text": "」，成功轉型為服務導向之控股公司，同時仍維持水泥儲運及混凝土配銷之穩健現金流業務。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [],
      "groups": [
        {
          "title": "上游 (水泥代理與資產)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "水泥業務:"
                    },
                    {
                      "type": "text",
                      "text": " 已轉型為經銷與儲運模式，主要代理銷售台泥、亞泥等大廠產品，或進口水泥。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "資產:"
                    },
                    {
                      "type": "text",
                      "text": " 擁有台北市精華地段之"
                    },
                    {
                      "type": "wikilink",
                      "text": "嘉新大樓"
                    },
                    {
                      "type": "text",
                      "text": "及其他土地資產。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "下游應用 (多元事業)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "建材事業:"
                    },
                    {
                      "type": "text",
                      "text": " 預拌混凝土銷售，供應北部建築與公共工程。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "旅宿事業:"
                    },
                    {
                      "type": "text",
                      "text": " 日本沖繩 "
                    },
                    {
                      "type": "wikilink",
                      "text": "Hotel Collective"
                    },
                    {
                      "type": "text",
                      "text": " (自有品牌飯店)。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "健康事業:"
                    },
                    {
                      "type": "text",
                      "text": " "
                    },
                    {
                      "type": "wikilink",
                      "text": "人之初"
                    },
                    {
                      "type": "text",
                      "text": "產後護理之家 (高階月子中心)，佈局台北與台中。"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "customer_supplier": {
      "heading": "主要客戶及供應商",
      "blocks": [],
      "groups": [
        {
          "title": "主要客戶",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "建材採購:"
                    },
                    {
                      "type": "text",
                      "text": " 北部地區之各級營造廠、建設公司。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "高端旅宿:"
                    },
                    {
                      "type": "text",
                      "text": " "
                    },
                    {
                      "type": "wikilink",
                      "text": "Hotel Collective"
                    },
                    {
                      "type": "text",
                      "text": " 下榻之國際觀光客與日本國內自駕旅客。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "健康照護:"
                    },
                    {
                      "type": "text",
                      "text": " 支付 "
                    },
                    {
                      "type": "wikilink",
                      "text": "人之初"
                    },
                    {
                      "type": "text",
                      "text": " 月子護理費用之本國與外國高產值家庭。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "主要供應商",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "大宗水泥來源:"
                    },
                    {
                      "type": "text",
                      "text": " 長線穩定合作之本土雙雄 "
                    },
                    {
                      "type": "wikilink",
                      "text": "台灣水泥"
                    },
                    {
                      "type": "text",
                      "text": " ("
                    },
                    {
                      "type": "wikilink",
                      "text": "台泥"
                    },
                    {
                      "type": "text",
                      "text": ")、"
                    },
                    {
                      "type": "wikilink",
                      "text": "亞洲水泥"
                    },
                    {
                      "type": "text",
                      "text": " ("
                    },
                    {
                      "type": "wikilink",
                      "text": "亞泥"
                    },
                    {
                      "type": "text",
                      "text": ")。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "飯店營運備品:"
                    },
                    {
                      "type": "text",
                      "text": " 當地生鮮食材供應商、國內外聯網訂房平台 (OTA)。"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
