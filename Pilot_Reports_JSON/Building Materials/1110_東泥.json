                    },
                    {
                      "type": "text",
                      "text": " — 熟料研磨、水泥儲運、爐石粉產銷"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "[[東泥建設]]"
                    },
                    {
                      "type": "text",
                      "text": " — 住宅建案開發"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
