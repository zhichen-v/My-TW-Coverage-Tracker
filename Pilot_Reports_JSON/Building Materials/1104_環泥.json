                      "type": "strong",
                      "text": "科技廠辦營造:"
                    },
                    {
                      "type": "text",
                      "text": " "
                    },
                    {
                      "type": "wikilink",
                      "text": "台積電"
                    },
                    {
                      "type": "text",
                      "text": " 及其南科進駐廠商之廠房建設專案。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "AI醫療與電子:"
                    },
                    {
                      "type": "text",
                      "text": " 採購壓力感測器之北美與歐洲產業領導品牌，以及 "
                    },
                    {
                      "type": "wikilink",
                      "text": "北醫行愛長照中心"
                    },
                    {
                      "type": "text",
                      "text": "。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "主要供應商",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "水泥熟料來源:"
                    },
                    {
                      "type": "text",
                      "text": " 國內東部之大型水泥與熟料製造商、"
                    },
                    {
                      "type": "wikilink",
                      "text": "台電"
                    },
                    {
                      "type": "text",
                      "text": " (脫硫石膏來源)。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "特殊建材授權:"
                    },
                    {
                      "type": "text",
                      "text": " 日本外牆建材大廠 "
                    },
                    {
                      "type": "wikilink",
                      "text": "NICHIHA"
                    },
                    {
                      "type": "text",
                      "text": "。"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
