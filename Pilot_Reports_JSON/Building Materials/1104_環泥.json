  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "環球水泥股份有限公司 (Universal Cement Corporation) 成立於 1959 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "台北"
            },
            {
              "type": "text",
              "text": "，為「台南幫」企業之一。公司深耕南台灣，主要產品為"
            },
            {
              "type": "wikilink",
              "text": "水泥"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "預拌混凝土"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "石膏板"
            },
            {
              "type": "text",
              "text": " (市佔率全台第一，約 90%)。近年環泥積極跨足電子科技領域，透過子公司"
            },
            {
              "type": "wikilink",
              "text": "利永環球"
            },
            {
              "type": "text",
              "text": "發展軟性觸覺感測器 (Micro-pressure Sensor)，應用於3C產品及智慧醫療。此外，環泥亦是南科科技廠房建設之主要混凝土供應商。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [],
      "groups": [
        {
          "title": "上游 (原料與生產)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "水泥熟料:"
                    },
                    {
                      "type": "text",
                      "text": " 熟料多為外購或進口 (向國內東部大廠採購)，於高雄阿蓮、台南麻豆等地設有研磨廠與預拌廠。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "石膏板原物料:"
                    },
                    {
                      "type": "text",
                      "text": " 採用火力發電廠之副產品 ("
                    },
                    {
                      "type": "wikilink",
                      "text": "脫硫石膏"
                    },
                    {
                      "type": "text",
                      "text": ") 進行循環再利用，於桃園海湖設有工廠。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "建材合作:"
                    },
                    {
                      "type": "text",
                      "text": " 強化與日本建材大廠 "
                    },
                    {
                      "type": "wikilink",
                      "text": "NICHIHA"
                    },
                    {
                      "type": "text",
                      "text": " 合作，增加外牆與屋頂系統建材多樣性。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "下游應用 (終端市場)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "建材業務 (混凝土):"
                    },
                    {
                      "type": "text",
                      "text": " 供應高磅數水泥予 "
                    },
                    {
                      "type": "wikilink",
                      "text": "台積電"
                    },
                    {
                      "type": "text",
                      "text": " 南部廠房 (為其兩大供應商之一)、高雄台南捷運及南科擴建案等重大工程。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "電子業務 (利永環球):"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "感測器應用:"
                    },
                    {
                      "type": "text",
                      "text": " 觸控筆、智慧鍵盤、醫療床 (導入 "
                    },
                    {
                      "type": "wikilink",
                      "text": "北醫行愛長照中心"
                    },
                    {
                      "type": "text",
                      "text": " 之褥瘡偵測)、智慧倉儲。"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "customer_supplier": {
      "heading": "主要客戶及供應商",
      "blocks": [],
      "groups": [
