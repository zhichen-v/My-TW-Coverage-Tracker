  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "富威電力 (6994，FWP) 為"
            },
            {
              "type": "wikilink",
              "text": "森崴能源"
            },
            {
              "type": "text",
              "text": " (6806) 旗下子公司，隸屬"
            },
            {
              "type": "wikilink",
              "text": "正崴精密"
            },
            {
              "type": "text",
              "text": "集團。公司定位為全方位綠能售電與永續服務平台。三大業務支柱：(1) 綠電轉供 — 整合再生能源裝置容量 164MW，超過 300 個綠電轉供據點，為 "
            },
            {
              "type": "wikilink",
              "text": "Nvidia"
            },
            {
              "type": "text",
              "text": " 台灣高雄南軟 AI 機房之唯一綠電供應商；(2) 儲能系統 — 已上線運轉 57MW 自持案場，新開發 200MW/750MWh 儲能案場；(3) 節能服務。2025 年 1 月正式於"
            },
            {
              "type": "wikilink",
              "text": "台灣證券交易所"
            },
            {
              "type": "text",
              "text": "掛牌。2024 年營收 18.7 億元，年增 112%。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [],
