  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "雙邦實業 (6506，Shuang Bang Industrial) 為高機能"
            },
            {
              "type": "wikilink",
              "text": "PU樹脂"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "TPU"
            },
            {
              "type": "text",
              "text": "及透濕防水布料製造商，為國內生產高機能透濕防水布之先驅。自行生產"
            },
            {
              "type": "wikilink",
              "text": "PU樹脂"
            },
            {
              "type": "text",
              "text": "供加工貼合，產品應用於國際運動鞋品牌鞋材 (供應"
            },
            {
              "type": "wikilink",
              "text": "Nike"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "adidas"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Columbia"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "The North Face"
            },
            {
              "type": "text",
              "text": "代工體系如"
            },
            {
              "type": "wikilink",
              "text": "豐泰"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "裕元"
            },
            {
              "type": "text",
              "text": ")、戶外運動機能服飾、太陽能電池封裝膜及節能建材。上游"
            },
            {
              "type": "wikilink",
              "text": "MDI"
            },
            {
              "type": "text",
              "text": "/TDI 原料來自"
            },
            {
              "type": "wikilink",
              "text": "台塑"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "南亞塑膠"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "萬華化學"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
      ],
      "groups": []
    },
