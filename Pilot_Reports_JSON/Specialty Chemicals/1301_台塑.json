                    },
                    {
                      "type": "text",
                      "text": " (聚乙烯)、"
                    },
                    {
                      "type": "wikilink",
                      "text": "PP"
                    },
                    {
                      "type": "text",
                      "text": " (聚丙烯)、EVA。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "化學品:"
                    },
                    {
                      "type": "text",
                      "text": " 液鹼、丙烯酸酯 (AE)、正丁醇 (NBA)、AN。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "特用化學:"
                    },
                    {
                      "type": "text",
                      "text": " "
                    },
                    {
                      "type": "wikilink",
                      "text": "碳纖維"
                    },
                    {
                      "type": "text",
                      "text": " (Carbon Fiber)、高吸水性樹脂 ("
                    },
                    {
                      "type": "wikilink",
                      "text": "SAP"
                    },
                    {
                      "type": "text",
                      "text": ")。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "終端應用:"
                    },
                    {
                      "type": "text",
                      "text": " 建材管材、食品包裝、汽車零組件、紡織成衣、醫療衛生用品、航太、風力發電葉片。"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
