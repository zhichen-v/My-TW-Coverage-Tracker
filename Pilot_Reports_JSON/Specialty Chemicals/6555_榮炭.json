  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "榮炭科技 (6555，Long Time Carbon Technology) 為台灣唯一鋰電池"
            },
            {
              "type": "wikilink",
              "text": "負極材料"
            },
            {
              "type": "text",
              "text": "研發製造商，專注"
            },
            {
              "type": "wikilink",
              "text": "人造石墨"
            },
            {
              "type": "text",
              "text": "、天然石墨及碳微球負極材料。擁有台灣宜蘭廠及中國廣東江門廠。與日本"
            },
            {
              "type": "wikilink",
              "text": "大阪瓦斯"
            },
            {
              "type": "text",
              "text": " (Osaka Gas) 簽訂代工合約。獲"
            },
            {
              "type": "wikilink",
              "text": "鴻海"
            },
            {
              "type": "text",
              "text": "集團、"
            },
            {
              "type": "wikilink",
              "text": "富邦金控"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "碩禾"
            },
            {
              "type": "text",
              "text": "等戰略投資。下游客戶涵蓋中國一線電池芯大廠如"
            },
            {
              "type": "wikilink",
              "text": "寧德時代"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "比亞迪"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "億緯鋰能"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "國軒高科"
            },
            {
              "type": "text",
              "text": "等，終端應用為"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "儲能系統"
            },
            {
              "type": "text",
              "text": "。2026 年 1-2 月累計營收年增率達 295%。"
            }
          ]
        }
      ],
      "groups": []
    },
