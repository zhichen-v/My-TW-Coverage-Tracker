  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "三福化工 (4755，San Fu Chemical) 為半導體濕製程關鍵化學品供應商，核心產品涵蓋"
            },
            {
              "type": "wikilink",
              "text": "TMAH"
            },
            {
              "type": "text",
              "text": "顯影液、蝕刻液、剝離液及清洗劑。為"
            },
            {
              "type": "wikilink",
              "text": "CoWoS"
            },
            {
              "type": "text",
              "text": "先進封裝重大受惠者 — "
            },
            {
              "type": "wikilink",
              "text": "CoWoS"
            },
            {
              "type": "text",
              "text": " 用剝離液 2024 年前三季營收成長 251%。半導體營收佔比目標從 20% 提升至 25-30%。主要客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": " (主要客戶，"
            },
            {
              "type": "wikilink",
              "text": "CoWoS"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "InFO"
            },
            {
              "type": "text",
              "text": "製程)、"
            },
            {
              "type": "wikilink",
              "text": "聯電"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "世界先進"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "力成"
            },
            {
              "type": "text",
              "text": "。面板客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "友達"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "群創"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "彩晶"
            },
            {
              "type": "text",
              "text": "。LED/太陽能客戶含"
            },
            {
              "type": "wikilink",
              "text": "晶元光電"
            },
            {
              "type": "text",
              "text": "。另為"
            },
            {
              "type": "wikilink",
              "text": "TMAH"
            },
            {
              "type": "text",
              "text": "廢液回收再利用先驅，實踐循環經濟。"
            }
          ]
        }
      ],
      "groups": []
    },
