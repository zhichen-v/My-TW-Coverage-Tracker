  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "雙鍵化工 (4764，Double Bond Chemical) 為特用化學品廠，專精塑膠添加劑 ("
            },
            {
              "type": "wikilink",
              "text": "紫外線吸收劑"
            },
            {
              "type": "text",
              "text": "/HALS 光穩定劑/抗氧化劑) 及"
            },
            {
              "type": "wikilink",
              "text": "UV固化"
            },
            {
              "type": "text",
              "text": "材料 (單體/寡聚物/光引發劑)。積極拓展電子化學品 — "
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": "/6G "
            },
            {
              "type": "wikilink",
              "text": "CCL"
            },
            {
              "type": "text",
              "text": "樹脂添加劑、環氧硬化劑、"
            },
            {
              "type": "wikilink",
              "text": "LED"
            },
            {
              "type": "text",
              "text": "封裝膠。已確認打入主要"
            },
            {
              "type": "wikilink",
              "text": "CCL"
            },
            {
              "type": "text",
              "text": "廠供應鏈如"
            },
            {
              "type": "wikilink",
              "text": "台光電"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "聯茂"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "台燿"
            },
            {
              "type": "text",
              "text": "。另開發數位紡織墨水及"
            },
            {
              "type": "wikilink",
              "text": "3D 列印"
            },
            {
              "type": "text",
              "text": "材料。下游塑膠客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "台塑"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "南亞塑膠"
            },
            {
              "type": "text",
              "text": "等。"
            }
          ]
        }
      ],
      "groups": []
    },
