    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "國化實業 (1713，Cathay Chemical Works) 為台灣特用化學品製造商，產品涵蓋清洗劑、半導體濕製程化學品及工業化學品。近年成功切入半導體供應鏈，子公司"
            },
            {
              "type": "wikilink",
              "text": "和淞科技"
            },
            {
              "type": "text",
              "text": "專注半導體特化品，供應"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Micron"
            },
            {
              "type": "text",
              "text": "等晶圓廠。"
            }
          ]
        }
      ],
