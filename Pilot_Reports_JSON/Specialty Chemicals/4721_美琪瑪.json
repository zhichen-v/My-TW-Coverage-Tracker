  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "美琪瑪科技 (4721，Mechema) 雙核心事業：(1) PTA 氧化觸媒 (醋酸鈷/醋酸錳) — 全球領導地位，供應 PTA 製造商如"
            },
            {
              "type": "wikilink",
              "text": "亞東石化"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "台化"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "遠東新世紀"
            },
            {
              "type": "text",
              "text": "；(2) 電動車電池材料 — "
            },
            {
              "type": "wikilink",
              "text": "硫酸鈷"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "硫酸鎳"
            },
            {
              "type": "text",
              "text": "供應"
            },
            {
              "type": "wikilink",
              "text": "鋰電池"
            },
            {
              "type": "text",
              "text": "正極材料前驅體，與日本"
            },
            {
              "type": "wikilink",
              "text": "Toda Kogyo"
            },
            {
              "type": "text",
              "text": " (戶田工業) 合資設立"
            },
            {
              "type": "wikilink",
              "text": "美戶先進材料"
            },
            {
              "type": "text",
              "text": "生產 NCA/NCM 正極前驅體。電池材料營收佔比已達約 50%。供應鏈經由"
            },
            {
              "type": "wikilink",
              "text": "住友金屬礦山"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Panasonic"
            },
            {
              "type": "text",
              "text": "間接供應"
            },
            {
              "type": "wikilink",
              "text": "Tesla"
            },
            {
              "type": "text",
              "text": "電動車電池。另發展廢電池鈷鎳回收循環經濟。"
            }
          ]
        }
      ],
      "groups": []
    },
