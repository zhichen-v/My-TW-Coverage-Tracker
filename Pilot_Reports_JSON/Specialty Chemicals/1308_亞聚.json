  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "亞洲聚合 (1308，Asia Polymer) 隸屬"
            },
            {
              "type": "wikilink",
              "text": "台聚"
            },
            {
              "type": "text",
              "text": "集團，專注"
            },
            {
              "type": "wikilink",
              "text": "LDPE"
            },
            {
              "type": "text",
              "text": " (低密度聚乙烯) 與"
            },
            {
              "type": "wikilink",
              "text": "EVA"
            },
            {
              "type": "text",
              "text": " (乙烯醋酸乙烯酯) 生產。光伏級"
            },
            {
              "type": "wikilink",
              "text": "EVA"
            },
            {
              "type": "text",
              "text": "為"
            },
            {
              "type": "wikilink",
              "text": "太陽能封裝膜"
            },
            {
              "type": "text",
              "text": "關鍵材料，供應中國膠膜龍頭"
            },
            {
              "type": "wikilink",
              "text": "福斯特"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "海優新材"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "賽伍技術"
            },
            {
              "type": "text",
              "text": "，終端模組廠涵蓋"
            },
            {
              "type": "wikilink",
              "text": "晶科能源"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "晶澳科技"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "天合光能"
            },
            {
              "type": "text",
              "text": "。塗覆級"
            },
            {
              "type": "wikilink",
              "text": "LDPE"
            },
            {
              "type": "text",
              "text": "應用於半導體包裝與保護膜。集團投資福建"
            },
            {
              "type": "wikilink",
              "text": "古雷石化"
            },
            {
              "type": "text",
              "text": "掌握乙烯來源，上游原料亦來自"
            },
            {
              "type": "wikilink",
              "text": "台灣中油"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
      ],
      "groups": []
    },
