  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "達輝光電 (6434，TacBright Optronics) 為台灣唯一具 TAC (三醋酸纖維素) 光學膜量產技術之專業廠商，"
            },
            {
              "type": "wikilink",
              "text": "新光合纖"
            },
            {
              "type": "text",
              "text": "轉投資子公司。2006 年收購瑞士"
            },
            {
              "type": "wikilink",
              "text": "Lonza"
            },
            {
              "type": "text",
              "text": "集團旗下德國 LOFO High Tech Film GmbH 取得 TAC 膜製造技術。"
            },
            {
              "type": "wikilink",
              "text": "TAC膜"
            },
            {
              "type": "text",
              "text": "為"
            },
            {
              "type": "wikilink",
              "text": "LCD"
            },
            {
              "type": "wikilink",
              "text": "偏光板"
            },
            {
              "type": "text",
              "text": "之關鍵保護膜。下游客戶涵蓋全球偏光板大廠如"
            },
            {
              "type": "wikilink",
              "text": "日東電工"
            },
            {
              "type": "text",
              "text": " (Nitto Denko)、"
            },
            {
              "type": "wikilink",
              "text": "住友化學"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "LG化學"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "奇美材料"
            },
            {
              "type": "text",
              "text": "。終端面板客戶含"
            },
            {
              "type": "wikilink",
              "text": "友達"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "群創"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Samsung Display"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "LG Display"
            },
            {
              "type": "text",
              "text": "。上游醋酸纖維素原料來自"
            },
            {
              "type": "wikilink",
              "text": "Daicel"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
      ],
      "groups": []
    },
