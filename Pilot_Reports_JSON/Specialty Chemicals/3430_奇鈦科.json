  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "奇鈦科技 (3430，Chitec Technology) 為利基型特用化學品供應商，專精"
            },
            {
              "type": "wikilink",
              "text": "紫外線吸收劑"
            },
            {
              "type": "text",
              "text": " (UVA，佔營收約 49%)、抗氧化劑 (27%)、"
            },
            {
              "type": "wikilink",
              "text": "光引發劑"
            },
            {
              "type": "text",
              "text": " (20%，全球前五大) 及阻燃劑 (4%)。海外營收佔比高 (亞洲 52%、美洲 27%、歐洲 8%)。下游塗料客戶涵蓋全球前五大塗料廠中三家 — "
            },
            {
              "type": "wikilink",
              "text": "PPG"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Sherwin-Williams"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Nippon Paint"
            },
            {
              "type": "text",
              "text": " (立邦)、"
            },
            {
              "type": "wikilink",
              "text": "AkzoNobel"
            },
            {
              "type": "text",
              "text": "。電子級"
            },
            {
              "type": "wikilink",
              "text": "光引發劑"
            },
            {
              "type": "text",
              "text": "為"
            },
            {
              "type": "wikilink",
              "text": "光阻"
            },
            {
              "type": "text",
              "text": "上游原料之一，間接服務"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": "等晶圓廠。另應用於光纖塗料、3D 列印樹脂及"
            },
            {
              "type": "wikilink",
              "text": "UV固化"
            },
            {
              "type": "text",
              "text": "油墨。設有美國休士頓及上海子公司。"
            }
          ]
        }
      ],
      "groups": []
    },
