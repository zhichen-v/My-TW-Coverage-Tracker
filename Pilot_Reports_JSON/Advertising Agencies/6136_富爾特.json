  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "富爾特科技 (6136) 是一家以電信加值服務與數位娛樂為核心的平台營運商。公司為"
            },
            {
              "type": "wikilink",
              "text": "中華電信"
            },
            {
              "type": "text",
              "text": "代理商，經營"
            },
            {
              "type": "wikilink",
              "text": "預付卡"
            },
            {
              "type": "text",
              "text": "申辦、儲值及入境觀光卡服務，並以 S2B2C 模式拓展"
            },
            {
              "type": "wikilink",
              "text": "國際漫遊"
            },
            {
              "type": "text",
              "text": "業務，覆蓋全球 95% 國人出遊目的地。集團旗下"
            },
            {
              "type": "wikilink",
              "text": "格帝控股"
            },
            {
              "type": "text",
              "text": " (GRANDI) 負責影視娛樂與"
            },
            {
              "type": "wikilink",
              "text": "整合行銷"
            },
            {
              "type": "text",
              "text": "，"
            },
            {
              "type": "wikilink",
              "text": "IMAGEMORE"
            },
            {
              "type": "text",
              "text": " 品牌經營東方風格原創"
            },
            {
              "type": "wikilink",
              "text": "數位圖庫"
            },
            {
              "type": "text",
              "text": "。公司另持有"
            },
            {
              "type": "wikilink",
              "text": "大聯大控股"
            },
            {
              "type": "text",
              "text": " (WPG)、"
            },
            {
              "type": "wikilink",
              "text": "萬里雲"
            },
            {
              "type": "text",
              "text": " (CloudMile) 及"
            },
            {
              "type": "wikilink",
              "text": "曙客"
            },
            {
              "type": "text",
              "text": " (funNow) 等策略性投資。"
            }
          ]
        }
      ],
      "groups": []
    },
