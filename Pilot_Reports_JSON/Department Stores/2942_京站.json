  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "京站實業 (2942，Q Square) 為"
            },
            {
              "type": "wikilink",
              "text": "日勝生活科技"
            },
            {
              "type": "text",
              "text": "旗下子公司，經營「京站時尚廣場」複合式購物中心。旗艦店坐落於"
            },
            {
              "type": "wikilink",
              "text": "台北車站"
            },
            {
              "type": "text",
              "text": "交九轉運站，坐擁台鐵、高鐵、"
            },
            {
              "type": "wikilink",
              "text": "台北捷運"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "桃園機場捷運"
            },
            {
              "type": "text",
              "text": "、國道客運五鐵共構之絕佳交通優勢。京站以「餐飲」為核心吸客引擎，並結合"
            },
            {
              "type": "wikilink",
              "text": "威秀影城"
            },
            {
              "type": "text",
              "text": "娛樂業態與"
            },
            {
              "type": "wikilink",
              "text": "統一健身俱樂部"
            },
            {
              "type": "text",
              "text": "運動休閒，打造通勤族與年輕族群的一站式生活消費場域。京站亦進駐"
            },
            {
              "type": "wikilink",
              "text": "君品酒店"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "雲朗觀光集團"
            },
            {
              "type": "text",
              "text": ") 共構營運。"
            }
          ]
        }
      ],
      "groups": []
    },
