    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "宏盛建設"
            },
            {
              "type": "text",
              "text": " (2534，Hung Sheng Construction) 成立於 1986 年，總部位於台北，隸屬於"
            },
            {
              "type": "wikilink",
              "text": "宏泰集團"
            },
            {
              "type": "text",
              "text": "。公司以打造頂級豪宅聞名，最具代表性作品為台灣豪宅指標"
            },
            {
              "type": "wikilink",
              "text": "仁愛帝寶"
            },
            {
              "type": "text",
              "text": " (The Palace)，曾為全台最貴豪宅。除頂級豪宅外，近年亦積極佈局淡海新市鎮及台北市區中小坪數精緻住宅。營造施工主要由集團關係企業"
            },
            {
              "type": "wikilink",
              "text": "助群營造"
            },
            {
              "type": "text",
              "text": "負責，形成開發與施工之垂直整合優勢。"
            },
            {
              "type": "wikilink",
              "text": "宏泰集團"
            },
            {
              "type": "text",
              "text": "旗下包含"
            },
            {
              "type": "wikilink",
              "text": "宏泰人壽"
            },
            {
              "type": "text",
              "text": "等金融事業。"
            }
          ]
        }
      ],
      "groups": []
    },
