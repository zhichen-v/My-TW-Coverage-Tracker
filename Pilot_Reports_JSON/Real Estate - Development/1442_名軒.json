    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "名軒開發"
            },
            {
              "type": "text",
              "text": " (1442) 為"
            },
            {
              "type": "wikilink",
              "text": "麗寶集團"
            },
            {
              "type": "text",
              "text": "旗下上市營建公司，由"
            },
            {
              "type": "wikilink",
              "text": "吳寶田"
            },
            {
              "type": "text",
              "text": "家族主導經營。公司專注於淡海新市鎮、桃園及台中等區域之住宅及商辦開發，擅長大規模軌道經濟開發案，代表建案包括淡海「名軒海樂地」系列。名軒運用"
            },
            {
              "type": "wikilink",
              "text": "麗寶集團"
            },
            {
              "type": "text",
              "text": "之營造及資源整合能力，從土地取得、規劃設計到銷售一條龍運作。"
            },
            {
              "type": "wikilink",
              "text": "麗寶集團"
            },
            {
              "type": "text",
              "text": "旗下亦包含"
            },
            {
              "type": "wikilink",
              "text": "麗寶樂園"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "福容大飯店"
            },
            {
              "type": "text",
              "text": "等觀光休閒事業，形成集團綜效。"
            }
          ]
        }
      ],
      "groups": []
    },
