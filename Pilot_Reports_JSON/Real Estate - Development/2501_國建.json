    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "國泰建設"
            },
            {
              "type": "text",
              "text": " (2501，國建) 成立於 1964 年，總部位於台北，隸屬於"
            },
            {
              "type": "wikilink",
              "text": "霖園集團"
            },
            {
              "type": "text",
              "text": "。公司為台灣老牌龍頭建商，以「國泰格局」之高品質住宅聞名，品牌信譽卓著。主要業務為委託營造廠興建國民住宅及商業大樓出租出售，推案遍及全台主要都會區。近年跨足飯店 ("
            },
            {
              "type": "wikilink",
              "text": "國泰飯店觀光事業"
            },
            {
              "type": "text",
              "text": ") 及健康管理業務。集團內營造資源由三井工程支援，形成從開發到施工之垂直整合優勢。"
            },
            {
              "type": "wikilink",
              "text": "霖園集團"
            },
            {
              "type": "text",
              "text": "旗下包含"
            },
            {
              "type": "wikilink",
              "text": "國泰金控"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "國泰人壽"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "國泰世華銀行"
            },
            {
              "type": "text",
              "text": "等金融事業。"
            }
          ]
        }
      ],
      "groups": []
    },
