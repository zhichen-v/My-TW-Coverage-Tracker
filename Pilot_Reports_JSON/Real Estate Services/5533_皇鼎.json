  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "皇鼎建設開發股份有限公司 (5533，Royal Crown Construction) 為台灣中型建設公司，主要在大台北及"
            },
            {
              "type": "wikilink",
              "text": "桃園"
            },
            {
              "type": "text",
              "text": "地區從事住宅大樓開發。公司產品以中高價位住宅為主，注重建築品質與社區規劃。近年推案集中於"
            },
            {
              "type": "wikilink",
              "text": "新北市"
            },
            {
              "type": "text",
              "text": "重劃區及桃園地區，受惠於雙北房價外溢效應帶動之"
            },
            {
              "type": "wikilink",
              "text": "桃園"
            },
            {
              "type": "text",
              "text": "購屋需求。營造合作以知名營造廠如"
            },
            {
              "type": "wikilink",
              "text": "達欣工程"
            },
            {
              "type": "text",
              "text": "等為主。"
            }
          ]
        }
      ],
      "groups": []
    },
