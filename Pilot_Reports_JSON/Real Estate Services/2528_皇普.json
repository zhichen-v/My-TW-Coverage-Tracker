  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "皇普建設 (2528，Huang Pu Construction) 為台灣中型建設公司，主要從事"
            },
            {
              "type": "wikilink",
              "text": "住宅大樓"
            },
            {
              "type": "text",
              "text": "之投資興建與銷售。建案分佈於全台各大都會區及重劃區，包括大台北地區、新竹"
            },
            {
              "type": "wikilink",
              "text": "竹北"
            },
            {
              "type": "text",
              "text": "、桃園"
            },
            {
              "type": "wikilink",
              "text": "青埔"
            },
            {
              "type": "text",
              "text": "重劃區、台中及高雄。公司秉持「以人為本」理念，產品以中價位住宅為主，服務"
            },
            {
              "type": "wikilink",
              "text": "首購族"
            },
            {
              "type": "text",
              "text": "與換屋族群。土地取得方式涵蓋自行規劃用地、地主合建、政府標售及市場資訊蒐集等多元管道。"
            }
          ]
        }
      ],
      "groups": []
    },
