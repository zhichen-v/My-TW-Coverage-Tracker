  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "宏璟建設股份有限公司 (2527，Hung Ching Development) 為台灣知名建設公司，與"
            },
            {
              "type": "wikilink",
              "text": "日月光[[半導體"
            },
            {
              "type": "text",
              "text": "]]集團具有關聯。公司專注於台灣北部地區之住宅與"
            },
            {
              "type": "wikilink",
              "text": "商辦"
            },
            {
              "type": "text",
              "text": "大樓開發，產品定位偏向中高階市場。主要業務涵蓋"
            },
            {
              "type": "wikilink",
              "text": "住宅"
            },
            {
              "type": "text",
              "text": "大樓、商辦大樓之投資興建與銷售，以及"
            },
            {
              "type": "wikilink",
              "text": "不動產"
            },
            {
              "type": "text",
              "text": "租賃收入。公司深耕大"
            },
            {
              "type": "wikilink",
              "text": "台北"
            },
            {
              "type": "text",
              "text": "精華地段，以穩健經營策略著稱。"
            }
          ]
        }
      ],
      "groups": []
    },
