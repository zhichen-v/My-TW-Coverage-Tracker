            {
              "type": "text",
              "text": "開發股份有限公司 (9902，Tidehold Development) 前身為"
            },
            {
              "type": "wikilink",
              "text": "台灣火柴"
            },
            {
              "type": "text",
              "text": "公司 (1938 年成立)，已從火柴製造完全轉型為"
            },
            {
              "type": "wikilink",
              "text": "不動產"
            },
            {
              "type": "text",
              "text": "開發與投資控股公司。主要業務涵蓋"
            },
            {
              "type": "wikilink",
              "text": "住宅"
            },
            {
              "type": "text",
              "text": "及商業大樓之開發、租賃與銷售，以及"
            },
            {
              "type": "wikilink",
              "text": "設備租賃"
            },
            {
              "type": "text",
              "text": " (含小客車出租及"
            },
            {
              "type": "wikilink",
              "text": "電動垃圾車"
            },
            {
              "type": "text",
              "text": "銷售)。公司持有"
            },
            {
              "type": "wikilink",
              "text": "台北"
            },
            {
              "type": "text",
              "text": "精華地段不動產資產，以穩定租金收入為主要獲利來源。近年亦投入"
            },
            {
              "type": "wikilink",
              "text": "環保"
            },
            {
              "type": "text",
              "text": "事業，銷售電動壓縮式油電混合垃圾車。"
            }
          ]
        }
