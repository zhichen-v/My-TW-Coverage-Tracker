                      "text": "半導體產業:"
                    },
                    {
                      "type": "text",
                      "text": " 晶圓代工廠及封測廠產出之封裝膠邊料、"
                    },
                    {
                      "type": "wikilink",
                      "text": "CMP"
                    },
                    {
                      "type": "text",
                      "text": "研磨污泥、廢晶矽泥"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "重工業:"
                    },
                    {
                      "type": "text",
                      "text": " 焚化底渣、重金屬污泥等無機廢棄物"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "環保設備:"
                    },
                    {
                      "type": "text",
                      "text": " 破碎脫水篩分機具、穩定化處理設備、除臭化學藥劑"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "中游 (再生處理)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "成信實業"
                    },
                    {
                      "type": "text",
                      "text": " — 廢棄物清除處理、"
                    },
                    {
                      "type": "wikilink",
                      "text": "球形二氧化矽"
                    },
                    {
                      "type": "text",
                      "text": "純化、矽粉矽碇加工、"
                    },
                    {
                      "type": "wikilink",
                      "text": "SRF"
                    },
                    {
                      "type": "text",
                      "text": " 固體再生燃料生產、污染土地環境整治"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "下游 (再生產品應用)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "半導體材料:"
                    },
                    {
                      "type": "text",
                      "text": " "
                    },
                    {
                      "type": "wikilink",
                      "text": "球形二氧化矽"
                    },
                    {
                      "type": "text",
                      "text": "回售予半導體封裝材料廠"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "鋼鐵業:"
                    },
                    {
                      "type": "text",
                      "text": " 矽粉矽碇作為煉鋼輔材供應鋼鐵廠"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "營建業:"
                    },
                    {
                      "type": "text",
                      "text": " "
                    },
                    {
                      "type": "wikilink",
                      "text": "CLSM"
                    },
                    {
                      "type": "text",
                      "text": "（控制性低強度回填材料）再生粒料供應預拌混凝土廠"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "能源:"
                    },
                    {
                      "type": "text",
                      "text": " "
                    },
                    {
                      "type": "wikilink",
                      "text": "SRF"
                    },
                    {
                      "type": "text",
                      "text": " 供應焚化發電廠"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
