  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "是方電訊股份有限公司 (6561，Chief Telecom) 隸屬於"
            },
            {
              "type": "wikilink",
              "text": "中華電"
            },
            {
              "type": "text",
              "text": "集團(為其最大股東)，是全台規模最大且保持高度中立的電信級網際網路"
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "(IDC)營運商。「是方」在台灣雲端基礎建設中極具戰略地位，不僅是全台最大的海纜交換中心，更是各大國際公有雲(AWS、Azure、GCP、Oracle等)落地台灣的關鍵直連節點(Direct Connect)。隨著"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "算力需求噴發，是方全新完工的第四棟綠能智慧"
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "(LY2)專注於提供支援輝達("
            },
            {
              "type": "wikilink",
              "text": "NVIDIA"
            },
            {
              "type": "text",
              "text": ")等HPC"
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "的高用電機櫃，成功轉型為"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "雲端算力服務的「包租公」。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 第一類電信業者(提供光纖網路、頻寬資源)、"
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "製造商、機房設備廠及綠電供應商。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "是方電訊"
            },
            {
              "type": "text",
              "text": " (電信級高密度IDC機房運營、雲端運算應用服務、企業私有雲及數據網路交換業務)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 大型"
            },
            {
              "type": "wikilink",
              "text": "雲端服務"
            },
            {
              "type": "text",
              "text": "供應商("
            },
            {
              "type": "wikilink",
              "text": "CSP"
            },
            {
              "type": "text",
              "text": ")、跨國社群媒體/電商巨頭、金融機構、遊戲娛樂業及各類企業用戶。"
            }
          ]
        }
      ],
      "groups": []
    },
