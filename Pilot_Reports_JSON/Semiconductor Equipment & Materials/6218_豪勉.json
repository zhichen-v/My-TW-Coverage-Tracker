            },
            {
              "type": "text",
              "text": ": 歐美日韓等國際"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "/光電設備原廠，以及全球知名的網路通訊硬體與資安軟體原廠。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
