    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "鈺寶科技 (3150) 是一家專業的 "
            },
            {
              "type": "wikilink",
              "text": "IC 設計"
            },
            {
              "type": "text",
              "text": "公司，專注於高效能低功耗"
            },
            {
              "type": "wikilink",
              "text": "無線音訊傳輸"
            },
            {
              "type": "text",
              "text": "晶片及模組設計。公司核心技術為無線數位音視訊傳輸，採用 "
            },
            {
              "type": "wikilink",
              "text": "CMOS"
            },
            {
              "type": "text",
              "text": " 製程。競爭同業包括 "
            },
            {
              "type": "wikilink",
              "text": "Qualcomm"
            },
            {
              "type": "text",
              "text": " (aptX) 及 "
            },
            {
              "type": "wikilink",
              "text": "Airoha"
            },
            {
              "type": "text",
              "text": "，產品廣泛應用於"
            },
            {
              "type": "wikilink",
              "text": "無線耳機"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "無線音響"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "無線麥克風"
            },
            {
              "type": "text",
              "text": "及家電音響設備。公司為全球無線音訊傳輸技術的領導廠商之一。"
            }
          ]
        }
      ],
