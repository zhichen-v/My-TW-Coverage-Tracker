    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "世禾科技 (Shih Her Technologies) 為台灣 "
            },
            {
              "type": "strong",
              "text": "半導體與光電設備清洗"
            },
            {
              "type": "text",
              "text": " 龍頭廠商。\n專注於 "
            },
            {
              "type": "strong",
              "text": "[[PVD]]/[[CVD]]/Etch"
            },
            {
              "type": "text",
              "text": " 等製程設備零組件的 "
            },
            {
              "type": "strong",
              "text": "精密清洗"
            },
            {
              "type": "text",
              "text": " 與 "
            },
            {
              "type": "strong",
              "text": "再生處理"
            },
            {
              "type": "text",
              "text": " (Clean & Reborn)。\n主要服務 "
            },
            {
              "type": "strong",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": " (佔營收大宗) 與 "
            },
            {
              "type": "strong",
              "text": "面板"
            },
            {
              "type": "text",
              "text": " 產業。\n技術能力涵蓋先進製程 (如 3nm/2nm) 潔淨需求，為 "
            },
            {
              "type": "strong",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": " 主要清洗夥伴。"
            }
          ]
        }
      ],
