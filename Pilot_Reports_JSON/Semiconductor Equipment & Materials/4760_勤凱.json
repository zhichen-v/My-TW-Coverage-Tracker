    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "勤凱科技 (4760) 是一家專業的電子"
            },
            {
              "type": "wikilink",
              "text": "導電漿"
            },
            {
              "type": "text",
              "text": "製造商，主力產品為"
            },
            {
              "type": "wikilink",
              "text": "銀漿"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "銅漿"
            },
            {
              "type": "text",
              "text": "，應用於"
            },
            {
              "type": "wikilink",
              "text": "電感"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "電阻"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "MLCC"
            },
            {
              "type": "text",
              "text": " (積層陶瓷電容) 等被動元件的電路連接。公司產品為電子零組件中不可或缺的關鍵材料，市場涵蓋台灣、中國及韓國。近年積極布局半導體化學品、高階 AI 用"
            },
            {
              "type": "wikilink",
              "text": "合金膏"
            },
            {
              "type": "text",
              "text": "及先進"
            },
            {
              "type": "wikilink",
              "text": "散熱材料"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
      ],
      "groups": []
    },
