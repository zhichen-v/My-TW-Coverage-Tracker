          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "嘉晶電子 (3016) 是"
            },
            {
              "type": "wikilink",
              "text": "漢磊投控"
            },
            {
              "type": "text",
              "text": "旗下的專業"
            },
            {
              "type": "wikilink",
              "text": "磊晶"
            },
            {
              "type": "wikilink",
              "text": "矽晶圓"
            },
            {
              "type": "text",
              "text": "廠，為台灣唯一能量產 4 吋及 6 吋"
            },
            {
              "type": "wikilink",
              "text": "碳化矽"
            },
            {
              "type": "text",
              "text": " (SiC) "
            },
            {
              "type": "wikilink",
              "text": "磊晶"
            },
            {
              "type": "text",
              "text": "及 6 吋"
            },
            {
              "type": "wikilink",
              "text": "氮化鎵"
            },
            {
              "type": "text",
              "text": " (GaN) "
            },
            {
              "type": "wikilink",
              "text": "磊晶"
            },
            {
              "type": "text",
              "text": "的廠商。公司業務涵蓋矽"
            },
            {
              "type": "wikilink",
              "text": "磊晶"
            },
            {
              "type": "text",
              "text": "代工 (占 2024 年營收約 60%) 及"
            },
            {
              "type": "wikilink",
              "text": "磊晶"
            },
            {
              "type": "wikilink",
              "text": "矽晶圓"
            },
            {
              "type": "text",
              "text": "生產 (約 40%)，產品應用於功率元件、"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "智慧電網"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "儲能系統"
            },
            {
