    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "久元電子 (6261) 是一家半導體測試代工及設備製造商，業務涵蓋"
            },
            {
              "type": "wikilink",
              "text": "晶圓測試"
            },
            {
              "type": "text",
              "text": " (CP)、"
            },
            {
              "type": "wikilink",
              "text": "成品測試"
            },
            {
              "type": "text",
              "text": " (FT)、"
            },
            {
              "type": "wikilink",
              "text": "系統級測試"
            },
            {
              "type": "text",
              "text": " (SLT) 及測試程式開發。設備產品包括 IC 測試機、"
            },
            {
              "type": "wikilink",
              "text": "分選機"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "固晶機"
            },
            {
              "type": "text",
              "text": "及 AI 相關檢測設備。2025 上半年測試代工占營收 49%、設備銷售占 39%。主要客戶"
            },
            {
              "type": "wikilink",
              "text": "晶元光電"
            },
            {
              "type": "text",
              "text": "占營收 23.5%。"
            }
          ]
        }
      ],
