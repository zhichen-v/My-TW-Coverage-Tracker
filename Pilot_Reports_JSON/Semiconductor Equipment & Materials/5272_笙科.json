          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "笙科電子 (5272) 是亞洲唯一同時專長於 "
            },
            {
              "type": "wikilink",
              "text": "SRD"
            },
            {
              "type": "text",
              "text": " (短距離無線通訊) 及 "
            },
            {
              "type": "wikilink",
              "text": "LNB"
            },
            {
              "type": "text",
              "text": " (低雜訊降頻器) 之 "
            },
            {
              "type": "wikilink",
              "text": "RF IC"
            },
            {
              "type": "text",
              "text": " 設計公司，前身為聯笙無線事業部門。公司專注以 "
            },
            {
              "type": "wikilink",
              "text": "CMOS"
            },
            {
              "type": "text",
              "text": " 製程開發射頻半導體晶片，產品應用於"
            },
            {
              "type": "wikilink",
              "text": "無線滑鼠"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "無線鍵盤"
            },
            {
              "type": "text",
              "text": "、遙控器、"
            },
            {
              "type": "wikilink",
              "text": "衛星電視"
            },
            {
              "type": "text",
              "text": "接收及 "
            },
            {
              "type": "wikilink",
              "text": "物聯網"
            },
            {
              "type": "text",
              "text": " 無線通訊模組。"
            }
          ]
        }
