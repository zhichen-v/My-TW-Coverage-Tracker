  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "旺矽科技股份有限公司 (6223) 是一家具備全球領導地位的"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "晶圓測試"
            },
            {
              "type": "wikilink",
              "text": "探針卡"
            },
            {
              "type": "text",
              "text": "大廠。旺矽是全球前五大"
            },
            {
              "type": "wikilink",
              "text": "探針卡"
            },
            {
              "type": "text",
              "text": "製造商，更在懸臂式(CPC)與垂直式(VPC)"
            },
            {
              "type": "wikilink",
              "text": "探針卡"
            },
            {
              "type": "text",
              "text": "領域稱霸全球。公司提供一站式量測解決方案，涵蓋"
            },
            {
              "type": "wikilink",
              "text": "探針卡"
            },
            {
              "type": "text",
              "text": "、測試機台及溫控系統。近年來，受惠於"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "晶片及高效能運算(HPC)的強勁測試需求，旺矽的高階VPC"
            },
            {
              "type": "wikilink",
              "text": "探針卡"
            },
            {
              "type": "text",
              "text": "與微機電(MEMS)"
            },
            {
              "type": "wikilink",
              "text": "探針卡"
            },
            {
              "type": "text",
              "text": "出貨大增，並成功打入"
            },
            {
              "type": "wikilink",
              "text": "NVIDIA"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "AMD"
            },
            {
              "type": "text",
              "text": "等國際"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "晶片巨頭的測試供應鏈，成為"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "測試鏈中的核心受惠者。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 探針金屬線材(鎢/鈹銅等合金)、特殊印刷電路板("
            },
            {
              "type": "wikilink",
              "text": "PCB"
            },
            {
              "type": "text",
              "text": "，正提高自製率)、陶瓷基板及機電加工零件。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "旺矽科技"
            },
            {
              "type": "text",
              "text": " (高階晶圓測試"
            },
            {
              "type": "wikilink",
              "text": "探針卡"
            },
            {
              "type": "text",
              "text": "CPC/VPC/MEMS、光電"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "測試系統及溫控儀器之研發製造)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "晶圓代工廠(Foundry)、專業封裝測試廠(OSAT)、IC設計公司(Fabless)及光電廠。"
            }
          ]
        }
      ],
      "groups": []
    },
