    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "景碩科技 (3189) 是全球 "
            },
            {
              "type": "wikilink",
              "text": "Flip Chip"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "覆晶封裝"
            },
            {
              "type": "text",
              "text": ") IC 載板前三大供應商，為"
            },
            {
              "type": "wikilink",
              "text": "和碩"
            },
            {
              "type": "text",
              "text": "轉投資公司。公司主力產品為 "
            },
            {
              "type": "wikilink",
              "text": "BGA"
            },
            {
              "type": "text",
              "text": " 基板、"
            },
            {
              "type": "wikilink",
              "text": "ABF 載板"
            },
            {
              "type": "text",
              "text": "及 "
            },
            {
              "type": "wikilink",
              "text": "BT 載板"
            },
            {
              "type": "text",
              "text": "，服務全球頂級 IC 設計及 IDM 客戶。子公司"
            },
            {
              "type": "wikilink",
              "text": "晶碩"
            },
            {
              "type": "text",
              "text": " (6491) 專攻高階 "
            },
            {
              "type": "wikilink",
              "text": "ABF 載板"
            },
            {
              "type": "text",
              "text": "。生產據點涵蓋台灣新屋、新豐及蘇州。"
            }
          ]
        }
      ],
      "groups": []
    },
