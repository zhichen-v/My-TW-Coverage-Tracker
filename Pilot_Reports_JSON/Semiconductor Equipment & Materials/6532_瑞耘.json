  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "瑞耘科技股份有限公司 (6532) 是一家專精於"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "前段製程設備之關鍵零組件製造商。瑞耘具備深厚的精密金屬與特殊陶瓷加工能力，其主力產品包含晶圓夾持環(Retaining Ring)、靜電吸盤(E-Chuck)、氣體擴散盤等，廣泛應用於"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "wikilink",
              "text": "蝕刻"
            },
            {
              "type": "text",
              "text": "(Etch)、化學機械平坦化("
            },
            {
              "type": "wikilink",
              "text": "CMP"
            },
            {
              "type": "text",
              "text": ")及薄膜沉積("
            },
            {
              "type": "wikilink",
              "text": "CVD"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "PVD"
            },
            {
              "type": "text",
              "text": ")等高階設備中。瑞耘以此獨特技術不僅提供晶圓廠耗材，更成功打入全球最大"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "設備龍頭應用材料("
            },
            {
              "type": "wikilink",
              "text": "Applied Materials"
            },
            {
              "type": "text",
              "text": ")的原廠供應鏈("
            },
            {
              "type": "wikilink",
              "text": "OEM"
            },
            {
              "type": "text",
              "text": ")長達十數年，並積極擴展自製的濕式製程設備(如晶圓旋乾機SRD)。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 頂級特種金屬加工料(如鈦/鋁合金)、精密工程塑膠(PEEK)、特殊石英及精密陶瓷材料(氧化鋁/氮化鋁)。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "瑞耘科技"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "前段製程設備關鍵零組件之精密加工加工製造、及濕式製程設備組裝)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 全球大型"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "設備原廠("
            },
            {
              "type": "wikilink",
              "text": "OEM"
            },
            {
              "type": "text",
              "text": ")、晶圓代工廠(Foundry)、整合元件廠(IDM)及各式光電面板廠。"
            }
          ]
        }
      ],
      "groups": []
    },
    "customer_supplier": {
      "heading": "主要客戶及供應商",
      "blocks": [],
      "groups": [
        {
          "title": "主要客戶",
          "blocks": [
            {
              "type": "paragraph",
              "segments": [
                {
                  "type": "text",
                  "text": "*   美商應用材料("
                },
                {
                  "type": "wikilink",
                  "text": "Applied Materials"
                },
                {
                  "type": "text",
                  "text": "，為瑞耘最大客戶佔營收六成)，以及"
                },
                {
                  "type": "wikilink",
                  "text": "台積電"
                },
                {
                  "type": "text",
                  "text": "、"
                },
                {
                  "type": "wikilink",
                  "text": "日月光投控"
                },
                {
                  "type": "text",
                  "text": "等本土晶圓/封測大廠。"
                }
              ]
            }
          ]
        },
        {
          "title": "主要供應商",
          "blocks": [
            {
              "type": "paragraph",
              "segments": [
                {
                  "type": "text",
                  "text": "*   國內外各大特種金屬/高階塑膠材料貿易商，以及具備高純度認證之精密陶瓷燒結與表面處理廠。"
                }
              ]
            }
          ]
        }
      ]
    },
