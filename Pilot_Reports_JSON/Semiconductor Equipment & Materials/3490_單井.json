  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "單井工業 (3490) 是一家專業的半導體及 "
            },
            {
              "type": "wikilink",
              "text": "LED"
            },
            {
              "type": "text",
              "text": " 封裝用"
            },
            {
              "type": "wikilink",
              "text": "模具"
            },
            {
              "type": "text",
              "text": "及自動化設備製造商。公司主力產品為 LED、半導體及"
            },
            {
              "type": "wikilink",
              "text": "二極體"
            },
            {
              "type": "text",
              "text": "封裝用模具，以及封裝後段製程所需之自動化設備。產品應用於 "
            },
            {
              "type": "wikilink",
              "text": "QFN"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "SOP"
            },
            {
              "type": "text",
              "text": " 等封裝型態之模具。國內 LED 及半導體一、二線大廠均為長期客戶，如 "
            },
            {
              "type": "wikilink",
              "text": "億光電子"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "日月光投控"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "矽品"
            },
            {
              "type": "text",
              "text": " 等封裝廠。近年跨足"
            },
            {
              "type": "wikilink",
              "text": "太陽能"
            },
            {
              "type": "text",
              "text": "光伏電站營運及售電。"
            }
          ]
        }
      ],
      "groups": []
    },
