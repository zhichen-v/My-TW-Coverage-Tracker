    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "聯策科技 (6658) 是一家專業的半導體設備及"
            },
            {
              "type": "wikilink",
              "text": "工業自動化"
            },
            {
              "type": "text",
              "text": "解決方案供應商，提供半導體製程相關的溫控設備，包括 "
            },
            {
              "type": "wikilink",
              "text": "CVD"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "蝕刻"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "清洗"
            },
            {
              "type": "text",
              "text": "製程用溫控、自動化系統及技術服務。公司產品應用於晶圓製造、封裝測試及面板製程，服務台灣及亞太地區半導體客戶。產品涵蓋 "
            },
            {
              "type": "wikilink",
              "text": "Chiller"
            },
            {
              "type": "text",
              "text": " 冷卻系統、"
            },
            {
              "type": "wikilink",
              "text": "加熱器"
            },
            {
              "type": "text",
              "text": "及精密溫控模組。"
            }
          ]
        }
      ],
      "groups": []
    },
