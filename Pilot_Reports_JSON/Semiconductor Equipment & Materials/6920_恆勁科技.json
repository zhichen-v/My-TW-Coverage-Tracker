    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "恆勁科技 (6920) 是一家專業的半導體"
            },
            {
              "type": "wikilink",
              "text": "先進封裝"
            },
            {
              "type": "text",
              "text": "基板製造商，開發 "
            },
            {
              "type": "wikilink",
              "text": "C2iM"
            },
            {
              "type": "text",
              "text": " 技術平台，以 Molding 材料生產 IC 載板，應用於 "
            },
            {
              "type": "wikilink",
              "text": "XQFN"
            },
            {
              "type": "text",
              "text": " 高階"
            },
            {
              "type": "wikilink",
              "text": "導線架"
            },
            {
              "type": "text",
              "text": "、線圈基板及 "
            },
            {
              "type": "wikilink",
              "text": "FOPLP"
            },
            {
              "type": "text",
              "text": " 扇出型面板級封裝。公司專注於"
            },
            {
              "type": "wikilink",
              "text": "第三代半導體"
            },
            {
              "type": "text",
              "text": "功率元件封裝市場，產品瞄準車用電源管理 IC、"
            },
            {
              "type": "wikilink",
              "text": "AI 伺服器"
            },
            {
              "type": "text",
              "text": "電源晶片及 "
            },
            {
              "type": "wikilink",
              "text": "氮化鎵"
            },
            {
              "type": "text",
              "text": " 功率元件。經過 7 年歐美大廠認證，預計量產訂單逐步放量。"
            }
          ]
        }
      ],
      "groups": []
    },
