  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "晶瑞光 (6787) 是一家專業的光學"
            },
            {
              "type": "wikilink",
              "text": "濾光片"
            },
            {
              "type": "text",
              "text": "及光學元件製造商，產品涵蓋"
            },
            {
              "type": "wikilink",
              "text": "窄帶通過濾光片"
            },
            {
              "type": "text",
              "text": " (NBPF)、"
            },
            {
              "type": "wikilink",
              "text": "藍色玻璃"
            },
            {
              "type": "text",
              "text": "濾光片 (NBG)、UVIR/IR Cut 濾光片、高反射濾光片、抗反射濾光片、分光鏡及二向色濾光片。產品應用於"
            },
            {
              "type": "wikilink",
              "text": "3D 感測"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "ToF"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "ADAS"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "DMS"
            },
            {
              "type": "text",
              "text": " 及黃光製程。近年開發雙光模組及黃光製程產品，瞄準商用"
            },
            {
              "type": "wikilink",
              "text": "無人機"
            },
            {
              "type": "text",
              "text": "、智慧監控及"
            },
            {
              "type": "wikilink",
              "text": "協作機器人"
            },
            {
              "type": "text",
              "text": "等新興應用。"
            }
          ]
        }
      ],
