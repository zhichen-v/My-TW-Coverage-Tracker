            },
            {
              "type": "text",
              "text": ")、主機板廠、"
            },
            {
              "type": "wikilink",
              "text": "網通"
            },
            {
              "type": "text",
              "text": "設備商、電源供應器廠及車用零組件廠。"
            }
          ]
        }
