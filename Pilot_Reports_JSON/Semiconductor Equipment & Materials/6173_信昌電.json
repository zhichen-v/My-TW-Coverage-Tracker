  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "信昌電子陶瓷股份有限公司 (6173) 隸屬於"
            },
            {
              "type": "wikilink",
              "text": "華新科"
            },
            {
              "type": "text",
              "text": "技集團，是一家專注於利基型被動元件與關鍵陶瓷材料(介電瓷粉)的製造商。信昌電具備從「原料瓷粉」到「元件成品」的垂直整合與100%台灣製造優勢。其核心產品聚焦於高功率、高電壓及大尺寸的特殊型"
            },
            {
              "type": "wikilink",
              "text": "MLCC"
            },
            {
              "type": "text",
              "text": "(積層陶瓷電容)與電阻/電感。近年來受惠於"
            },
            {
              "type": "wikilink",
              "text": "AI[[伺服器"
            },
            {
              "type": "text",
              "text": "]]("
            },
            {
              "type": "wikilink",
              "text": "MLCC"
            },
            {
              "type": "text",
              "text": "用量為傳統的十倍)、"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": "基地台及快充等高階應用需求爆發，信昌電在高規元件市場佔有重要地位。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
