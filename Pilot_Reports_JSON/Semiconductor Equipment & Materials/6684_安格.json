    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "安格科技 (6684) 是一家專業的 "
            },
            {
              "type": "wikilink",
              "text": "IC 設計"
            },
            {
              "type": "text",
              "text": "公司，由矽谷及台灣半導體研發菁英於 2010 年創立。公司核心技術為超高速"
            },
            {
              "type": "wikilink",
              "text": "實體層介面"
            },
            {
              "type": "text",
              "text": " (PHY) IP 設計及相關應用 IC。產品包括高速傳輸介面 IC、"
            },
            {
              "type": "wikilink",
              "text": "USB"
            },
            {
              "type": "text",
              "text": " 控制器及相關 IP 授權，應用於消費電子、"
            },
            {
              "type": "wikilink",
              "text": "工業控制"
            },
            {
              "type": "text",
              "text": "及通訊設備。產品支援 "
            },
            {
              "type": "wikilink",
              "text": "USB4"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "PCIe"
            },
            {
              "type": "text",
              "text": " 等高速傳輸介面規格。"
            }
          ]
        }
      ],
