              "type": "wikilink",
              "text": "雷射二極體"
            },
            {
              "type": "text",
              "text": " (LD) 及 "
            },
            {
              "type": "wikilink",
              "text": "LED"
            },
            {
              "type": "text",
              "text": "，主要應用於"
            },
            {
              "type": "wikilink",
              "text": "光通訊"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "矽光子"
            },
            {
              "type": "text",
              "text": " (SiPho)/"
