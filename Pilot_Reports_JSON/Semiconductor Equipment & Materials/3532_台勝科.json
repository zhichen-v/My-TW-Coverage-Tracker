      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "台勝科 (3532，"
            },
            {
              "type": "wikilink",
              "text": "台塑"
            },
            {
              "type": "text",
              "text": "勝高) 是"
            },
            {
              "type": "wikilink",
              "text": "台塑集團"
            },
            {
              "type": "text",
              "text": "與日本 "
            },
            {
              "type": "wikilink",
              "text": "SUMCO"
            },
            {
              "type": "text",
              "text": " 合資的專業"
            },
            {
              "type": "wikilink",
              "text": "矽晶圓"
            },
            {
              "type": "text",
              "text": "製造商，生產 8 吋及 12 吋"
            },
            {
              "type": "wikilink",
              "text": "矽晶圓"
            },
            {
              "type": "text",
              "text": "，為台灣最大"
            },
            {
              "type": "wikilink",
              "text": "矽晶圓"
            },
            {
              "type": "text",
              "text": "廠之一。產品涵蓋拋光晶圓、退火晶圓及"
            },
            {
              "type": "wikilink",
              "text": "磊晶"
            },
            {
              "type": "text",
              "text": "晶圓，應用於邏輯及記憶體晶片製造。12 吋產品中記憶體與邏輯晶圓比約 6:4，拋光晶圓占比超過 60%。公司導入 "
            },
            {
              "type": "wikilink",
              "text": "SUMCO"
            },
            {
              "type": "text",
              "text": " 先進技術，在 "
            },
            {
              "type": "wikilink",
              "text": "HBM"
            },
            {
              "type": "text",
              "text": " 等高階產品具品質優勢。"
            }
          ]
        }
      ],
      "groups": []
    },
