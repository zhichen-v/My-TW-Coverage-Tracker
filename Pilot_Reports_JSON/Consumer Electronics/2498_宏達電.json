  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "宏達國際電子股份有限公司 (HTC Corporation) 成立於 1997 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "新北"
            },
            {
              "type": "text",
              "text": "。公司曾為全球智慧型手機領導品牌 (Android 手機先驅)。近年轉型專注於 "
            },
            {
              "type": "strong",
              "text": "虛擬實境 (VR)"
            },
            {
              "type": "text",
              "text": " 與 "
            },
            {
              "type": "strong",
              "text": "元宇宙 ([[Meta]]verse)"
            },
            {
              "type": "text",
              "text": " 領域，推出 "
            },
            {
              "type": "wikilink",
              "text": "VIVE"
            },
            {
              "type": "text",
              "text": " 系列頭戴式顯示器 (Headsets) 及 "
            },
            {
              "type": "wikilink",
              "text": "VIVERSE"
            },
            {
              "type": "text",
              "text": " 開放式元宇宙平台。公司仍保留部分智慧型手機業務 (U 系列)，並積極發展 "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": " 眼鏡及 "
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": " 專網解決方案。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "宏達電位於消費電子產業鏈品牌與設計端。\n*   "
            },
            {
              "type": "strong",
              "text": "上游 (組件):"
            },
            {
              "type": "text",
              "text": "\n*   "
            },
            {
              "type": "strong",
              "text": "晶片:"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "Qualcomm"
            },
            {
              "type": "text",
              "text": " (XR 晶片), "
            },
            {
              "type": "wikilink",
              "text": "VIA Labs"
            },
            {
              "type": "text",
              "text": " (USB/Audio 晶片).\n*   "
            },
            {
              "type": "strong",
              "text": "光學/感測:"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "ZEISS"
            },
            {
              "type": "text",
              "text": " (鏡片), 義明 (感測晶片).\n*   "
            },
            {
              "type": "strong",
              "text": "顯示:"
            },
            {
              "type": "text",
              "text": " 面板供應商。\n*   "
            },
            {
              "type": "strong",
              "text": "中游 (製造):"
            },
            {
              "type": "text",
              "text": " 自有產線與委外組裝。\n*   "
            },
            {
              "type": "strong",
              "text": "下游 (應用/客戶):"
            },
            {
              "type": "text",
              "text": "\n*   "
            },
            {
              "type": "strong",
              "text": "消費 (B2C):"
            },
            {
              "type": "text",
              "text": " 遊戲玩家、科技愛好者 (VIVE Flow, XR Elite).\n*   "
            },
            {
              "type": "strong",
              "text": "企業 (B2B):"
            },
            {
              "type": "text",
              "text": " 教育、醫療、建築設計、軍事模擬 (VIVE Pro, VIVE Focus)."
            }
          ]
        }
      ],
      "groups": []
    },
