    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "美隆工業股份有限公司 (2477) 成立於 1973 年，總部位於台灣桃園。公司為全球知名揚聲器設計與製造商，產品涵蓋家用音響、"
            },
            {
              "type": "wikilink",
              "text": "Soundbar"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "智慧音箱"
            },
            {
              "type": "text",
              "text": "、車用揚聲器及專業音響。生產基地遍及台灣、中國及印尼。營運模式以 "
            },
            {
              "type": "wikilink",
              "text": "ODM"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "OEM"
            },
            {
              "type": "text",
              "text": " 代工為主，服務國際知名音響品牌。"
            }
          ]
        }
      ],
      "groups": []
    },
