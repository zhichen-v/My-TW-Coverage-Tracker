  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "明泰科技 (Alpha Networks) 為佳世達 (Qisda) 集團旗下"
            },
            {
              "type": "wikilink",
              "text": "網通"
            },
            {
              "type": "text",
              "text": "旗艦大廠，具備強大的研發與製造垂直整合能力。\n公司致力於提供全方位"
            },
            {
              "type": "wikilink",
              "text": "網通"
            },
            {
              "type": "text",
              "text": "解決方案，產品線涵蓋 "
            },
            {
              "type": "strong",
              "text": "乙太網路交換器"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "strong",
              "text": "行動通信設備 (5G/LTE)"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "strong",
              "text": "無線寬頻網路"
            },
            {
              "type": "text",
              "text": " 及 "
            },
            {
              "type": "strong",
              "text": "數位多媒體"
            },
            {
              "type": "text",
              "text": "。\n核心戰略與成長動能：\n1.  "
            },
            {
              "type": "strong",
              "text": "AI 資料中心布局"
            },
            {
              "type": "text",
              "text": ": 針對生成式 "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": " 帶來的大頻寬需求，加速開發 "
            },
            {
              "type": "strong",
              "text": "400G/800G"
            },
            {
              "type": "text",
              "text": " 及下一代 "
            },
            {
              "type": "strong",
              "text": "Tomahawk 6 (1.6T)"
            },
            {
              "type": "text",
              "text": " 高速交換器方案。\n2.  "
            },
            {
              "type": "strong",
              "text": "5G 專網與 Open RAN"
            },
            {
              "type": "text",
              "text": ": 積極投入 "
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": " 基站與核心網技術，搶占全球企業專網與開放網路架構商機。\n3.  "
            },
            {
              "type": "strong",
              "text": "車載網路與感測"
            },
            {
              "type": "text",
              "text": ": 研發毫米波雷達與車用乙太網路技術，佈局自駕車與智慧"
            },
            {
              "type": "wikilink",
              "text": "車聯網"
            },
            {
              "type": "text",
              "text": "生態系。\n4.  "
            },
            {
              "type": "strong",
              "text": "佳世達集團綜效"
            },
            {
              "type": "text",
              "text": ": 利用集團資源優化採購與製造效率，提供客戶更具競爭力的 "
            },
            {
              "type": "wikilink",
              "text": "ODM"
            },
            {
              "type": "text",
              "text": "/JDM 服務。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [],
      "groups": [
        {
          "title": "上游 (核心晶片與基材)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "高速晶片與機構件採購:"
                    },
                    {
                      "type": "text",
                      "text": " 海量採購來自於全球大廠之網通核心控制處理晶片 (如 "
                    },
                    {
                      "type": "wikilink",
                      "text": "Broadcom 博通"
                    },
                    {
                      "type": "text",
                      "text": "、"
                    },
                    {
                      "type": "wikilink",
                      "text": "Realtek 瑞昱"
                    },
                    {
                      "type": "text",
                      "text": "、"
                    },
                    {
                      "type": "wikilink",
                      "text": "MediaTek 聯發科"
                    },
                    {
                      "type": "text",
                      "text": ")、高階光通訊主被動交換元件，以及車用 PCB 載板與散熱電源元件。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "中游 (網通系統設備製造)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "集團網通旗艦主艦:"
                    },
                    {
                      "type": "text",
                      "text": " "
                    },
                    {
                      "type": "strong",
                      "text": "明泰 (3380)"
                    },
                    {
                      "type": "text",
                      "text": " (隸屬於明基"
                    },
                    {
                      "type": "wikilink",
                      "text": "友達"
                    },
                    {
                      "type": "text",
                      "text": "集團，具備強大硬體製造及軟體定義網路 (SDN) 開發之全球網通設備代工/設計 (ODM/JDM) 巨頭。產品無所不包，從 400G/800G 頂規資料中心交換器、5G 小基站、Wi-Fi 7 無線分享器到車聯網毫米波雷達，於台灣、中國大陸及越南皆設有龐大優質產能)。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "下游 (品牌商、電信商與雲端)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "萬物互聯的終極出口:"
                    },
                    {
                      "type": "text",
                      "text": " 提供一站式的完整網通系統設計大樓整合，硬體直接大量出貨給全球一線網通品牌商、歐美強勢基礎電信服務商、超大型雲端資料中心 (CSP)，及智慧車輛零組件 Tier 1 供應鏈。"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "customer_supplier": {
      "heading": "主要客戶及供應商",
      "blocks": [],
      "groups": [
        {
          "title": "主要客戶",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "全球一線雲端大廠與電信商:"
                    },
                    {
                      "type": "text",
                      "text": " 極度針對生成式 AI 帶來恐怖的大頻寬吞吐需求，其高階 400G/800G 甚至研發中之 1.6T 網路高頻寬交換器，已大量出貨給北美、歐洲與印度之大型雲端資料中心 (CSP) 與超級電信營運商。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "國際電信品牌與電動車終端廠:"
                    },
                    {
                      "type": "text",
                      "text": " 除常年承接全球知名網通品牌 (包含同集團自有老字號品牌 "
                    },
                    {
                      "type": "wikilink",
                      "text": "友訊 D-Link"
                    },
                    {
                      "type": "text",
                      "text": ") 之大型 ODM 長單，近年憑藉絕佳實力更被瘋傳點名為美系 "
                    },
                    {
                      "type": "wikilink",
                      "text": "Tesla 特斯拉"
                    },
                    {
                      "type": "text",
                      "text": " 及 "
                    },
                    {
                      "type": "wikilink",
                      "text": "Apple 蘋果"
                    },
                    {
                      "type": "text",
                      "text": " (透過生態系供應鏈) 之網通聯網終端裝置核心合作供應商。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "主要供應商",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "網通晶片寡佔龍頭:"
                    },
                    {
                      "type": "text",
                      "text": " 針對其未來重頭戲之最高階 1.6T 水冷世代交換器，極度高度且緊密地採用全球網通矽智財絕對霸權 "
                    },
                    {
                      "type": "wikilink",
                      "text": "Broadcom 博通"
                    },
                    {
                      "type": "text",
                      "text": " (及旗下廠商) 所提供的旗艦網路交換晶片，確保達到全世界最高的資料吞吐量效能。"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
