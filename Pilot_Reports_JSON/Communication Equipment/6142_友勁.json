  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "友勁科技 (6142，Alpha Networks) 為"
            },
            {
              "type": "wikilink",
              "text": "友訊科技"
            },
            {
              "type": "text",
              "text": " (2332，"
            },
            {
              "type": "wikilink",
              "text": "D-Link"
            },
            {
              "type": "text",
              "text": ") 轉投資之專業網通設備製造商，隸屬"
            },
            {
              "type": "wikilink",
              "text": "台鋼集團"
            },
            {
              "type": "text",
              "text": "。公司堅持「台灣製造 (MIT)」以確保品質與資訊安全，近年全面轉型，汰換低毛利消費型網通產品，將營運重心集中於高毛利的商用/企業級網通市場。"
            }
          ]
        },
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "主力產品涵蓋 2.5G/10G/100G 規格之 L2/L3 企業級網路交換器、"
            },
            {
              "type": "wikilink",
              "text": "Wi-Fi 7"
            },
            {
              "type": "text",
              "text": " 企業級智慧型基地台 (AP)、以及小型資料中心交換器。公司在美國對 "
            },
            {
              "type": "wikilink",
              "text": "TP-Link"
            },
            {
              "type": "text",
              "text": " 等中系網通產品實施禁令的「去中化」趨勢下，以 100% 台灣製造優勢成為客戶產能轉移的首選。"
            }
          ]
        }
      ],
      "groups": []
    },
