  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "潤德室內裝修設計工程 (6881) 隸屬"
            },
            {
              "type": "wikilink",
              "text": "潤泰集團"
            },
            {
              "type": "text",
              "text": "，為大型法人級室內設計裝修事業體。主要業務涵蓋：(1) 商業空間 — 承攬"
            },
            {
              "type": "wikilink",
              "text": "CITYLINK"
            },
            {
              "type": "text",
              "text": "松山/南港/內湖/三重商場裝修，為"
            },
            {
              "type": "wikilink",
              "text": "蔦屋書店"
            },
            {
              "type": "text",
              "text": "打造松山壹號店；(2) 國際企業商辦 — 服務"
            },
            {
              "type": "wikilink",
              "text": "Microsoft"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "LINE"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Google"
            },
            {
              "type": "text",
              "text": "硬體研發中心、"
            },
            {
              "type": "wikilink",
              "text": "Shiseido"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Porsche"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Schneider Electric"
            },
            {
              "type": "text",
              "text": "等；(3) 高階住宅 — "
            },
            {
              "type": "wikilink",
              "text": "潤泰新"
            },
            {
              "type": "text",
              "text": "松濤苑等高端住宅公設裝修；(4) 醫療空間 — "
            },
            {
              "type": "wikilink",
              "text": "臺北榮民總醫院"
            },
            {
              "type": "text",
              "text": "重粒子癌症治療中心；(5) 公共文化 — "
            },
            {
              "type": "wikilink",
              "text": "經國七海文化園區"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "政治大學"
            },
            {
              "type": "text",
              "text": "圖書館、"
            },
            {
              "type": "wikilink",
              "text": "臺中國際會展中心"
            },
            {
              "type": "text",
              "text": "等。母公司為"
            },
            {
              "type": "wikilink",
              "text": "潤弘精密工程"
            },
            {
              "type": "text",
              "text": "。2024 年營收 20 億元，年增 32%。"
            }
          ]
        }
      ],
      "groups": []
    },
