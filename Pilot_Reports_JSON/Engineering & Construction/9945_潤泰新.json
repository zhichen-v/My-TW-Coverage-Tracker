  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "潤泰創新國際股份有限公司（原名潤泰建設）成立於1977年，為"
            },
            {
              "type": "wikilink",
              "text": "潤泰集團"
            },
            {
              "type": "text",
              "text": "旗下核心上市公司，跨足營建與生活事業。營建事業以集團獨有之"
            },
            {
              "type": "wikilink",
              "text": "預鑄工法"
            },
            {
              "type": "text",
              "text": "（以工廠預製鋼筋混凝土構件，現場組裝，工期快、品質優）為競爭利器，開發住宅建案，營造工程則由關係企業"
            },
            {
              "type": "wikilink",
              "text": "潤弘精密"
            },
            {
              "type": "text",
              "text": "承包執行，曾創下「百日建廠」紀錄。生活事業透過 BOT 模式投資興建大型複合式商場"
            },
            {
              "type": "wikilink",
              "text": "CITYLINK"
            },
            {
              "type": "text",
              "text": "購物中心（南港、松山等據點），並引進"
            },
            {
              "type": "wikilink",
              "text": "蔦屋書店"
            },
            {
              "type": "text",
              "text": "等特色品牌。轉投資布局廣泛，持有"
            },
            {
              "type": "wikilink",
              "text": "南山人壽"
            },
            {
              "type": "text",
              "text": "約25%股權（為最大獲利來源），並投資"
            },
            {
              "type": "wikilink",
              "text": "日友環保"
            },
            {
              "type": "text",
              "text": "（廢棄物處理）、"
            },
            {
              "type": "wikilink",
              "text": "大潤發"
            },
            {
              "type": "text",
              "text": "等事業。"
            }
          ]
        }
      ],
      "groups": []
    },
