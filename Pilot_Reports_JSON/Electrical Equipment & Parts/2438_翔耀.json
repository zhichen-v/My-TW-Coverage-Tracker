  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "翔耀實業股份有限公司 (Aerowin Industrial Co., Ltd.) 成立於 1982 年 (原名英誌企業)，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "新北"
            },
            {
              "type": "text",
              "text": "。公司早期業務較為多元 (如照明、五金)，近年積極轉型進軍 "
            },
            {
              "type": "strong",
              "text": "AI 算力服務"
            },
            {
              "type": "text",
              "text": " (AICC) 及"
            },
            {
              "type": "strong",
              "text": "光電事業"
            },
            {
              "type": "text",
              "text": "。2024 年與"
            },
            {
              "type": "wikilink",
              "text": "美超微"
            },
            {
              "type": "text",
              "text": " (Supermicro) 及"
            },
            {
              "type": "wikilink",
              "text": "是方電訊"
            },
            {
              "type": "text",
              "text": "合作，建置 "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": " 運算中心，提供算力租賃服務。旗下子公司"
            },
            {
              "type": "strong",
              "text": "嵩達光電"
            },
            {
              "type": "text",
              "text": "則專注於觸控面板及工控顯示器，並切入電子紙產業鏈。此外，公司亦經營"
            },
            {
              "type": "strong",
              "text": "國軍服裝"
            },
            {
              "type": "text",
              "text": "供應業務。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "翔耀位於 "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": " 算力服務及光電顯示產業鏈中下游。\n*   "
            },
            {
              "type": "strong",
              "text": "上游 (設備/技術):"
            },
            {
              "type": "text",
              "text": "\n*   "
            },
            {
              "type": "strong",
              "text": "AI 算力:"
            },
            {
              "type": "text",
              "text": " 採購 "
            },
            {
              "type": "wikilink",
              "text": "NVIDIA"
            },
            {
              "type": "text",
              "text": " H100/H200 "
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": " (供應商: "
            },
            {
              "type": "wikilink",
              "text": "Supermicro"
            },
            {
              "type": "text",
              "text": ")，"
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "託管 (供應商: "
            },
            {
              "type": "wikilink",
              "text": "是方電訊"
            },
            {
              "type": "text",
              "text": ")。\n*   "
            },
            {
              "type": "strong",
              "text": "光電:"
            },
            {
              "type": "text",
              "text": " 採購玻璃基板、驅動 IC、電子紙膜片。\n*   "
            },
            {
              "type": "strong",
              "text": "中游 (服務/製造):"
            },
            {
              "type": "text",
              "text": "\n*   "
            },
            {
              "type": "strong",
              "text": "AI:"
            },
            {
              "type": "text",
              "text": " 建置 AICC ("
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": " Cloud Computing) 算力調度平台 (由翔耀主導)。\n*   "
            },
            {
              "type": "strong",
              "text": "光電:"
            },
            {
              "type": "text",
              "text": " 觸控模組貼合、組裝 (子公司嵩達光電)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游 (應用市場):"
            },
            {
              "type": "text",
              "text": "\n*   "
            },
            {
              "type": "strong",
              "text": "AI:"
            },
            {
              "type": "text",
              "text": " 銷售算力給大學院校、政府機關、影視產業、金融機構。\n*   "
            },
            {
              "type": "strong",
              "text": "光電:"
            },
            {
              "type": "text",
              "text": " 工控電腦、醫療設備、博弈機台。"
            }
          ]
        }
      ],
      "groups": []
    },
