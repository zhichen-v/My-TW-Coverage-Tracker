    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "太空梭高傳真資訊科技 (2440，Space Shuttle Hi-Tech) 專注銅材二次加工及資訊傳輸線材製造，產品涵蓋"
            },
            {
              "type": "wikilink",
              "text": "USB"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "HDMI"
            },
            {
              "type": "text",
              "text": "電腦線、"
            },
            {
              "type": "wikilink",
              "text": "CAT-6"
            },
            {
              "type": "text",
              "text": "/CAT-8 通訊線、遊戲機線材及醫療用線。具備極細銅線抽絲能力，取得 UL/CSA/"
            },
            {
              "type": "wikilink",
              "text": "Sony"
            },
            {
              "type": "text",
              "text": " Green Partner 等國際認證。客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "Microsoft"
            },
            {
              "type": "text",
              "text": " (遊戲機線材)、"
            },
            {
              "type": "wikilink",
              "text": "Sony"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "PlayStation"
            },
            {
              "type": "text",
              "text": "周邊)、"
            },
            {
              "type": "wikilink",
              "text": "HP"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Philips"
            },
            {
              "type": "text",
              "text": "及連接器廠"
            },
            {
              "type": "wikilink",
              "text": "JAE"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Black Box"
            },
            {
              "type": "text",
              "text": "。銅材供應自"
