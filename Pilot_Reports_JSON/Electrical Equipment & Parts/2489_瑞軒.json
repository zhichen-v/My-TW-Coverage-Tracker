    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "瑞軒科技 (2489，Amtran Technology) 為知名顯示器及電視"
            },
            {
              "type": "wikilink",
              "text": "ODM"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "OEM"
            },
            {
              "type": "text",
              "text": "組裝廠，生產基地主要位於越南海防。電視客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "Vizio"
            },
            {
              "type": "text",
              "text": " (現轉為"
            },
            {
              "type": "wikilink",
              "text": "Walmart"
            },
            {
              "type": "text",
              "text": "自有品牌)、"
            },
            {
              "type": "wikilink",
              "text": "小米"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Sharp"
            },
            {
              "type": "text",
              "text": "。電競螢幕成為主要成長動能，OEM 客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "Samsung"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "華碩"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "MSI"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Gigabyte"
            },
            {
              "type": "text",
              "text": "。上游面板來自"
            },
            {
              "type": "wikilink",
              "text": "LG Display"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "友達"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "群創"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "華星光電"
