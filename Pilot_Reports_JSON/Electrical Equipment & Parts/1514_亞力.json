  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "亞力電機 (1514，Allis Electric) 為台灣重電設備領導廠商，產品涵蓋變壓器 (含模塑型)、高低壓配電盤、氣封型開關及真空斷路器。電力電子事業含"
            },
            {
              "type": "wikilink",
              "text": "UPS"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "太陽能"
            },
            {
              "type": "text",
              "text": "逆變器、"
            },
            {
              "type": "wikilink",
              "text": "電動巴士"
            },
            {
              "type": "text",
              "text": "充電樁及微電網。亦為軌道工業 ("
            },
            {
              "type": "wikilink",
              "text": "高鐵"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "台鐵"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "台北捷運"
            },
            {
              "type": "text",
              "text": ") 提供電力/號誌/監控系統機電統包。受惠"
            },
            {
              "type": "wikilink",
              "text": "台電"
            },
            {
              "type": "text",
              "text": "強韌電網計畫、"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "廠擴廠及"
            },
            {
              "type": "wikilink",
              "text": "AI 伺服器"
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "電源設備。客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "台電"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "聯電"
            },
            {
              "type": "text",
              "text": "。上游矽鋼片來自"
            },
            {
              "type": "wikilink",
              "text": "日本製鐵"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "POSCO"
            },
            {
              "type": "text",
              "text": "，銅材來自"
            },
            {
              "type": "wikilink",
              "text": "華新麗華"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
      ],
