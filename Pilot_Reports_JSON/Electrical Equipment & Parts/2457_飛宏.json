  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "飛宏科技 (2457，Phihong Technology) 為全球前十大電源供應器製造商，近年積極轉型至"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "充電樁領域。子公司"
            },
            {
              "type": "wikilink",
              "text": "馳諾瓦"
            },
            {
              "type": "text",
              "text": " (Zerova Technologies) 提供 AC 及 DC 直流快充樁。EV 充電樁客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "Shell"
            },
            {
              "type": "text",
              "text": " (全球採購協議)、"
            },
            {
              "type": "wikilink",
              "text": "Audi"
            },
            {
              "type": "text",
              "text": " (台灣超快充站)、"
            },
            {
              "type": "wikilink",
              "text": "Volvo"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Jaguar"
            },
            {
              "type": "text",
              "text": "。傳統電源客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "Cisco"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Nokia"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Honeywell"
            },
            {
              "type": "text",
              "text": "。加入"
            },
            {
              "type": "wikilink",
              "text": "鴻海"
            },
            {
              "type": "wikilink",
              "text": "MIH"
            },
            {
              "type": "text",
              "text": "電動車聯盟。上游功率半導體採用"
            },
            {
              "type": "wikilink",
              "text": "Infineon"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Onsemi"
            },
            {
              "type": "text",
              "text": "之"
            },
            {
              "type": "wikilink",
              "text": "氮化鎵"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "碳化矽"
            },
            {
              "type": "text",
              "text": "元件。"
            }
          ]
        }
      ],
