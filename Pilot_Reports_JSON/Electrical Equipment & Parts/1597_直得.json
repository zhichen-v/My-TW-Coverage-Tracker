      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "直得科技 (1597，Chieftek Precision) 為全球微型"
            },
            {
              "type": "wikilink",
              "text": "線性滑軌"
            },
            {
              "type": "text",
              "text": "領導廠商，自有品牌「cpc」。產品涵蓋微型至大型"
            },
            {
              "type": "wikilink",
              "text": "線性滑軌"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "滾珠螺桿"
            },
            {
              "type": "text",
              "text": "、線性模組、"
            },
            {
              "type": "wikilink",
              "text": "線性馬達"
            },
            {
              "type": "text",
              "text": "及驅動器。主要應用於"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "製程設備 (最大領域)、醫療精密儀器及自動化設備。半導體設備客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "Applied Materials"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "ASML"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "KLA"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Tokyo Electron"
            },
            {
              "type": "text",
              "text": "。醫療客戶含"
            },
            {
              "type": "wikilink",
              "text": "Siemens Healthineers"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "GE Healthcare"
            },
            {
              "type": "text",
              "text": "。上游特殊鋼材來自"
