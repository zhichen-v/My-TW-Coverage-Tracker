  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "揚明光學 (Young Optics) 為 "
            },
            {
              "type": "strong",
              "text": "中強光電 (Coretronic)"
            },
            {
              "type": "text",
              "text": " 集團旗下之光學模組廠。\n核心技術為 "
            },
            {
              "type": "strong",
              "text": "微投影光機"
            },
            {
              "type": "text",
              "text": " (Micro-projection) 與 "
            },
            {
              "type": "strong",
              "text": "精密光學鏡頭"
            },
            {
              "type": "text",
              "text": "。\n主要產品包括 "
            },
            {
              "type": "strong",
              "text": "微投影模組"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "strong",
              "text": "3D 列印機"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "strong",
              "text": "車用 HUD"
            },
            {
              "type": "text",
              "text": " (抬頭顯示器) 與 "
            },
            {
              "type": "strong",
              "text": "AR/VR 光學模組"
            },
            {
              "type": "text",
              "text": "。\n與 "
            },
            {
              "type": "strong",
              "text": "德州儀器 (TI)"
            },
            {
              "type": "text",
              "text": " 在 DLP 技術上有長期合作關係。\n近年積極切入 "
            },
            {
              "type": "strong",
              "text": "[[Apple]]"
            },
            {
              "type": "text",
              "text": " 混合實境 (MR) 頭戴裝置供應鏈 (Pancake Lens)。"
            }
          ]
        }
      ],
