            },
            {
              "type": "text",
              "text": "、中華車。\n*   "
            },
            {
              "type": "strong",
              "text": "外銷:"
            },
            {
              "type": "text",
              "text": " 北美電力公司、"
            },
            {
              "type": "wikilink",
              "text": "Mitsubishi"
            },
            {
              "type": "text",
              "text": "。\n*   "
            },
            {
              "type": "strong",
              "text": "主要供應商:"
            },
            {
              "type": "text",
              "text": "\n*   "
            },
            {
              "type": "strong",
