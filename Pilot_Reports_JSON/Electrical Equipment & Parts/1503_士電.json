  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "士林電機廠股份有限公司 (Shihlin Electric & Engineering Corp.) 成立於 1955 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "台北"
            },
            {
              "type": "text",
              "text": "，為"
            },
            {
              "type": "wikilink",
              "text": "仰德集團"
            },
            {
              "type": "text",
              "text": "核心企業。士電為台灣"
            },
            {
              "type": "wikilink",
              "text": "重電"
            },
            {
              "type": "text",
              "text": "設備龍頭之一，與三菱電機 ("
            },
            {
              "type": "wikilink",
              "text": "Mitsubishi"
            },
            {
              "type": "text",
              "text": " Electric) 長期技術合作。業務範疇涵蓋電力配電、車輛零件、"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "設備及數位家電。近年受惠於"
            },
            {
              "type": "wikilink",
              "text": "台電強韌電網計畫"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "綠能"
            },
            {
              "type": "text",
              "text": "建置及"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "充電樁需求，營運成長動能強勁。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "士電位於重電及機電產業鏈中下游，為關鍵設備供應商與系統整合商。\n*   "
            },
            {
              "type": "strong",
              "text": "上游:"
            },
            {
              "type": "text",
              "text": " 採購銅、鋁、矽鋼片、絕緣油、電子元件。\n*   "
            },
            {
              "type": "strong",
              "text": "中游:"
            },
            {
              "type": "text",
              "text": " 製造變壓器、配電盤、馬達、電裝品。\n*   "
            },
            {
              "type": "strong",
              "text": "下游:"
            },
            {
              "type": "text",
              "text": " 供應給電力公司 ("
            },
            {
              "type": "wikilink",
              "text": "台電"
            },
            {
              "type": "text",
              "text": ")、工廠 ("
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "/傳產)、車廠、建築業。"
            }
          ]
        }
      ],
      "groups": []
    },
    "customer_supplier": {
