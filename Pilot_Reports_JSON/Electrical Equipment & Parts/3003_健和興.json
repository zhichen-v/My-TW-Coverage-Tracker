    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "健和興端子 (3003，K.S. Terminals / KST) 為亞洲知名端子與"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "製造商，近年成功轉型至"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "與綠能市場。產品涵蓋 EV 高壓"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "、充電槍、充電樁連接器、太陽能/風電/"
            },
            {
              "type": "wikilink",
              "text": "儲能"
            },
            {
              "type": "text",
              "text": "系統高壓連接器及車用電子端子。為"
            },
            {
              "type": "wikilink",
              "text": "Tesla"
            },
            {
              "type": "text",
              "text": "充電槍及"
            },
            {
              "type": "wikilink",
              "text": "Tesla Powerwall"
            },
            {
              "type": "wikilink",
              "text": "儲能"
            },
            {
              "type": "text",
              "text": "系統之綠能連接器供應商。其他 EV 客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "BYD"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "蔚來汽車"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "吉利汽車"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Honda"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Nissan"
            },
            {
              "type": "text",
              "text": "。綠能/充電樁客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "台達電"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "華為"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "陽光電源"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
