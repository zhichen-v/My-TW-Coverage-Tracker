  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "協禧電機 (3071，ADDA Corporation) 為全球知名散熱風扇製造商，自有品牌 ADDA。近年轉型聚焦：(1) 車用電子 — 獲歐美 Tier 1 認證，應用於車燈/座椅通風/電池散熱，間接供應"
            },
            {
              "type": "wikilink",
              "text": "Tesla"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "GM"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Ford"
            },
            {
              "type": "text",
              "text": "；(2) "
            },
            {
              "type": "wikilink",
              "text": "AI 伺服器"
            },
            {
              "type": "text",
              "text": "散熱 — 高效能風扇與液冷散熱模組，供應"
            },
            {
              "type": "wikilink",
              "text": "廣達"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "緯創"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "英業達"
            },
            {
              "type": "text",
              "text": "等伺服器代工廠；(3) NB/PC — 供應"
            },
            {
              "type": "wikilink",
              "text": "HP"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Dell"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Lenovo"
            },
            {
              "type": "text",
              "text": "。上游馬達控制 IC 採用"
            },
            {
              "type": "wikilink",
              "text": "ROHM"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
      ],
