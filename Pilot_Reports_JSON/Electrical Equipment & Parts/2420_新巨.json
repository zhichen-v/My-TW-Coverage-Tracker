  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "新巨企業 (2420，Zippy Technology) 為利基型電源供應器及微動開關專業廠。電源品牌「EMACS」提供伺服器用電源 (涵蓋"
            },
            {
              "type": "wikilink",
              "text": "CRPS"
            },
            {
              "type": "text",
              "text": "模組/1U/2U 冗餘式/醫療級，1400W-2700W)，已切入"
            },
            {
              "type": "wikilink",
              "text": "AI 伺服器"
            },
            {
              "type": "text",
              "text": "電源市場，供應白牌伺服器廠及雲端業者如"
            },
            {
              "type": "wikilink",
              "text": "Amazon"
            },
            {
              "type": "text",
              "text": " (AWS)、"
            },
            {
              "type": "wikilink",
              "text": "HP"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Dell"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "IBM"
            },
            {
              "type": "text",
              "text": "。微動開關品牌「Zippy」供應"
            },
            {
              "type": "wikilink",
              "text": "Audi"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Volkswagen"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Ford"
            },
            {
              "type": "text",
              "text": "及日系車廠之汽車電子，以及國際高階家電品牌。"
            }
          ]
        }
      ],
      "groups": []
    },
