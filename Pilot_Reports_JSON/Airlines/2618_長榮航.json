  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "長榮航空"
            },
            {
              "type": "text",
              "text": " (2618，EVA Air) 成立於 1989 年，隸屬"
            },
            {
              "type": "wikilink",
              "text": "長榮集團"
            },
            {
              "type": "text",
              "text": "，為台灣第二大航空公司，「"
            },
            {
              "type": "wikilink",
              "text": "星空聯盟"
            },
            {
              "type": "text",
              "text": "」(Star Alliance) 成員，連續多年獲評 "
            },
            {
              "type": "wikilink",
              "text": "SKYTRAX"
            },
            {
              "type": "text",
              "text": " 五星級航空。機隊以"
            },
            {
              "type": "wikilink",
              "text": "Boeing"
            },
            {
              "type": "text",
              "text": " 777-300ER (33 架)、787-9/787-10 (21 架) 及"
            },
            {
              "type": "wikilink",
              "text": "Airbus"
            },
            {
              "type": "text",
              "text": " A330-300/A321 為主力。已訂購 24 架"
            },
            {
              "type": "wikilink",
              "text": "Airbus"
            },
            {
              "type": "text",
              "text": " A350-1000 (搭載"
            },
            {
              "type": "wikilink",
              "text": "Rolls-Royce"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "Trent XWB"
            },
            {
              "type": "text",
              "text": "引擎) 及 18 架 A321neo 推動機隊更新。貨運業務受惠於北美"
            },
            {
              "type": "wikilink",
              "text": "AI 伺服器"
            },
            {
              "type": "text",
              "text": "與"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "運輸需求爆發，全貨機機隊 (9 架 777F) 表現亮眼。集團航太版圖涵蓋"
            },
            {
              "type": "wikilink",
              "text": "長榮航太"
            },
            {
              "type": "text",
              "text": " (2645，MRO)、"
            },
            {
              "type": "wikilink",
              "text": "長榮空廚"
            },
            {
              "type": "text",
              "text": " (9978)、"
            },
            {
              "type": "wikilink",
              "text": "長榮航勤"
            },
            {
              "type": "text",
              "text": " (地勤)。"
            }
          ]
        }
      ],
      "groups": []
    },
