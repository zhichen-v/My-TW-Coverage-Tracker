    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "建榮"
            },
            {
              "type": "text",
              "text": "工業 (Baotek) 成立於1989年，總部位於台灣桃園。公司主要生產電子級"
            },
            {
              "type": "wikilink",
              "text": "玻纖布"
            },
            {
              "type": "text",
              "text": "，為"
            },
            {
              "type": "wikilink",
              "text": "PCB"
            },
            {
              "type": "text",
              "text": "印刷電路板的關鍵補強材料。建榮是日本"
            },
            {
              "type": "wikilink",
              "text": "日東紡"
            },
            {
              "type": "text",
              "text": " (Nitto Boseki) 集團成員 ("
            },
            {
              "type": "wikilink",
              "text": "日東紡"
            },
            {
              "type": "text",
              "text": "持股約47%)，受益於母公司技術支援，在高階Low-Dk (低介電) "
            },
            {
              "type": "wikilink",
              "text": "玻纖布"
            },
            {
              "type": "text",
              "text": "領域具競爭優勢。產品廣泛應用於"
            },
            {
              "type": "wikilink",
              "text": "AI 伺服器"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": "通訊及高效能運算 (HPC)。受惠AI伺服器高階"
            },
            {
              "type": "wikilink",
              "text": "玻纖布"
            },
            {
              "type": "text",
              "text": "需求暴增，訂單持續滿載。"
            }
          ]
        }
      ],
      "groups": []
    },
