          "segments": [
            {
              "type": "strong",
              "text": "光明絲織"
            },
            {
              "type": "text",
              "text": " (4420) 為 "
            },
            {
              "type": "wikilink",
              "text": "宜進集團"
            },
            {
              "type": "text",
              "text": " 旗下成員，原專注於織布業務，近年轉型為 "
            },
            {
              "type": "wikilink",
              "text": "聚酯加工絲"
            },
            {
              "type": "text",
              "text": " 製造商。主要產品為 "
            },
            {
              "type": "wikilink",
              "text": "機能性加工絲"
            },
            {
              "type": "text",
              "text": " (如抗菌、吸濕排汗) 及 "
            },
            {
              "type": "wikilink",
              "text": "環保回收紗"
            },
            {
              "type": "text",
              "text": "。面對紡織業國際競爭，光明積極進行垂直整合與轉型，除本業外，亦跨足 "
            },
            {
              "type": "wikilink",
              "text": "不動產開發"
            },
            {
              "type": "text",
              "text": " 與租賃業務，活化各廠區資產 (如南港、龜山)，並以投資收益穩定營運獲利。"
            }
          ]
        }
      ],
      "groups": []
    },
