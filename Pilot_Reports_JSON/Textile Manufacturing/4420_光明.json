      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "光明位於紡織產業鏈的"
            },
            {
              "type": "strong",
              "text": "中游加工絲製造端"
            },
            {
              "type": "text",
              "text": "：\n*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": "：採購 "
            },
            {
              "type": "wikilink",
              "text": "聚酯粒"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "POY"
            },
            {
              "type": "text",
              "text": " 原絲，主要供應商為集團母公司 "
            },
            {
              "type": "wikilink",
              "text": "宜進"
            },
            {
              "type": "text",
              "text": " 及其他化纖大廠。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": "：進行 "
            },
            {
              "type": "wikilink",
              "text": "假撚"
            },
            {
              "type": "text",
              "text": " 加工，生產各類特多龍加工絲。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": "：供應給 "
            },
            {
              "type": "wikilink",
              "text": "織布廠"
            },
            {
              "type": "text",
              "text": "，應用於成衣、家飾及工業用布；另有部分業務為 "
            },
            {
              "type": "wikilink",
              "text": "不動產"
            },
            {
              "type": "text",
              "text": " 租售。"
