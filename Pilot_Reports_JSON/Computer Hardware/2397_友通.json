    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "友通資訊 (2397，"
            },
            {
              "type": "wikilink",
              "text": "DFI"
            },
            {
              "type": "text",
              "text": ") 成立於 1981 年，總部位於新北市，為專業嵌入式主機板及"
            },
            {
              "type": "wikilink",
              "text": "工業電腦"
            },
            {
              "type": "text",
              "text": "系統設計製造商，隸屬"
            },
            {
              "type": "wikilink",
              "text": "佳世達"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "BenQ"
            },
            {
              "type": "text",
              "text": ") 集團。公司與佳世達集團協同提供嵌入式應用之完整解決方案。"
            }
          ]
        },
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "核心產品涵蓋工業主機板、電腦模組 (COM)、嵌入式無風扇電腦、"
            },
            {
              "type": "wikilink",
              "text": "Edge AI"
            },
            {
              "type": "text",
              "text": " 推論/訓練系統、強固型嵌入式系統、工業觸控面板電腦及邊緣伺服器。應用領域橫跨工廠自動化、醫療、博弈娛樂、交通運輸、能源、"
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": " 網通及智慧零售等利基市場。"
            }
          ]
        }
      ],
      "groups": []
    },
