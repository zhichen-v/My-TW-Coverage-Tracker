  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "研揚科技股份有限公司 (6579，AAEON) 隸屬於"
            },
            {
              "type": "wikilink",
              "text": "華碩"
            },
            {
              "type": "text",
              "text": "(ASUS)集團，是全球領先的工業"
            },
            {
              "type": "wikilink",
              "text": "物聯網"
            },
            {
              "type": "text",
              "text": "(IIoT)與邊緣"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "(Edge "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": ")運算平台製造商。研揚的產品線涵蓋單板電腦、強固型平板及工業系統，廣泛應用於智慧城市、智慧零售、智慧製造及交通醫療等領域。近年來，研揚敏銳捕捉人工智慧落地邊緣端的龐大商機，與"
            },
            {
              "type": "wikilink",
              "text": "NVIDIA"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Intel"
            },
            {
              "type": "text",
              "text": "等晶片巨擘深度結盟，推出一系列專為機器視覺、無人化機台及生成式"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "設計的高效能邊緣運算平台。研揚更透過策略結盟(如廣積、醫揚、融程電)組成「泛研揚集團」，極大化了在關鍵零組件採購與技術整合上的綜效規模。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 繪圖處理晶片(GPU)、核心運算處理器(CPU)、神經網路加速器(NPU)、"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "text",
              "text": "及工業級機殼。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "研揚科技"
            },
            {
              "type": "text",
              "text": " (單板電腦、工業系統、醫療電腦及邊緣"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "(Edge "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": ")運算硬體平台之研發製造)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 全球系統整合商(SI)、各行業的"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "設備商、智慧零售KIOSK廠及醫療推車/設備供應商。"
            }
          ]
        }
      ],
      "groups": []
    },
