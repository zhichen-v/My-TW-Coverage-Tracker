    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "承啟科技股份有限公司 (Chaintech Technology Corporation) 成立於 1986 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "新北"
            },
            {
              "type": "text",
              "text": "。公司原名承啟大眾科技 (Walton Chaintech)，2013 年更名為承啟科技。主要從事電腦板卡及周邊產品之設計、製造與銷售，市場以中國大陸及台灣為主。核心產品包括"
            },
            {
              "type": "wikilink",
              "text": "顯示卡"
            },
            {
              "type": "text",
              "text": " (自有品牌 AX-Gaming)、"
            },
            {
              "type": "wikilink",
              "text": "主機板"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "Intel"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "AMD"
            },
            {
              "type": "text",
              "text": " 平台)、電競整機及 "
            },
            {
              "type": "wikilink",
              "text": "AI 伺服器"
            },
            {
              "type": "text",
              "text": "。近年積極切入 "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "領域，受惠於全球 "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": " 算力需求成長。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "承啟位於電腦硬體/板卡產業鏈中下游。\n*   "
            },
            {
              "type": "strong",
              "text": "上游:"
            },
            {
              "type": "text",
              "text": " 採購 GPU 晶片 ("
            },
            {
              "type": "wikilink",
              "text": "NVIDIA"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "AMD"
            },
            {
              "type": "text",
              "text": ")、主機板晶片組 ("
            },
            {
              "type": "wikilink",
              "text": "Intel"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "AMD"
            },
            {
              "type": "text",
              "text": ")、"
            },
            {
              "type": "wikilink",
              "text": "DRAM"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "PCB"
            },
            {
              "type": "text",
              "text": "。\n*   "
            },
            {
              "type": "strong",
              "text": "中游:"
            },
            {
              "type": "text",
              "text": " 設計及組裝顯示卡、主機板、電競整機、"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "。\n*   "
            },
            {
              "type": "strong",
              "text": "下游:"
            },
            {
              "type": "text",
              "text": " 銷售至中國及台灣通路商、電商平台、系統整合商。"
            }
          ]
        }
      ],
