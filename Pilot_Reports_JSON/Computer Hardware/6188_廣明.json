            },
            {
              "type": "text",
              "text": " Flash"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "text",
              "text": "(客戶常指定)、硬碟控制IC、機器手臂零組件(伺服馬達/減速機/感測器)供應商。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "廣明光電"
            },
            {
              "type": "text",
              "text": " (儲存裝置SSD/HDD之"
            },
            {
              "type": "wikilink",
              "text": "EMS"
            },
            {
              "type": "text",
              "text": "代工、Docking製造，以及達明協作型"
            },
            {
              "type": "wikilink",
              "text": "機器人"
            },
            {
              "type": "text",
              "text": "研發製造)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 國際大型儲存品牌(如WD/Seagate)、母公司"
            },
            {
              "type": "wikilink",
              "text": "廣達"
            },
            {
              "type": "text",
              "text": "("
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "/電腦組裝)及各產業系統整合商(SI)。"
            }
          ]
        }
      ],
