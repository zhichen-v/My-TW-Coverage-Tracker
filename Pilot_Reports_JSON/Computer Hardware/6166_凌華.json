  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "凌華科技股份有限公司 (6166, ADLINK) 是全球知名的"
            },
            {
              "type": "wikilink",
              "text": "工業電腦"
            },
            {
              "type": "text",
              "text": "("
            },
            {
              "type": "wikilink",
              "text": "IPC"
            },
            {
              "type": "text",
              "text": ")與邊緣運算(Edge Computing)解決方案大廠。業務涵蓋嵌入式運算模組、"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "加速器、智慧製造、醫療及國防航太設備。凌華在全球模組化電腦(如COM Express)擁有領先地位，並積極結盟"
            },
            {
              "type": "wikilink",
              "text": "NVIDIA"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Intel"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "友達"
            },
            {
              "type": "text",
              "text": "(最大單一股東)及"
            },
            {
              "type": "wikilink",
              "text": "鴻海"
            },
            {
              "type": "text",
              "text": "(合資法博智能)，深化在自駕車、"
            },
            {
              "type": "wikilink",
              "text": "機器人"
            },
            {
              "type": "text",
              "text": "作業系統(ROS 2)、"
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "物聯網"
            },
            {
              "type": "text",
              "text": "的佈局。近年更加速擴展北美醫療及企業級邊緣"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "專案市場。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 中央處理器(CPU)、圖形處理器(GPU)、"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "text",
              "text": "、面板、印刷電路板("
            },
            {
              "type": "wikilink",
              "text": "PCB"
            },
            {
              "type": "text",
              "text": ")及機殼廠。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "凌華科技"
            },
            {
              "type": "text",
              "text": " (工業級嵌入式運算模組、邊緣"
            },
            {
              "type": "wikilink",
              "text": "AI[[伺服器"
            },
            {
              "type": "text",
              "text": "]]與垂直產業解決方案研發製造)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 各垂直產業之系統整合商(SI)、醫療設備原廠、智慧工廠、電信及軍工航太業者。"
            }
          ]
        }
      ],
