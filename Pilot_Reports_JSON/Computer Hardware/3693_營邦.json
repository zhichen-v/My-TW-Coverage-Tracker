            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "主板開發、系統熱力設計、準系統組裝、整機櫃測試。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ":\n*   "
            },
            {
              "type": "strong",
              "text": "二、三線雲端客戶"
            },
            {
              "type": "text",
              "text": ": 北美及區域型 Tier-2 "
            },
            {
              "type": "wikilink",
              "text": "CSP"
            },
            {
              "type": "text",
              "text": "。\n*   "
            },
            {
              "type": "strong",
              "text": "軟體定義儲存商"
            },
            {
              "type": "text",
              "text": ": Media Entertainment, 影像監控系統整合商。\n*   "
            },
            {
              "type": "strong",
              "text": "邊緣運算"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": " 網絡、自動駕駛與工業 4.0 設施。"
            }
          ]
        }
      ],
