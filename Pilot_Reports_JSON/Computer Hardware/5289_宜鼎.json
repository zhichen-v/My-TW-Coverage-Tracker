  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "宜鼎國際 (Innodisk) 為全球工業級 "
            },
            {
              "type": "strong",
              "text": "嵌入式快閃記憶體 (Flash)"
            },
            {
              "type": "text",
              "text": " 與 "
            },
            {
              "type": "strong",
              "text": "DRAM 模組"
            },
            {
              "type": "text",
              "text": " 領導廠商。\n專注於工控、航太、車載、伺服器等利基市場，強調高度客製化與耐用性。\n近年積極轉型 "
            },
            {
              "type": "strong",
              "text": "AIoT (AI + IoT)"
            },
            {
              "type": "text",
              "text": " 解決方案：\n1.  "
            },
            {
              "type": "strong",
              "text": "AI 邊緣運算"
            },
            {
              "type": "text",
              "text": ": 透過子公司 "
            },
            {
              "type": "strong",
              "text": "安提國際 (Aetina)"
            },
            {
              "type": "text",
              "text": " 與 "
            },
            {
              "type": "wikilink",
              "text": "Nvidia"
            },
            {
              "type": "text",
              "text": " 合作，提供 Edge AI 平台。\n2.  "
            },
            {
              "type": "strong",
              "text": "InnoAGE/InnoOSR"
            },
            {
              "type": "text",
              "text": ": 整合微軟 AzureSphere 之資安 SSD。\n3.  "
            },
            {
              "type": "strong",
              "text": "工業模組"
            },
            {
              "type": "text",
              "text": ": CANbus、PoE 等擴充卡。"
            }
          ]
        }
      ],
      "groups": []
    },
