  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "敦吉科技股份有限公司 (Audix Corporation) 成立於 1980 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "台北"
            },
            {
              "type": "text",
              "text": "。公司業務涵蓋三大領域：電子零組件通路 (Distribution)、製造 (Manufacturing) 及驗證服務 (Testing)。製造業務包括精密模具、塑膠射出及 VCM 音圈馬達零件；驗證業務提供 EMC/Safety 檢測。近期積極切入 "
            },
            {
              "type": "wikilink",
              "text": "AI Server"
            },
            {
              "type": "text",
              "text": " 及"
            },
            {
              "type": "wikilink",
              "text": "車用電子"
            },
            {
              "type": "text",
              "text": "檢測市場。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "敦吉位於電子產業鏈中下游，兼具通路、製造與服務角色。\n*   "
            },
            {
              "type": "strong",
              "text": "上游 (原廠/材料):"
            },
            {
              "type": "text",
              "text": " 日本電子零組件品牌 ("
            },
            {
              "type": "wikilink",
              "text": "Panasonic"
            },
            {
              "type": "text",
              "text": ", "
            },
            {
              "type": "wikilink",
              "text": "Hitachi"
            },
            {
              "type": "text",
              "text": "), 塑膠/金屬材料供應商。\n*   "
            },
            {
              "type": "strong",
              "text": "中游 (營運):"
            },
            {
              "type": "text",
              "text": "\n*   "
            },
            {
              "type": "strong",
              "text": "通路:"
            },
            {
              "type": "text",
              "text": " 代理銷售零組件。\n*   "
            },
            {
              "type": "strong",
              "text": "製造:"
            },
            {
              "type": "text",
              "text": " 模具開發、塑膠射出、精密沖壓。\n*   "
            },
            {
              "type": "strong",
              "text": "驗證:"
            },
            {
              "type": "text",
              "text": " 檢測服務 ("
            },
            {
              "type": "wikilink",
              "text": "EMC"
            },
            {
              "type": "text",
              "text": ", Safety).\n*   "
            },
            {
              "type": "strong",
              "text": "下游 (應用):"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "消費性電子"
            },
            {
              "type": "text",
              "text": "、汽車電子、資訊家電、"
            },
            {
              "type": "wikilink",
              "text": "網通"
            },
            {
              "type": "text",
              "text": "設備。"
            }
          ]
        }
      ],
      "groups": []
    },
