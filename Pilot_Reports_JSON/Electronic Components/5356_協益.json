  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "協益電子 (5356，"
            },
            {
              "type": "wikilink",
              "text": "Sirtec"
            },
            {
              "type": "text",
              "text": ") 主要從事 "
            },
            {
              "type": "strong",
              "text": "電子產品組裝 (EMS)"
            },
            {
              "type": "text",
              "text": " 與 "
            },
            {
              "type": "strong",
              "text": "塑膠射出成型"
            },
            {
              "type": "text",
              "text": "，為老牌電子代工廠。"
            }
          ]
        },
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "業務範疇：(1) "
            },
            {
              "type": "strong",
              "text": "雷射印表機碳粉匣"
            },
            {
              "type": "text",
              "text": " — 為 "
            },
            {
              "type": "wikilink",
              "text": "Lexmark"
            },
            {
              "type": "text",
              "text": " 代工製造碳粉匣與機構件，為傳統核心業務；(2) "
            },
            {
              "type": "strong",
              "text": "網通/電子產品"
            },
            {
              "type": "text",
              "text": " — 為 "
            },
            {
              "type": "wikilink",
              "text": "Motorola"
            },
            {
              "type": "text",
              "text": " 代工路由器等網通設備組裝；(3) "
            },
            {
              "type": "strong",
              "text": "車用電子"
            },
            {
              "type": "text",
              "text": " — 車用音響面板、抬頭顯示器 ("
            },
            {
              "type": "wikilink",
              "text": "HUD"
            },
            {
              "type": "text",
              "text": ") 相關零組件；(4) "
            },
            {
              "type": "strong",
              "text": "消費電子"
            },
            {
              "type": "text",
              "text": " — "
            },
            {
              "type": "wikilink",
              "text": "Sony"
            },
            {
              "type": "text",
              "text": " 等品牌電子產品代工；(5) "
            },
            {
              "type": "strong",
              "text": "塑膠製品"
            },
            {
              "type": "text",
              "text": " — 3C 產品外殼、精密塑膠射出件；(6) "
            },
            {
              "type": "strong",
              "text": "面板驅動板"
            },
            {
              "type": "text",
              "text": " — "
            },
            {
              "type": "wikilink",
              "text": "TFT-LCD"
            },
            {
              "type": "text",
              "text": " Drive Card 組裝。主要工廠位於中國東莞及蘇州，以 EMS/ODM 模式服務國際品牌客戶。"
            }
          ]
        }
      ],
      "groups": []
    },
