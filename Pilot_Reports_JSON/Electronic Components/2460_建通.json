  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "建通精密 (2460) 是台灣精密電子零組件製造商，核心業務為"
            },
            {
              "type": "wikilink",
              "text": "端子"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "及異型"
            },
            {
              "type": "wikilink",
              "text": "銅材"
            },
            {
              "type": "text",
              "text": "。產品包括電源插頭片、"
            },
            {
              "type": "wikilink",
              "text": "家電"
            },
            {
              "type": "text",
              "text": "連接端子及"
            },
            {
              "type": "wikilink",
              "text": "電腦"
            },
            {
              "type": "text",
              "text": "外接元件。近年積極發展高階"
            },
            {
              "type": "wikilink",
              "text": "異型銅材"
            },
            {
              "type": "text",
              "text": "，利用專利精煉與軋延技術生產高導電性特殊截面銅帶。並開發"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "用高壓端子，應用於車載供電、電池連接模組及充電樁。"
            }
          ]
        }
      ],
      "groups": []
    },
