    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "洋華光電 (3622，"
            },
            {
              "type": "wikilink",
              "text": "Young Fast"
            },
            {
              "type": "text",
              "text": ") 目前業務雙軌並行：機電工程與觸控面板。"
            }
          ]
        },
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "1. "
            },
            {
              "type": "strong",
              "text": "機電工程 (主要獲利來源)"
            },
            {
              "type": "text",
              "text": ": 受惠於 "
            },
            {
              "type": "wikilink",
              "text": "台電"
            },
            {
              "type": "text",
              "text": "「強韌電網計畫」，電纜接頭與終端匣訂單滿載。與日本 "
            },
            {
              "type": "wikilink",
              "text": "古河電氣"
            },
            {
              "type": "text",
              "text": " (Furukawa Electric) 技術合作，產品具高度技術門檻。\n2. "
            },
            {
              "type": "strong",
              "text": "觸控面板"
            },
            {
              "type": "text",
              "text": ": 早期為消費性電子觸控大廠，近年轉型至工控、醫療與車用等利基市場，避開紅海競爭。越南廠產能佔比高，具地緣政治優勢。"
            }
          ]
        }
      ],
      "groups": []
    },
