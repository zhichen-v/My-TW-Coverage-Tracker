            },
            {
              "type": "text",
              "text": "/液冷"
            },
            {
              "type": "wikilink",
              "text": "散熱"
            },
            {
              "type": "text",
              "text": "系統之設計製造)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
