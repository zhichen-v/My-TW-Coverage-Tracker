  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "聯致科技股份有限公司 (3585) 隸屬於"
            },
            {
              "type": "wikilink",
              "text": "欣興"
            },
            {
              "type": "text",
              "text": "電子(Unimicron)集團(泛"
            },
            {
              "type": "wikilink",
              "text": "聯電"
            },
            {
              "type": "text",
              "text": "集團)，是一家專業的印刷電路板("
            },
            {
              "type": "wikilink",
              "text": "PCB"
            },
            {
              "type": "text",
              "text": ")與高階封裝輔助材料供應商。聯致科技的產品線涵蓋各類接著膠片(PP)、"
            },
            {
              "type": "wikilink",
              "text": "銅箔"
            },
            {
              "type": "text",
              "text": "基板(CCL)、防焊油墨及玻璃基板應用材料。隨著"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "晶片算力大幅提升，先進封裝技術(如"
            },
            {
              "type": "wikilink",
              "text": "Intel"
            },
            {
              "type": "text",
              "text": "與"
            },
            {
              "type": "wikilink",
              "text": "AMD"
            },
            {
              "type": "text",
              "text": "積極布局的玻璃核心基板)成為"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "業的下一個戰場。聯致科技憑藉在「玻璃基板銅層附著」等核心材料領域的研發突破，不僅直接供應母公司"
            },
            {
              "type": "wikilink",
              "text": "欣興"
            },
            {
              "type": "text",
              "text": "電子，更有望藉此間接打入全球頂級"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "晶片巨頭的高階封裝供應鏈。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "wikilink",
