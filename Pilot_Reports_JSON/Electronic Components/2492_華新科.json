      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "華新科"
            },
            {
              "type": "text",
              "text": "位於被動元件產業鏈製造端。\n*   "
            },
            {
              "type": "strong",
              "text": "上游 (材料):"
            },
            {
              "type": "text",
