    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "華新科"
            },
            {
              "type": "text",
              "text": "技股份有限公司 (Walsin Technology Corp.) 成立於 1992 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "桃園"
            },
            {
              "type": "text",
              "text": "，為華新麗華集團成員。公司為全球主要被動元件製造商，專注於積層陶瓷電容 ("
            },
            {
              "type": "wikilink",
              "text": "MLCC"
            },
            {
              "type": "text",
              "text": ")、晶片電阻 (Chip Resistors) 及射頻元件 (RF)。近年積極佈局"
            },
            {
              "type": "wikilink",
              "text": "車用電子"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": ") 及 "
            },
            {
              "type": "wikilink",
              "text": "AI Server"
            },
            {
              "type": "text",
              "text": " 市場，並與 "
            },
            {
              "type": "wikilink",
              "text": "Caiden"
            },
            {
              "type": "text",
              "text": " (2456) 等集團成員整合。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
