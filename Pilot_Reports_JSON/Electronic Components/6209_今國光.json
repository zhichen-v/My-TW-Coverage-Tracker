  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "今國光學工業股份有限公司 (6209) 是一家歷史悠久的老字號光學鏡頭廠。公司具備玻璃研磨、塑膠射出及模造玻璃技術的全方位光學設計製造能力。過去以數位相機與遊戲機(如"
            },
            {
              "type": "wikilink",
              "text": "Sony"
            },
            {
              "type": "text",
              "text": ")鏡頭聞名，近年來全面轉型佈局高附加價值領域，特別聚焦於「車載應用」(如"
            },
            {
              "type": "wikilink",
              "text": "ADAS"
            },
            {
              "type": "text",
              "text": "/LiDAR鏡頭)與「遠紅外線熱成像鏡頭」(應用於無人機及工業安防)。此外，今國光也積極跨足"
            },
            {
              "type": "wikilink",
              "text": "物聯網"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "機器視覺及"
            },
            {
              "type": "wikilink",
              "text": "AR"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "VR"
            },
            {
              "type": "text",
              "text": "智慧眼鏡等新興科技，並規劃海外擴產以因應「去中化」的全球供應鏈趨勢。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 各式光學玻璃毛胚/原料、光學級塑膠粒、鍍膜材料及高精密模具模具鋼材。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "今國光學"
            },
            {
              "type": "text",
              "text": " (玻璃/塑膠光學鏡片研磨射出、紅外線熱成像鏡頭及車載/"
            },
            {
              "type": "wikilink",
              "text": "物聯網"
            },
            {
              "type": "text",
              "text": "終端鏡頭模組製造)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 全球汽車零組件一線大廠(Tier 1)、無人機品牌、智慧家居/"
            },
            {
              "type": "wikilink",
              "text": "物聯網"
            },
            {
              "type": "text",
              "text": "設備商及安防監控系統廠。"
            }
          ]
        }
      ],
      "groups": []
    },
    "customer_supplier": {
      "heading": "主要客戶及供應商",
      "blocks": [],
      "groups": [
