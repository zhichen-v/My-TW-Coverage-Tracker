  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "欣普羅光電股份有限公司 (6560) 是一家專注於高階光學影像與系統整合設計的研發型企業(Design House)。有別於傳統的製造代工("
            },
            {
              "type": "wikilink",
              "text": "OEM"
            },
            {
              "type": "text",
              "text": ")，欣普羅採取高度客製化的商業模式，透過提供專業的演算法、軟硬體設計方案，向客戶收取設計費與授權金，生產則委外進行。其核心技術涵蓋網路監控攝影機、醫療用內視鏡、車載"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "相機及無人機攝像模組。近年來，欣普羅積極結盟神盾集團(如芯鼎、鈺寶)發展邊緣運算"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "視覺辨識技術，將產品從單純的影像捕捉升級至具備深度學習與工業"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "的智慧感知系統。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 影像感測晶片("
            },
            {
              "type": "wikilink",
              "text": "CIS"
            },
            {
              "type": "text",
              "text": ")、DSP影像處理器、光學鏡頭模組、"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "視覺晶片及各式電子零組件。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "欣普羅光電"
            },
            {
              "type": "text",
              "text": " (高階影像處理系統、"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "視覺演算法之客製化設計服務、及硬體委外生產代管)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 歐美一線安防品牌商、專業醫療設備大廠、無人機製造商及日系車廠一階(Tier 1)供應商。"
            }
          ]
        }
      ],
      "groups": []
    },
    "customer_supplier": {
      "heading": "主要客戶及供應商",
      "blocks": [],
