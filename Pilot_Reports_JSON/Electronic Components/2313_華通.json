    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "華通電腦 (2313) 是台灣領先的高階 "
            },
            {
              "type": "wikilink",
              "text": "HDI"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "高密度互連"
            },
            {
              "type": "text",
              "text": ") 印刷電路板製造商，提供硬板、"
            },
            {
              "type": "wikilink",
              "text": "軟板"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "軟硬結合板"
            },
            {
              "type": "text",
              "text": "一站式服務。主力產品應用於智慧型手機主板、"
            },
            {
              "type": "wikilink",
              "text": "低軌衛星"
            },
            {
              "type": "text",
              "text": "通訊及"
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "市場。公司參與客戶早期設計開發，從製造到組裝出貨提供完整服務。"
            }
          ]
        }
      ],
      "groups": []
    },
