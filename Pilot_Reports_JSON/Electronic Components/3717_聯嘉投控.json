              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": "：採購 "
            },
            {
              "type": "wikilink",
              "text": "LED 晶粒"
            },
            {
              "type": "text",
              "text": " (Chip) 及 "
            },
            {
              "type": "wikilink",
              "text": "封裝"
            },
            {
              "type": "text",
              "text": " 元件 (Package)。\n*   "
