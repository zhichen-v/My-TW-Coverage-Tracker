  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "立隆電子工業股份有限公司 (Lelon Electronics Corp.) 成立於 1976 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "台中"
            },
            {
              "type": "text",
              "text": "。公司為全球主要鋁質電解電容器製造商，產品涵蓋液態鋁電容、固態鋁電容 (Polymer) 及混合型鋁電容 (Hybrid)。立隆電擁有垂直整合優勢 (透過立敦製造鋁箔)，產品廣泛應用於"
            },
            {
              "type": "wikilink",
              "text": "車用電子"
            },
            {
              "type": "text",
              "text": " (EV)、"
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": " 網通及"
            },
            {
              "type": "wikilink",
              "text": "AI Server"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "立隆電位於被動元件產業鏈中游製造端。\n*   "
            },
            {
              "type": "strong",
              "text": "上游 (材料):"
            },
            {
              "type": "text",
              "text": " 化成鋁箔 (轉投資"
            },
            {
              "type": "wikilink",
              "text": "Liton"
            },
            {
              "type": "text",
              "text": " 立敦, 6175), 電解液, 橡膠, 鋁殼。\n*   "
            },
            {
              "type": "strong",
              "text": "中游 (製造):"
            },
            {
              "type": "text",
              "text": " 捲繞、含浸、組立、老化測試 (蘇州/惠州/泰國廠).\n*   "
            },
            {
              "type": "strong",
              "text": "下游 (應用):"
            },
            {
              "type": "text",
              "text": "\n*   "
            },
            {
              "type": "strong",
              "text": "車用:"
            },
            {
              "type": "text",
              "text": " 歐美 Tier 1 車廠 ("
            },
            {
              "type": "wikilink",
              "text": "Bosch"
            },
            {
              "type": "text",
              "text": ", "
            },
            {
              "type": "wikilink",
              "text": "Continental"
            },
            {
              "type": "text",
              "text": "), 中國車廠 ("
            },
            {
              "type": "wikilink",
              "text": "BYD"
            },
            {
              "type": "text",
              "text": ").\n*   "
            },
            {
              "type": "strong",
              "text": "網通:"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "Huawei"
            },
            {
              "type": "text",
              "text": " (華為), "
            },
            {
              "type": "wikilink",
              "text": "Nokia"
            },
            {
              "type": "text",
              "text": ", "
            },
            {
              "type": "wikilink",
              "text": "Ericsson"
            },
            {
              "type": "text",
              "text": ".\n*   "
            },
            {
              "type": "strong",
              "text": "工控/綠能:"
            },
            {
              "type": "text",
              "text": " 變頻器、風電/太陽能逆變器。"
            }
          ]
        }
      ],
