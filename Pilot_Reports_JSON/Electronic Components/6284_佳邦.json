  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "佳邦科技股份有限公司 (6284，INPAQ) 隸屬於"
            },
            {
              "type": "wikilink",
              "text": "華新焦家"
            },
            {
              "type": "text",
              "text": "集團旗下的"
            },
            {
              "type": "wikilink",
              "text": "PSA華科事業群"
            },
            {
              "type": "text",
              "text": "，是一家專注於高頻微波通訊天線及電路保護元件的設計製造廠。佳邦的核心產品包括"
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "Wi-Fi 6"
            },
            {
              "type": "text",
              "text": "/6E高頻天線、GPS/GNSS定位天線、NFC模組以及各類過電壓/過電流保護元件。這些關鍵零件被廣泛應用於"
            },
            {
              "type": "wikilink",
              "text": "智慧型手機"
            },
            {
              "type": "text",
              "text": "、筆記型電腦、穿戴式裝置及"
            },
            {
              "type": "wikilink",
              "text": "車用電子"
            },
            {
              "type": "text",
              "text": "(如"
            },
            {
              "type": "wikilink",
              "text": "車聯網"
            },
            {
              "type": "text",
              "text": "模組)。受惠於"
            },
            {
              "type": "wikilink",
              "text": "物聯網"
            },
            {
              "type": "text",
              "text": "終端設備增加及高速傳輸需求，佳邦的高頻天線及保護元件出貨量穩健攀升。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 陶瓷粉末材料(用於LTCC天線)、高分子聚合物、"
            },
            {
              "type": "wikilink",
              "text": "銅箔"
            },
            {
              "type": "text",
              "text": "、導電膠及各式金屬微波材料。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "佳邦科技"
            },
            {
              "type": "text",
              "text": " (高頻微波天線、射頻模組及過電壓/過電流電路保護元件研發製造)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 系統組裝代工廠("
            },
            {
              "type": "wikilink",
              "text": "EMS"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "ODM"
            },
            {
              "type": "text",
              "text": ")、智慧終端機品牌廠及車用通訊模組製造商。"
            }
          ]
        }
      ],
      "groups": []
    },
    "customer_supplier": {
      "heading": "主要客戶及供應商",
      "blocks": [],
      "groups": [
        {
          "title": "主要客戶",
          "blocks": [
            {
              "type": "paragraph",
              "segments": [
                {
                  "type": "text",
                  "text": "*   全球各大智慧型手機/PC品牌(如"
                },
                {
                  "type": "wikilink",
                  "text": "Apple"
                },
                {
                  "type": "text",
                  "text": "、非蘋陣營)、穿戴式裝置廠及各大車用電子Tier 1。"
                }
              ]
            }
          ]
        },
        {
          "title": "主要供應商",
          "blocks": [
            {
              "type": "paragraph",
              "segments": [
                {
                  "type": "text",
                  "text": "*   日系及兩岸專業陶瓷粉末及特種高頻電子化學材料供應商。"
                }
              ]
            }
          ]
        }
      ]
    },
