  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "宣德科技 (Speed Tech) 成立於 1990 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "桃園"
            },
            {
              "type": "text",
              "text": "，為中國 "
            },
            {
              "type": "strong",
              "text": "立訊精密 (Luxshare)"
            },
            {
              "type": "text",
              "text": " 集團成員 (立訊持股約 30%)。主要從事 "
            },
            {
              "type": "strong",
              "text": "電子連接器"
            },
            {
              "type": "text",
              "text": " 及 "
            },
            {
              "type": "strong",
              "text": "線纜模組"
            },
            {
              "type": "text",
              "text": " 之製造。產品涵蓋 "
            },
            {
              "type": "wikilink",
              "text": "Type-C"
            },
            {
              "type": "text",
              "text": ", RJ45, USB, HDMI 等"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "，近年積極拓展 "
            },
            {
              "type": "strong",
              "text": "FATP (整機組裝)"
            },
            {
              "type": "text",
              "text": " 業務，應用領域擴及 "
            },
            {
              "type": "strong",
              "text": "[[低軌衛星]]"
            },
            {
              "type": "text",
              "text": " (Starlink)、"
            },
            {
              "type": "strong",
              "text": "[[電動車]]"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "Tesla"
            },
            {
              "type": "text",
              "text": ")、"
            },
            {
              "type": "strong",
              "text": "美系手機"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "Apple"
            },
            {
              "type": "text",
              "text": ") 及 "
            },
            {
              "type": "strong",
              "text": "[[AI 伺服器]]"
            },
            {
              "type": "text",
              "text": " (高速"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "/線束)。"
            }
          ]
