            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "端子"
            },
            {
              "type": "text",
              "text": "及相關電子零件。公司提供各式電子連接解決方案，應用於"
            },
            {
              "type": "wikilink",
              "text": "消費電子"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "資訊設備"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "工業"
            },
            {
              "type": "text",
              "text": "領域。總部位於台北內湖。"
