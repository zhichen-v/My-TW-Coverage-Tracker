    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "信錦企業股份有限公司 (Syncmold Enterprise Corp.) 成立於 1979 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "新北"
            },
            {
              "type": "text",
              "text": "。信錦為全球最大之"
            },
            {
              "type": "wikilink",
              "text": "顯示器"
            },
            {
              "type": "text",
              "text": "樞紐 (Monitor Hinge) 與底座製造商，市佔率極高。公司具備模具開發、沖壓、壓鑄、射出成型及組裝之垂直整合能力。近年積極佈局折疊裝置樞紐與"
            },
            {
              "type": "wikilink",
              "text": "低軌衛星"
            },
            {
              "type": "text",
              "text": "地面接收設備機構件。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "信錦位於顯示器零組件產業鏈中游製造端。\n*   "
            },
            {
              "type": "strong",
              "text": "上游:"
            },
            {
              "type": "text",
              "text": " 採購鋼材、鋅/鋁合金、工程塑膠。\n*   "
            },
            {
              "type": "strong",
              "text": "中游:"
            },
            {
              "type": "text",
              "text": " 模具開發、沖壓/壓鑄/射出、塗裝、組裝。\n*   "
            },
            {
              "type": "strong",
              "text": "下游:"
            },
            {
              "type": "text",
              "text": " 供應給顯示器代工廠及品牌商。"
            }
          ]
        }
      ],
      "groups": []
    },
