  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "光環科技股份有限公司 (6442，光聖) 是一家專注於"
            },
            {
              "type": "wikilink",
              "text": "光通訊"
            },
            {
              "type": "text",
              "text": "主動與被動元件、以及射頻(RF)"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "的製造商。光環以其優異的光纖跳接線、光被動元件與高頻"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "產品，廣泛應用於電信基礎建設、有線電視寬頻及企業"
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "(Data Center)。隨著"
            },
            {
              "type": "wikilink",
              "text": "AI[[伺服器"
            },
            {
              "type": "text",
              "text": "]]與雲端運算帶來龐大的數據傳輸需求，光聖的高階光被動元件與多芯光纖"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "需求暴增，並成功打入美系大型"
            },
            {
              "type": "wikilink",
              "text": "雲端服務"
            },
            {
              "type": "text",
              "text": "供應商("
            },
            {
              "type": "wikilink",
              "text": "CSP"
            },
            {
              "type": "text",
              "text": ")的"
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "供應鏈。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 光纖裸線、雷射二極體(LD)及檢光二極體(PIN)晶粒、陶瓷插芯及各類金屬機構件。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "光聖"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "光通訊"
            },
            {
              "type": "text",
              "text": "主動/被動元件、光纖跳接線及高頻無源RF"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "之製造)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 大型電信營運商(Telco)、有線電視多系統經營者(MSO)、"
            },
            {
              "type": "wikilink",
              "text": "網通"
            },
            {
              "type": "text",
              "text": "設備廠及"
            },
            {
              "type": "wikilink",
              "text": "雲端服務"
            },
            {
              "type": "text",
              "text": "商("
            },
            {
              "type": "wikilink",
              "text": "CSP"
            },
            {
              "type": "text",
              "text": ")。"
            }
          ]
        }
      ],
      "groups": []
    },
