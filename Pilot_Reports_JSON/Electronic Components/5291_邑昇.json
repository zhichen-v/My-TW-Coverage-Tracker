          "segments": [
            {
              "type": "text",
              "text": "邑昇實業 (Eiso) 主要從事 "
            },
            {
              "type": "strong",
              "text": "PCB (印刷電路板)"
            },
            {
              "type": "text",
              "text": " 製造與 "
            },
            {
              "type": "strong",
              "text": "LED 自行車燈"
            },
            {
              "type": "text",
              "text": "。\n業務雙引擎：\n1.  "
            },
            {
              "type": "strong",
              "text": "PCB (主業)"
            },
            {
              "type": "text",
              "text": ": 專注於少量多樣之工控、"
            },
            {
              "type": "wikilink",
              "text": "網通"
            },
            {
              "type": "text",
              "text": "、車用板。近年切入 "
            },
            {
              "type": "strong",
              "text": "[[低軌衛星]]"
            },
            {
              "type": "text",
              "text": " 供應鏈。\n2.  "
            },
            {
              "type": "strong",
              "text": "LED 光電"
            },
            {
              "type": "text",
              "text": ": 自有品牌 「DOSUN」 行銷自行車燈及 "
            },
            {
              "type": "strong",
              "text": "e-Bike (電動輔助自行車)"
            },
            {
              "type": "text",
              "text": "。\n*   推出 Cargo Bike (貨運自行車) 搶攻歐洲市場。"
            }
          ]
        }
