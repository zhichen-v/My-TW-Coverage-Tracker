  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "聯茂電子股份有限公司 (6213) 是一家在全球電子材料供應鏈中扮演關鍵角色的頂尖大廠。主要產品為"
            },
            {
              "type": "wikilink",
              "text": "銅箔"
            },
            {
              "type": "text",
              "text": "基板(CCL)與玻璃纖維膠片(PP)。聯茂是全球第二大的高速CCL供應商。面對"
            },
            {
              "type": "wikilink",
              "text": "AI[[伺服器"
            },
            {
              "type": "text",
              "text": "]](如"
            },
            {
              "type": "wikilink",
              "text": "NVIDIA"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "AMD"
            },
            {
              "type": "text",
              "text": "架構)、"
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": "高頻通訊及車用電子的強勁需求，聯茂積極佈局超低損耗(Ultra Low Loss)的高階高頻材料(如M9等級)，這些高技術門檻產品是其獲利成長的主要動能。公司生產基地遍及兩岸，並積極在泰國擴產以因應供應鏈轉移。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "wikilink",
              "text": "銅箔"
            },
            {
              "type": "text",
              "text": "、玻璃纖維布(電子級)、以及各類絕緣樹脂(如環氧樹脂)等基礎化學/金屬材料商。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "聯茂電子"
            },
            {
              "type": "text",
              "text": " (高頻高速"
            },
            {
              "type": "wikilink",
              "text": "銅箔"
            },
            {
              "type": "text",
              "text": "基板CCL、玻璃纖維膠片PP及"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "/封裝用基板材料之研發製造)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 多層印刷電路板("
            },
            {
              "type": "wikilink",
              "text": "PCB"
            },
            {
              "type": "text",
              "text": ")製造廠、IC載板廠，最終應用於"
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "網通"
            },
            {
              "type": "text",
              "text": "、車用及"
            },
            {
              "type": "wikilink",
              "text": "消費性電子"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
      ],
      "groups": []
    },
