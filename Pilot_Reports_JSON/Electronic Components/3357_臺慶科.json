  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "臺慶科 (TAI-TECH) 為專業 "
            },
            {
              "type": "strong",
              "text": "電感 (Inductor)"
            },
            {
              "type": "text",
              "text": " 與 "
            },
            {
              "type": "strong",
              "text": "磁性元件"
            },
            {
              "type": "text",
              "text": " 製造商。\n主要產品包括 "
            },
            {
              "type": "strong",
              "text": "積層晶片電感"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "strong",
              "text": "繞線電感"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "strong",
              "text": "一體成型功率電感"
            },
            {
              "type": "text",
              "text": " (Molding Power Choke) 及 "
            },
            {
              "type": "strong",
              "text": "網路變壓器"
            },
            {
              "type": "text",
              "text": "。\n產品廣泛應用於 "
            },
            {
              "type": "strong",
              "text": "車用電子"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "ADAS"
            },
            {
              "type": "text",
              "text": ", BMS, Infotainment)、"
            },
            {
              "type": "strong",
              "text": "網通設備"
            },
            {
              "type": "text",
              "text": " (Router, Switch, Lan Transformer) 及 "
            },
            {
              "type": "strong",
              "text": "[[AI 伺服器]]"
            },
            {
              "type": "text",
              "text": " (Power Choke, TLVR)。\n特別是 "
            },
            {
              "type": "strong",
              "text": "TLVR"
            },
            {
              "type": "text",
              "text": " (Trans-Inductor Voltage Regulator) 電感已切入 "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "電源供應鏈。"
            }
          ]
        }
      ],
