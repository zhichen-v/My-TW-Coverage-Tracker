  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "詠昇電子股份有限公司 (6418) 是一家立足台灣的專業訊號傳輸線材及"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "製造商。詠昇提供從模具設計、金屬沖壓、塑膠射出到線材橋接組裝的一條龍服務。產品線廣泛應用於"
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": "通訊、"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "、工控設備、"
            },
            {
              "type": "wikilink",
              "text": "AI 伺服器"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "醫療器材"
            },
            {
              "type": "text",
              "text": "等領域。詠昇憑藉高性價比及穩定的交期，不僅打入全球第二大醫療設備製造商供應鏈，也成為德國車廠之Tier 2供應商。近年來，詠昇亦積極配合客戶切入無人機供應鏈，佈局利基型傳輸線材市場。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 無氧銅線、PVC/TPE等塑膠絕緣粒、金屬沖壓件及電子端子。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "詠昇電子"
            },
            {
              "type": "text",
              "text": " (各類訊號傳輸線、"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "、PCBA及訊號放大器之製造組裝)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "wikilink",
              "text": "消費性電子"
            },
            {
              "type": "text",
              "text": "組裝廠、醫療設備製造商、汽車電子模組廠及"
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "代工廠。"
            }
          ]
        }
      ],
      "groups": []
    },
