  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "佳穎精密 (3310，"
            },
            {
              "type": "wikilink",
              "text": "Chialin"
            },
            {
              "type": "text",
              "text": ") 專注於精密金屬沖壓零組件製造。業務由三大區塊組成：車用電子、光電/半導體與消費電子。"
            }
          ]
        },
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "車用產品佔比最高，主要供應 "
            },
            {
              "type": "wikilink",
              "text": "Bosch"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "TE Connectivity"
            },
            {
              "type": "text",
              "text": " 等國際 Tier 1 大廠，應用於含氧感知器、噴油嘴、車用"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "端子等關鍵零組件。光電事業供應 "
            },
            {
              "type": "wikilink",
              "text": "億光"
            },
            {
              "type": "text",
              "text": " 等 LED 封裝廠之"
            },
            {
              "type": "wikilink",
              "text": "導線架"
            },
            {
              "type": "text",
              "text": "產品。消費電子領域則提供 "
            },
            {
              "type": "wikilink",
              "text": "Type-C"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "端子與鐵殼。近年透過併購晉碁強化"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "與線束佈局，並具備模具自主開發能力。生產基地涵蓋台灣桃園、中國 (昆山/東莞/淮安) 與泰國。"
            }
          ]
        }
      ],
      "groups": []
    },
