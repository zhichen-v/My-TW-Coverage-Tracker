  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "日勝化工 (1735，Evermore Chemical) 為日本"
            },
            {
              "type": "wikilink",
              "text": "AICA Kogyo"
            },
            {
              "type": "text",
              "text": " (持股 50.1%) 之台灣子公司，專精"
            },
            {
              "type": "wikilink",
              "text": "PU樹脂"
            },
            {
              "type": "text",
              "text": " (聚氨酯樹脂)、"
            },
            {
              "type": "wikilink",
              "text": "TPU"
            },
            {
              "type": "text",
              "text": " (熱塑性聚氨酯)、接著劑及 UV 硬化塗料製造。產品應用涵蓋鞋材 (供應"
            },
            {
              "type": "wikilink",
              "text": "寶成"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "豐泰"
            },
            {
              "type": "text",
              "text": "等"
            },
            {
              "type": "wikilink",
              "text": "Nike"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "adidas"
            },
            {
              "type": "text",
              "text": "代工廠)、合成皮革 (供應"
            },
            {
              "type": "wikilink",
              "text": "三芳"
            },
            {
              "type": "text",
              "text": ")、綠建材環保塗料 (與母公司"
            },
            {
              "type": "wikilink",
              "text": "AICA Kogyo"
            },
            {
              "type": "text",
              "text": "共同開發) 及光電抗反射/抗眩 UV 塗料。上游異氰酸酯原料採購自"
            },
            {
              "type": "wikilink",
              "text": "BASF"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Covestro"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "萬華化學"
            },
            {
              "type": "text",
              "text": "。生產基地位於台灣南投、中國及越南。"
            }
          ]
        }
      ],
      "groups": []
    },
