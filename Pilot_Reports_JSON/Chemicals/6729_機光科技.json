  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "機光科技 (6729，Luminescence Technology / Lumtec) 為台灣唯一完全自主研發之"
            },
            {
              "type": "wikilink",
              "text": "OLED"
            },
            {
              "type": "text",
              "text": "有機發光材料製造商，產品行銷逾 70 國。核心產品涵蓋 "
            },
            {
              "type": "wikilink",
              "text": "OLED"
            },
            {
              "type": "text",
              "text": " 發光/傳輸材料、"
            },
            {
              "type": "wikilink",
              "text": "TADF"
            },
            {
              "type": "text",
              "text": " (熱活化延遲螢光) 材料、"
            },
            {
              "type": "wikilink",
              "text": "OPV"
            },
            {
              "type": "text",
              "text": " (有機光伏) 材料、"
            },
            {
              "type": "wikilink",
              "text": "鈣鈦礦太陽能電池"
            },
            {
              "type": "text",
              "text": "材料、"
            },
            {
              "type": "wikilink",
              "text": "聚醯亞胺"
            },
            {
              "type": "text",
              "text": " (PI) 單體及 ITO 玻璃。毛利率約 65%。下游客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "Merck"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Dow"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "3M"
            },
            {
              "type": "text",
              "text": "等全球 "
            },
            {
              "type": "wikilink",
              "text": "OLED"
            },
            {
              "type": "text",
              "text": " 材料巨頭。PI 單體供應"
            },
            {
              "type": "wikilink",
              "text": "達邁"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "台虹"
            },
            {
              "type": "text",
              "text": "等 PI 膜廠用於軟性電路板及手機散熱。重要股東及共同開發夥伴為"
            },
            {
              "type": "wikilink",
              "text": "台化"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
      ],
      "groups": []
    },
