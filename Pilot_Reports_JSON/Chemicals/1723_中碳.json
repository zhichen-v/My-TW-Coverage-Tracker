  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "中鋼"
            },
            {
              "type": "text",
              "text": "碳素化學股份有限公司 (China Steel Chemical Corporation, CSCC) 成立於 1989 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "高雄"
            },
            {
              "type": "text",
              "text": "。公司為"
            },
            {
              "type": "wikilink",
              "text": "中鋼集團"
            },
            {
              "type": "text",
              "text": "成員，是台灣唯一之專業"
            },
            {
              "type": "wikilink",
              "text": "煤化工"
            },
            {
              "type": "text",
              "text": "製造商。中碳以"
            },
            {
              "type": "wikilink",
              "text": "中鋼"
            },
            {
              "type": "text",
              "text": "煉鋼副產品 (煤焦油、輕油) 為原料，生產各類化學品及碳材料。主要產品包括雜酚油、軟瀝青、苯、甲苯、以及鋰離子電池負極材料 ("
            },
            {
              "type": "wikilink",
              "text": "介相石墨碳微球"
            },
            {
              "type": "text",
              "text": ")。近年來，中碳積極轉型為碳材料供應商，切入"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "及儲能供應鏈。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [],
      "groups": [
        {
          "title": "上游 (高爐煉鋼之巨型副產物)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "煉鋼廢料再鑄:"
                    },
                    {
                      "type": "text",
                      "text": " 材料來源極度獨特且具備獨佔性，專門回收利用一貫化作業煉鋼廠之高爐衍生副產物如煤焦油 (Coal Tar) 與輕油 (Light Oil)，具備絕對的成本與料源優勢。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "中游 (全台唯一煤化工與電池碳材廠)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "特化與次世代材料樞紐:"
                    },
                    {
                      "type": "text",
                      "text": " "
                    },
                    {
                      "type": "strong",
                      "text": "中碳 (1723)"
                    },
                    {
                      "type": "text",
                      "text": " (為"
                    },
                    {
                      "type": "wikilink",
                      "text": "中鋼"
                    },
                    {
                      "type": "text",
                      "text": "集團重點培育之綠色金雞母，為台灣唯一且寡占的專業煤化工廠，提煉珍貴化學品如軟瀝青、雜酚油，並成功孕育量產出全球極稀缺的電動車電池「介相石墨碳微球」負極材料)。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "下游 (次世代能源與半導體長晶)",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "基礎化工至高科技應用:"
                    },
                    {
                      "type": "text",
                      "text": " 短期從傳統的化工苯/甲苯、建材用雜酚油、煉鋁廠用預焙陽極，強勢進軍至爆炸性成長的電動車鋰電池芯 (負極材料)、超級電容，以及第三代半導體 (SiC) 碳化矽長晶用之超純高溫碳粉原料。"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    "customer_supplier": {
      "heading": "主要客戶及供應商",
      "blocks": [],
      "groups": [
        {
          "title": "主要客戶",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "全球鋰電池芯與電動車供應鏈:"
                    },
                    {
                      "type": "text",
                      "text": " 其具備高自製率優勢之介相石墨微球深受國內外車廠與電池廠矚目，大量供應予 "
                    },
                    {
                      "type": "wikilink",
                      "text": "台塑集團"
                    },
                    {
                      "type": "text",
                      "text": " 電池芯廠、"
                    },
                    {
                      "type": "wikilink",
                      "text": "鴻海 MIH 聯盟"
                    },
                    {
                      "type": "text",
                      "text": " 相關成員，以及歐美日各大動力電池龍頭企業。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "國際大型煉鋁與高爐鋼鐵廠:"
                    },
                    {
                      "type": "text",
                      "text": " 從煤焦油精煉回收提煉之高品質軟瀝青 (Soft Pitch)，則跨洋遠銷至澳洲、加拿大等地之國際頂級煉鋁大廠，作為煉鋁電極不可或缺之高單價黏結劑。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "主要供應商",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "絕對獨占的鋼鐵霸主母集團:"
                    },
                    {
                      "type": "text",
                      "text": " 擁有全台無法被複製之堅實原料護城河，其工業用初級原料 100% 絕對仰賴同集團老大哥 "
                    },
                    {
                      "type": "wikilink",
                      "text": "中鋼"
                    },
                    {
                      "type": "text",
                      "text": " (2002) 及其子公司 "
                    },
                    {
                      "type": "wikilink",
                      "text": "中龍鋼鐵"
                    },
                    {
                      "type": "text",
                      "text": " 之穩定且極低成本的高爐煉鋼副產物之管線直供。"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
