            {
              "type": "wikilink",
              "text": "網路設備"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "工業控制"
            },
            {
              "type": "text",
              "text": "、"
            },
