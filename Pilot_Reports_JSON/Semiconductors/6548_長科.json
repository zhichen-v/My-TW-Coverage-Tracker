  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "長華科技股份有限公司 (6548，長科*) 隸屬於長華集團，是全球排名第二的"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "IC"
            },
            {
              "type": "wikilink",
              "text": "導線架"
            },
            {
              "type": "text",
              "text": "(Leadframe)製造巨擘。長科*專精於各式"
            },
            {
              "type": "wikilink",
              "text": "導線架"
            },
            {
              "type": "text",
              "text": "的研發與製造，涵蓋傳統的Non-QFN及先進的QFN(四方平面無引腳)封裝"
            },
            {
              "type": "wikilink",
              "text": "導線架"
            },
            {
              "type": "text",
              "text": "。"
            },
            {
              "type": "wikilink",
              "text": "導線架"
            },
            {
              "type": "text",
              "text": "是晶片封裝中負責訊號傳輸與"
            },
            {
              "type": "wikilink",
              "text": "散熱"
            },
            {
              "type": "text",
              "text": "的極關鍵材料。受惠於"
            },
            {
              "type": "wikilink",
              "text": "AI[[伺服器"
            },
            {
              "type": "text",
              "text": "]]高壓直流電源(HVDC)、"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "第三代[[半導體"
            },
            {
              "type": "text",
              "text": "]]("
            },
            {
              "type": "wikilink",
              "text": "碳化矽"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "氮化鎵"
            },
            {
              "type": "text",
              "text": ")對大電流與高效"
            },
            {
              "type": "wikilink",
              "text": "散熱"
            },
            {
              "type": "text",
              "text": "的嚴苛要求，長科*的車用及工控高階"
            },
            {
              "type": "wikilink",
              "text": "導線架"
            },
            {
              "type": "text",
              "text": "需求強勁，並積極擴建馬來西亞新廠以就近供應國際IDM大廠。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 高品質銅合金"
            },
            {
              "type": "wikilink",
              "text": "銅箔"
            },
            {
              "type": "text",
              "text": "、鐵鎳合金、電鍍用化學藥水及貴金屬(如金、銀、鈀)。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": **長華科技(長科*)** ("
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "IC及LED"
            },
            {
              "type": "wikilink",
              "text": "導線架"
            },
            {
              "type": "text",
              "text": "之沖壓/"
            },
            {
              "type": "wikilink",
              "text": "蝕刻"
            },
            {
              "type": "text",
              "text": "製造與電鍍加工)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "封裝測試代工廠(OSAT)及全球整合元件製造大廠(IDM)。"
            }
          ]
        }
      ],
      "groups": []
    },
