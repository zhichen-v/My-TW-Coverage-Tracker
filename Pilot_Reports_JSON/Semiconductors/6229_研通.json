            {
              "type": "wikilink",
              "text": "微控制器"
            },
            {
              "type": "text",
              "text": " IC ("
            },
            {
              "type": "wikilink",
              "text": "MCU"
            },
            {
              "type": "text",
              "text": ")，加入"
            },
            {
              "type": "wikilink",
              "text": "韌體"
            },
            {
              "type": "text",
              "text": "設計開發以提升消費性 IC 產品附加價值。業務涵蓋 MCU 韌體應用設計、IC "
            },
            {
              "type": "wikilink",
              "text": "系統整合"
            },
            {
              "type": "text",
              "text": "服務、電子"
            },
            {
              "type": "wikilink",
              "text": "電路設計"
            },
            {
              "type": "text",
              "text": "及 IC 晶片買賣代理。"
