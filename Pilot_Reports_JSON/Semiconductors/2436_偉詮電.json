                    },
                    {
                      "type": "text",
                      "text": " 筆記型電腦 (NB)、Switch 遊戲機、智慧型手機快充充電器 (Adapter/Charger)。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "馬達控制:"
                    },
                    {
                      "type": "text",
                      "text": " "
                    },
                    {
                      "type": "wikilink",
                      "text": "伺服器"
                    },
                    {
                      "type": "wikilink",
                      "text": "散熱"
                    },
                    {
                      "type": "text",
                      "text": "風扇 (Server Fan)、BLDC 馬達。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "其他:"
                    },
                    {
                      "type": "text",
                      "text": " 智慧鏡頭處理 IC ("
                    },
                    {
                      "type": "wikilink",
                      "text": "ADAS"
                    },
                    {
                      "type": "text",
                      "text": ")、POS 機讀頭 IC。"
                    }
                  ]
                }
              ]
            }
          ]
        }
