    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "茂矽電子 (2342) 是一家從 "
            },
            {
              "type": "wikilink",
              "text": "DRAM"
            },
            {
              "type": "text",
              "text": " 製造轉型為"
            },
            {
              "type": "wikilink",
              "text": "功率半導體"
            },
            {
              "type": "text",
              "text": "晶圓代工的專業廠商。公司主力產品包括溝槽式 "
            },
            {
              "type": "wikilink",
              "text": "MOSFET"
            },
            {
              "type": "text",
              "text": "、溝槽式 "
            },
            {
              "type": "wikilink",
              "text": "IGBT"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "蕭特基二極體"
            },
            {
              "type": "text",
              "text": "及各類整流二極體，廣泛應用於"
            },
            {
              "type": "wikilink",
              "text": "車用電子"
            },
            {
              "type": "text",
              "text": "、工業電子、"
            },
            {
              "type": "wikilink",
              "text": "太陽能"
            },
            {
              "type": "text",
              "text": "逆變器及"
            },
            {
              "type": "wikilink",
              "text": "儲能"
            },
            {
              "type": "text",
              "text": "系統。車用電子已占營收近五成，公司並積極布局"
            },
            {
              "type": "wikilink",
              "text": "碳化矽"
            },
            {
              "type": "text",
              "text": " (SiC) 功率元件，預計 2026 年成為新成長動能。"
            }
          ]
        }
      ],
