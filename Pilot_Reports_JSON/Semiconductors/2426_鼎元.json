    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "鼎元光電 (2426) 是一家專業的 "
            },
            {
              "type": "wikilink",
              "text": "LED"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "磊晶"
            },
            {
              "type": "text",
              "text": "及晶粒製造商，主要產品涵蓋"
            },
            {
              "type": "wikilink",
              "text": "砷化鎵"
            },
            {
              "type": "text",
              "text": " (GaAs) 紅外線 LED、可見光 LED 晶粒、"
            },
            {
              "type": "wikilink",
              "text": "雷射二極體"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "光感測器"
            },
            {
              "type": "text",
              "text": "元件。公司核心技術包括 "
            },
            {
              "type": "wikilink",
              "text": "MOCVD"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "磊晶"
            },
            {
              "type": "text",
              "text": "製程與晶圓級封裝，產品廣泛應用於光通訊、安防監控、車用感測、消費電子及工業檢測等領域。公司在紅外線 LED 晶粒領域具有重要市場地位。"
            }
          ]
        }
      ],
      "groups": []
    },
