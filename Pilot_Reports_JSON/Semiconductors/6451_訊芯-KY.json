          "segments": [
            {
              "type": "text",
              "text": "訊芯科技 (6451，ShunSin Technology，KY) 為半導體組裝及測試服務商，專注於光通訊及射頻元件之後段封裝與測試。產品涵蓋光收發模組封裝、"
            },
            {
              "type": "wikilink",
              "text": "VCSEL"
            },
            {
              "type": "text",
              "text": " 封裝及 RF 模組組裝，應用於"
            },
            {
              "type": "wikilink",
              "text": "光通訊"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": " 基地台及"
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "。技術涵蓋"
            },
            {
              "type": "wikilink",
              "text": "COB"
            },
            {
              "type": "text",
              "text": " (Chip on Board) 及 "
            },
            {
              "type": "wikilink",
              "text": "SMT"
            },
            {
              "type": "text",
              "text": " 封裝。"
