                      "text": "車用/工控 (NOR Flash):"
                    },
                    {
                      "type": "text",
                      "text": " 廣泛應用於車載資通訊、"
                    },
                    {
                      "type": "wikilink",
                      "text": "ADAS"
                    },
                    {
                      "type": "text",
                      "text": "、工業控制等高品質要求領域。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "通訊/消費:"
                    },
