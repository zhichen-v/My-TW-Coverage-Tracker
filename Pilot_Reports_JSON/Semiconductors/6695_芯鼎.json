    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "芯鼎科技 (6695，iCatch) 為專業數位影像處理晶片 "
            },
            {
              "type": "wikilink",
              "text": "IC 設計"
            },
            {
              "type": "text",
              "text": "公司，核心產品為影像訊號處理器 ("
            },
            {
              "type": "wikilink",
              "text": "ISP"
            },
            {
              "type": "text",
              "text": ") 及"
            },
            {
              "type": "wikilink",
              "text": "SoC"
            },
            {
              "type": "text",
              "text": "，應用於行車記錄器、安防監控、"
            },
            {
              "type": "wikilink",
              "text": "ADAS"
            },
            {
              "type": "text",
              "text": " 車用鏡頭、駕駛監控系統 (DMS) 及智慧門鎖。已量產基於 ThetaEye "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": " 解決方案之 "
            },
            {
              "type": "wikilink",
              "text": "4K"
            },
            {
              "type": "text",
              "text": " 智慧監控 SoC，並切入"
            },
            {
              "type": "wikilink",
              "text": "車用電子"
            },
            {
              "type": "text",
              "text": "市場。"
            }
          ]
        }
      ],
