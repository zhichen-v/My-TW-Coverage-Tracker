          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "博磊科技 (Zen Voce) 為 "
            },
            {
              "type": "strong",
              "text": "半導體封裝設備"
            },
            {
              "type": "text",
              "text": " 與 "
            },
            {
              "type": "strong",
              "text": "測試治具 (Test Socket)"
            },
            {
              "type": "text",
              "text": " 供應商。\n主要產品：\n1.  "
            },
            {
              "type": "strong",
              "text": "設備"
            },
            {
              "type": "text",
              "text": ": 植球機 (Ball Mounter)、晶圓切割機 (Dicing Saw)、清洗機。\n2.  "
            },
            {
              "type": "strong",
              "text": "治具"
            },
            {
              "type": "text",
              "text": ": 測試座 (Socket)、Change Kit、"
            },
            {
              "type": "wikilink",
              "text": "探針卡"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "PCB"
            },
            {
              "type": "text",
              "text": "。\n客戶涵蓋封測廠 (OSAT) 與"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "text",
              "text": "廠。\n近年受惠於 "
            },
            {
              "type": "strong",
              "text": "高頻寬記憶體 ([[HBM]])"
            },
            {
              "type": "text",
              "text": " 與 "
            },
            {
              "type": "strong",
              "text": "AI 晶片"
            },
            {
              "type": "text",
              "text": " 封裝測試需求，帶動切割與植球設備成長。"
            }
          ]
        }
