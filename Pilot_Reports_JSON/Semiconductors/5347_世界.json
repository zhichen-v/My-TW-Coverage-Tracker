      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "世界先進 (5347，"
            },
            {
              "type": "wikilink",
              "text": "Vanguard International Semiconductor"
            },
            {
              "type": "text",
              "text": ") 為台灣特殊製程"
            },
            {
              "type": "wikilink",
              "text": "晶圓代工"
            },
            {
              "type": "text",
              "text": "領導廠商，"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": "持股約 28%。公司擁有五座 8 吋晶圓廠 (台灣及新加坡)，專精高壓、超高壓、"
            },
            {
              "type": "wikilink",
              "text": "BCD"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "SOI"
            },
            {
              "type": "text",
              "text": "、分離式元件、類比、混合訊號及 "
            },
            {
              "type": "wikilink",
              "text": "MEMS"
            },
            {
              "type": "text",
              "text": " 等特殊製程。近期與 "
            },
            {
              "type": "wikilink",
              "text": "NXP"
            },
            {
              "type": "text",
              "text": " 合資 VSMC 於新加坡建設 12 吋晶圓廠，預計 2027 年投產。"
            }
          ]
        }
      ],
