      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "日月光投控"
            },
            {
              "type": "text",
              "text": "投控 (ASE Technology Holding) 成立於 2018 年 ("
            },
            {
              "type": "wikilink",
              "text": "日月光投控"
            },
            {
              "type": "text",
              "text": "與"
            },
            {
              "type": "wikilink",
              "text": "矽品"
            },
            {
              "type": "text",
              "text": "合併)，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "高雄"
            },
            {
              "type": "text",
              "text": "。公司為全球 "
            },
            {
              "type": "strong",
              "text": "封測 (OSAT)"
            },
            {
              "type": "text",
              "text": " 龍頭，市佔率世界第一。主要業務分為 "
            },
            {
              "type": "strong",
              "text": "半導體封測 (ATM)"
            },
            {
              "type": "text",
              "text": " (含"
            },
            {
              "type": "wikilink",
              "text": "日月光投控"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "矽品"
            },
            {
              "type": "text",
              "text": ") 及 "
            },
            {
              "type": "strong",
              "text": "電子代工服務 (EMS)"
            },
            {
              "type": "text",
              "text": " (環旭電子 USI)。"
            },
            {
              "type": "wikilink",
              "text": "日月光投控"
            },
            {
              "type": "text",
              "text": "在 "
            },
            {
              "type": "strong",
              "text": "先進封裝"
            },
            {
              "type": "text",
              "text": " (SiP, Fan-out, 2.5D/3D IC, "
            },
            {
              "type": "wikilink",
              "text": "CoWoS"
            },
            {
              "type": "text",
              "text": "-S/L/R) 及 "
            },
            {
              "type": "strong",
              "text": "異質整合"
            },
            {
              "type": "text",
              "text": " 技術領先，為 "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": "、HPC 晶片之關鍵後段合作夥伴。"
            }
          ]
        }
      ],
      "groups": []
    },
