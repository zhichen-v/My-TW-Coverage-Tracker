          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "華星光通 (LuxNet) 成立於 1999 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "桃園"
            },
            {
              "type": "text",
              "text": "。公司主要業務為"
            },
            {
              "type": "wikilink",
              "text": "光通訊"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "strong",
              "text": "主動元件 (Active Components)"
            },
            {
              "type": "text",
              "text": " 之封裝與模組製造，產品包含 "
            },
            {
              "type": "strong",
              "text": "光收發模組 (Transceiver)"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "strong",
              "text": "TOSA/ROSA"
            },
            {
              "type": "text",
              "text": " (光傳送/接收次模組) 及 "
            },
            {
              "type": "strong",
              "text": "雷射二極體 (LD)"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "strong",
              "text": "檢光二極體 (PD)"
            },
            {
              "type": "text",
              "text": "。近年成功轉型，切入 "
            },
            {
              "type": "strong",
              "text": "[[Marvell]]"
            },
            {
              "type": "text",
              "text": " 供應鏈，成為其 "
            },
            {
              "type": "strong",
              "text": "光收發模組代工夥伴"
            },
            {
              "type": "text",
              "text": "，主要應用於 "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "及 "
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": " 基礎建設。"
