            },
            {
              "type": "text",
              "text": " (AWS), "
            },
            {
              "type": "wikilink",
              "text": "Intel"
            },
            {
              "type": "text",
              "text": ", "
            },
            {
              "type": "wikilink",
              "text": "Google"
            },
            {
              "type": "text",
              "text": " 等。\n*   "
            },
            {
              "type": "strong",
              "text": "自研晶片大廠"
            },
            {
              "type": "text",
              "text": ": 理想汽車 (車用電子), 高端"
            },
            {
              "type": "wikilink",
              "text": "網通"
            },
            {
              "type": "text",
              "text": "與超級電腦業者。"
            }
