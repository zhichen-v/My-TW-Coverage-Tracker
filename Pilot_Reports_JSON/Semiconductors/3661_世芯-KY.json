            },
            {
              "type": "text",
              "text": " (先進製程唯一夥伴)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游 (終端客戶)"
            },
            {
              "type": "text",
              "text": ":\n*   "
            },
            {
              "type": "strong",
              "text": "超大型[[資料中心]]"
            },
            {
              "type": "text",
