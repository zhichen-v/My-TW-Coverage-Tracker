    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "台亞半導體 (2340) 是一家專注於"
            },
            {
              "type": "wikilink",
              "text": "化合物半導體"
            },
            {
              "type": "wikilink",
              "text": "磊晶"
            },
            {
              "type": "text",
              "text": "與"
            },
            {
              "type": "wikilink",
              "text": "LED"
            },
            {
              "type": "text",
              "text": "晶粒製造的光電半導體廠商，為"
            },
            {
              "type": "wikilink",
              "text": "富采投控"
            },
            {
              "type": "text",
              "text": "集團成員。公司核心技術涵蓋"
            },
            {
              "type": "wikilink",
              "text": "砷化鎵"
            },
            {
              "type": "text",
              "text": " (GaAs) 及"
            },
            {
              "type": "wikilink",
              "text": "磷化銦鎵"
            },
            {
              "type": "text",
              "text": " (InGaP) "
            },
            {
              "type": "wikilink",
              "text": "磊晶"
            },
            {
              "type": "text",
              "text": "製程，產品包括紅外線發光元件、可見光 LED 晶粒、"
            },
            {
              "type": "wikilink",
              "text": "光感測元件"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "VCSEL"
            },
            {
              "type": "text",
              "text": " 雷射元件，廣泛應用於光通訊、消費電子、車用照明及工業感測等領域。"
            }
          ]
        }
      ],
      "groups": []
    },
