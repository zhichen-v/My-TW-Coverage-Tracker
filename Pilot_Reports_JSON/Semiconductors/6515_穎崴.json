  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "穎崴科技股份有限公司 (6515，WinWay) 是一家位居全球前三大的"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "測試介面巨擘，近年更躍升為全球第一大測試座(Test Socket)供應商。穎崴專精於提供"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "/HPC、高速網路通訊及手機AP晶片從晶圓端到最終成品的高頻、高功率電性測試解決方案。其「同軸測試座」(Coaxial Socket)與高階"
            },
            {
              "type": "wikilink",
              "text": "探針卡"
            },
            {
              "type": "text",
              "text": "技術，能完美對接"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "wikilink",
              "text": "CoWoS"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "InFO"
            },
            {
              "type": "text",
              "text": "等先進封裝以及"
            },
            {
              "type": "wikilink",
              "text": "CPO"
            },
            {
              "type": "text",
              "text": "(共封裝光學)的嚴苛測試需求。全球前20大"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "廠中高達九成皆為其客戶，是"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "軍備競賽中「賣鏟子」的標準受惠者。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 微細工程塑膠材料、特殊合金探針材料(鈀/鈹銅合金)、高頻電路板("
            },
            {
              "type": "wikilink",
              "text": "PCB"
            },
            {
              "type": "text",
              "text": ")及微機電(MEMS)加工設備。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "穎崴科技"
            },
            {
              "type": "text",
              "text": " (高階邏輯IC測試座Test Socket、MEMS"
            },
            {
              "type": "wikilink",
              "text": "探針卡"
            },
            {
              "type": "text",
              "text": "及溫控模組之設計製造)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 晶圓代工廠、IC封裝測試廠(OSAT)、全球頂級IC設計廠及大型雲端系統廠("
            },
            {
              "type": "wikilink",
              "text": "CSP"
            },
            {
              "type": "text",
              "text": ")。"
            }
          ]
        }
      ],
      "groups": []
    },
