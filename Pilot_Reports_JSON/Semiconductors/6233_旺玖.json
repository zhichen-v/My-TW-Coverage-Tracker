  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "旺玖科技股份有限公司 (6233) 是一家專注於USB控制晶片設計的老字號IC設計公司。除了傳統的晶片設計業務外，旺玖也積極發展與生產各類「高速與高頻"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "」，應用於"
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "、車用電子("
            },
            {
              "type": "wikilink",
              "text": "ADAS"
            },
            {
              "type": "text",
              "text": ")、工控醫療及"
            },
            {
              "type": "wikilink",
              "text": "消費性電子"
            },
            {
              "type": "text",
              "text": "。近期，旺玖亦投入微機電系統(MEMS)領域以及"
            },
            {
              "type": "wikilink",
              "text": "散熱"
            },
            {
              "type": "text",
              "text": "風扇馬達IC的開發，並成功打入"
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "與"
            },
            {
              "type": "wikilink",
              "text": "AI[[伺服器"
            },
            {
              "type": "text",
              "text": "]]的"
            },
            {
              "type": "wikilink",
              "text": "散熱"
            },
            {
              "type": "text",
              "text": "解決方案供應鏈，藉由多角化產品線(控制晶片+"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "+馬達IC)尋求營運突破。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 晶圓代工廠(Foundry)、"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "封裝測試廠(OSAT)，以及銅材/塑膠等"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "原料供應商。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "旺玖科技"
            },
            {
              "type": "text",
              "text": " (USB控制晶片、無刷馬達"
            },
            {
              "type": "wikilink",
              "text": "散熱"
            },
            {
              "type": "text",
              "text": "控制IC之設計，以及高頻高速"
            },
            {
              "type": "wikilink",
              "text": "連接器"
            },
            {
              "type": "text",
              "text": "之研發製造)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 電腦周邊設備廠、"
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "系統組裝廠、汽車電子模組廠及"
            },
            {
              "type": "wikilink",
              "text": "網通"
            },
            {
              "type": "text",
              "text": "交換器製造商。"
            }
          ]
        }
      ],
