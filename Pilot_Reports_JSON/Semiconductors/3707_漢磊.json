  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "漢磊科技 (Episil) 成立於 1985 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "新竹"
            },
            {
              "type": "text",
              "text": "，為 "
            },
            {
              "type": "strong",
              "text": "漢民集團 (Hermes-Epitek)"
            },
            {
              "type": "text",
              "text": " 成員。公司為全球第一家 "
            },
            {
              "type": "strong",
              "text": "Sub-micron Bipolar/BiCMOS"
            },
            {
              "type": "text",
              "text": " 專業代工廠，近年轉型為 "
            },
            {
              "type": "strong",
              "text": "化合物半導體 (Compound Semiconductor)"
            },
            {
              "type": "text",
              "text": " 專業代工廠，專注於 "
            },
            {
              "type": "strong",
              "text": "SiC ([[碳化矽]])"
            },
            {
              "type": "text",
              "text": " 及 "
            },
            {
              "type": "strong",
              "text": "GaN ([[氮化鎵]])"
            },
            {
              "type": "text",
              "text": " 功率"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "代工。漢磊擁有 6 吋晶圓廠，提供從"
            },
            {
              "type": "wikilink",
              "text": "磊晶"
            },
            {
              "type": "text",
              "text": " (Epi) 到晶圓製造 (Foundry) 的一站式服務 (與子公司嘉晶合作)。"
            }
          ]
        }
      ],
      "groups": []
    },
