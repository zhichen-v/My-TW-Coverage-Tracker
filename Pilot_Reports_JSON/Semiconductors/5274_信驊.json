    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "信驊科技 (ASPEED) 成立於 2004 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "新竹"
            },
            {
              "type": "text",
              "text": "。公司為全球 "
            },
            {
              "type": "strong",
              "text": "BMC (伺服器遠端管理晶片)"
            },
            {
              "type": "text",
              "text": " 市場龍頭，市佔率高達 70% 以上。核心產品為 "
            },
            {
              "type": "strong",
              "text": "BMC (Baseboard Management Controller)"
            },
            {
              "type": "text",
              "text": "，是"
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "不可或缺的關鍵元件。近年亦發展 "
            },
            {
              "type": "strong",
              "text": "Cupola360"
            },
            {
              "type": "text",
              "text": " (360度全景影像處理晶片) 及 "
            },
            {
              "type": "strong",
              "text": "AV over IP"
            },
            {
              "type": "text",
              "text": "延伸晶片，拓展 non-BMC 業務。信驊為台灣高價股 (股王等級) 代表，具備極高護城河。"
            }
          ]
        }
      ],
      "groups": []
    },
