            {
              "type": "wikilink",
              "text": "功率半導體"
            },
            {
              "type": "text",
              "text": "製造商，前身為"
            },
            {
              "type": "wikilink",
              "text": "統一"
            },
            {
              "type": "text",
              "text": "集團電子事業部，成立於 1987 年。公司主力產品為"
            },
            {
              "type": "wikilink",
              "text": "蕭特基二極體"
            },
            {
              "type": "text",
              "text": " (占營收約 85%)、"
            },
            {
              "type": "wikilink",
              "text": "功率電晶體"
            },
            {
              "type": "text",
              "text": " (約 14%)，以及新興的 "
            },
            {
              "type": "wikilink",
              "text": "Power MOSFET"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "碳化矽"
            },
            {
              "type": "text",
              "text": " (SiC) 蕭特基及 "
            },
            {
              "type": "wikilink",
              "text": "IGBT"
            },
            {
              "type": "text",
              "text": " 模塊。產品廣泛應用於資訊、通訊、"
            },
            {
              "type": "wikilink",
              "text": "消費電子"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "工業電子"
            },
