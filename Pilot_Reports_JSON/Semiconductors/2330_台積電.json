  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": " 成立於 1987 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "新竹"
            },
            {
              "type": "text",
              "text": "。公司是"
            },
            {
              "type": "strong",
              "text": "全球最大"
            },
            {
              "type": "text",
              "text": "且最先進的專用積體電路製造服務公司 (Pure-play Foundry)，市佔率超過 60%。"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": "引領全球"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "製程技術，目前已量產 3 奈米 (N3) 製程，並積極研發 2 奈米 (N2) 及 A16 技術。公司客戶涵蓋全球主要無晶圓廠 IC 設計公司及 IDM 大廠。"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": "是驅動 "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "、高效能運算 (HPC)、智慧型手機及車用電子發展的核心引擎。"
            }
          ]
        }
      ],
      "groups": []
    },
