  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "環球晶"
            },
            {
              "type": "text",
              "text": "圓股份有限公司 (6488，GlobalWafers) 隸屬於"
            },
            {
              "type": "wikilink",
              "text": "中美晶"
            },
            {
              "type": "text",
              "text": "集團，是全球前三大、台灣第一大的"
            },
            {
              "type": "wikilink",
              "text": "矽晶圓"
            },
            {
              "type": "text",
              "text": "供應商。"
            },
            {
              "type": "wikilink",
              "text": "環球晶"
            },
            {
              "type": "text",
              "text": "生產的產品橫跨6吋、8吋到先進的12吋"
            },
            {
              "type": "wikilink",
              "text": "矽晶圓"
            },
            {
              "type": "text",
              "text": "，並具備退火片(Annealed Wafer)、"
            },
            {
              "type": "wikilink",
              "text": "磊晶"
            },
            {
              "type": "text",
              "text": "圓(EPI Wafer)及矽晶絕緣體(SOI)等高附加價值產品的量產能力。近年來，公司更積極佈局"
            },
            {
              "type": "wikilink",
              "text": "第三代[[半導體"
            },
            {
              "type": "text",
              "text": "]]材料，如"
            },
            {
              "type": "wikilink",
              "text": "碳化矽"
            },
            {
              "type": "text",
              "text": "與"
            },
            {
              "type": "wikilink",
              "text": "氮化鎵"
            },
            {
              "type": "text",
              "text": "。"
            },
            {
              "type": "wikilink",
              "text": "環球晶"
            },
            {
              "type": "text",
              "text": "在全球擁有18座生產基地，為響應供應鏈在地化，目前正於美國德州擴建最新的12吋"
            },
            {
              "type": "wikilink",
              "text": "矽晶圓"
            },
            {
              "type": "text",
              "text": "廠，並已取得"
            },
            {
              "type": "wikilink",
              "text": "Apple"
            },
            {
              "type": "text",
              "text": "(蘋果)及其他巨頭的"
            },
            {
              "type": "wikilink",
              "text": "矽晶圓"
            },
            {
              "type": "text",
              "text": "長約(LTA)。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 電子級多晶矽(Polysilicon)、石英坩堝、研磨砂漿/拋光液、鑽石線及工業氣體/特種微電子化學品。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "[[環球晶]]圓"
            },
            {
              "type": "text",
              "text": " (各式"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "矽晶棒長晶、"
            },
            {
              "type": "wikilink",
              "text": "矽晶圓"
            },
            {
              "type": "text",
              "text": "切片/研磨與拋光，及"
            },
            {
              "type": "wikilink",
              "text": "第三代[[半導體"
            },
            {
              "type": "text",
              "text": "]]晶圓製造)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 晶圓代工廠(Foundry)、整合元件製造廠(IDM)及各大"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "晶片製造商。"
            }
          ]
        }
      ],
      "groups": []
    },
