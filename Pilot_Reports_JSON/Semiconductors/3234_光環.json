          "segments": [
            {
              "type": "text",
              "text": "光環科技 (3234) 是光學半導體元件製造商，專注於 "
            },
            {
              "type": "wikilink",
              "text": "VCSEL"
            },
            {
              "type": "text",
              "text": " (垂直共振腔面射型雷射)、FP/DFB 雷射及 PIN/PINTIA "
            },
            {
              "type": "wikilink",
              "text": "光偵測器"
            },
            {
              "type": "text",
              "text": "之研發與製造。產品應用於"
            },
            {
              "type": "wikilink",
              "text": "光纖通訊"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": " 基地台、雲端"
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "及 "
            },
            {
              "type": "wikilink",
              "text": "3D 感測"
            },
            {
              "type": "text",
              "text": "。近年開發 100G "
            },
            {
              "type": "wikilink",
              "text": "VCSEL"
            },
            {
              "type": "text",
              "text": " array 瞄準高速光互連需求。"
