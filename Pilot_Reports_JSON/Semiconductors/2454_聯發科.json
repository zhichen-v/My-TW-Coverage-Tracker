        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "聯發科"
            },
            {
              "type": "text",
              "text": "技 (2454) 是全球領先的無晶圓 "
            },
            {
              "type": "wikilink",
              "text": "IC 設計"
            },
            {
              "type": "text",
              "text": "公司，為全球每年超過 20 億台消費性裝置提供晶片。公司核心產品涵蓋智慧型手機 "
            },
            {
              "type": "wikilink",
              "text": "SoC"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "天璣"
            },
            {
              "type": "text",
              "text": "系列)、"
            },
            {
              "type": "wikilink",
              "text": "Wi-Fi 7"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "Wi-Fi 6"
            },
            {
              "type": "text",
              "text": " 無線連接晶片、智慧電視 "
            },
            {
              "type": "wikilink",
              "text": "SoC"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "ASIC"
            },
            {
              "type": "text",
              "text": " 客製化晶片及"
            },
            {
              "type": "wikilink",
              "text": "車用晶片"
            },
            {
              "type": "text",
              "text": "。"
            },
            {
              "type": "wikilink",
              "text": "聯發科"
            },
            {
              "type": "text",
              "text": "在 "
            },
            {
              "type": "wikilink",
              "text": "5G"
            },
            {
              "type": "text",
              "text": " 手機晶片市占率位居全球前二，並積極拓展 "
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": " 運算、"
            },
            {
              "type": "wikilink",
              "text": "生成式 AI"
            },
            {
              "type": "text",
              "text": " 端側推論及高階運算市場。"
            }
          ]
        }
      ],
