  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "義隆電子股份有限公司 (Elan Microelectronics Corp.) 成立於 1994 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "新竹"
            },
            {
              "type": "text",
              "text": "。公司為全球著名"
            },
            {
              "type": "wikilink",
              "text": "人機介面"
            },
            {
              "type": "text",
              "text": " (HMI) 晶片設計商，主要產品包括"
            },
            {
              "type": "wikilink",
              "text": "觸控板"
            },
            {
              "type": "text",
              "text": " (Touchpad) 模組、觸控螢幕 IC 及"
            },
            {
              "type": "wikilink",
              "text": "指紋辨識"
            },
            {
              "type": "text",
              "text": " IC。義隆在全球筆電觸控板市場市佔率第一，並積極佈局 AI PC 及車用觸控市場。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "義隆位於 IC 設計產業鏈上游。\n*   "
            },
            {
              "type": "strong",
              "text": "上游 (製造/封測):"
            },
            {
              "type": "text",
              "text": " 晶圓代工 ("
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": ", "
            },
            {
              "type": "wikilink",
              "text": "聯電"
            },
            {
              "type": "text",
              "text": ", "
            },
            {
              "type": "wikilink",
              "text": "VIS"
            },
            {
              "type": "text",
              "text": "), 封裝測試 (國內封測廠)。\n*   "
            },
            {
              "type": "strong",
              "text": "中游 (設計/模組):"
            },
            {
              "type": "text",
              "text": " IC 設計 (義隆), 觸控模組組裝。\n*   "
            },
            {
              "type": "strong",
              "text": "下游 (應用):"
            },
            {
              "type": "text",
              "text": " 筆記型電腦 ("
            },
            {
              "type": "wikilink",
              "text": "HP"
            },
            {
              "type": "text",
              "text": ", "
            },
            {
              "type": "wikilink",
              "text": "Dell"
            },
            {
              "type": "text",
