          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "天方能源 (3073，前身為普格科技/凱柏實業) 隸屬於"
            },
            {
              "type": "wikilink",
              "text": "力麗集團"
            },
            {
              "type": "text",
              "text": "，已完全轉型為"
            },
            {
              "type": "wikilink",
              "text": "再生能源"
            },
            {
              "type": "text",
              "text": "開發商與營運商。公司專注於"
            },
            {
              "type": "wikilink",
              "text": "太陽能"
            },
            {
              "type": "text",
              "text": "電廠開發、建置與售電，並跨足"
            },
            {
              "type": "wikilink",
              "text": "儲能系統"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "綠電"
            },
            {
              "type": "text",
              "text": "憑證銷售。前身為消費性 IC "
            },
            {
              "type": "wikilink",
              "text": "韌體設計"
            },
            {
              "type": "text",
              "text": "公司，後再轉型並更名為天方能源，切入"
            },
            {
              "type": "wikilink",
              "text": "台電"
            },
            {
              "type": "text",
              "text": "售電及"
            },
            {
              "type": "wikilink",
              "text": "分散式能源"
            },
            {
              "type": "text",
              "text": "商機。"
            }
          ]
        }
      ],
