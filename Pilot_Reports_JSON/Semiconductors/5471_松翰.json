  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "松翰科技（5471）成立於1996年，為國內知名IC設計公司，以消費性IC起家，目前在語音控制器IC領域居全球領導地位。主要產品線包括微控制器（"
            },
            {
              "type": "wikilink",
              "text": "MCU"
            },
            {
              "type": "text",
              "text": "）、多媒體IC（Webcam控制晶片）、消費性IC及光學辨識（OID）晶片。公司在USB視訊攝影機控制晶片市場佔有高市佔率，並積極拓展醫療與健康量測（如血壓計、耳溫槍"
            },
            {
              "type": "wikilink",
              "text": "MCU"
            },
            {
              "type": "text",
              "text": "）及車用電子市場。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "松翰為無晶圓廠（Fabless）IC設計公司，位於"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "產業鏈上游。"
            }
          ]
        },
        {
          "type": "list",
          "items": [
            {
              "segments": [
                {
                  "type": "strong",
                  "text": "上游:"
                },
                {
                  "type": "text",
                  "text": " 晶圓代工廠（"
                },
                {
                  "type": "wikilink",
                  "text": "台積電"
                },
                {
                  "type": "text",
                  "text": "、"
                },
                {
                  "type": "wikilink",
                  "text": "聯電"
                },
                {
                  "type": "text",
                  "text": "、MagnaChip、元隆）、封裝測試廠（超豐、久元）。"
                }
              ]
            },
            {
              "segments": [
                {
                  "type": "strong",
                  "text": "中游:"
                },
                {
                  "type": "text",
                  "text": " 松翰科技（IC設計與銷售）。"
