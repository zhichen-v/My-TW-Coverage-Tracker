  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "力成"
            },
            {
              "type": "text",
              "text": "科技股份有限公司 (6239) 是全球前五大、同時也是全球「最大」的"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "封裝測試廠。"
            },
            {
              "type": "wikilink",
              "text": "力成"
            },
            {
              "type": "text",
              "text": "的核心業務涵蓋晶片凸塊、晶圓測試、IC封裝及系統級組裝，提供一站式(Turn-key)的封測服務。面對"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "與高效能運算(HPC)的強勁需求，"
            },
            {
              "type": "wikilink",
              "text": "力成"
            },
            {
              "type": "text",
              "text": "積極佈局先進封裝技術，包含高頻寬"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "text",
              "text": "("
            },
            {
              "type": "wikilink",
              "text": "HBM"
            },
            {
              "type": "text",
              "text": ")封裝、2.5D/3D封裝以及扇出型面板級封裝("
            },
            {
              "type": "wikilink",
              "text": "FOPLP"
            },
            {
              "type": "text",
              "text": ")。公司與美光("
            },
            {
              "type": "wikilink",
              "text": "Micron"
            },
            {
              "type": "text",
              "text": ")、SK海力士等全球"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "text",
              "text": "巨頭結為緊密戰略夥伴，並承接"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "wikilink",
              "text": "CoWoS"
            },
            {
              "type": "text",
              "text": "封裝外溢訂單，是"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "text",
              "text": "供應鏈的關鍵推手。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 全球各大"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "text",
              "text": "製造商(IDM/Fabless)、晶圓代工廠(Foundry)及各類封裝材料/設備供應商。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "[[力成]]科技"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "DRAM"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "NAND"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "text",
              "text": "、邏輯IC之封測代工，及"
            },
            {
              "type": "wikilink",
              "text": "HBM"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "FOPLP"
            },
            {
              "type": "text",
              "text": "先進封裝技術研發製造)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 個人電腦、"
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "、智慧型手機、車用電子、雲端"
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "及各類"
            },
            {
              "type": "wikilink",
              "text": "消費性電子"
            },
            {
              "type": "text",
              "text": "產品製造商。"
            }
          ]
        }
      ],
      "groups": []
    },
