  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "金麗科技 (3228) 是台灣首家專注於高階省電 "
            },
            {
              "type": "wikilink",
              "text": "x86"
            },
            {
              "type": "text",
              "text": " 相容"
            },
            {
              "type": "wikilink",
              "text": "嵌入式處理器"
            },
            {
              "type": "text",
              "text": "的 "
            },
            {
              "type": "wikilink",
              "text": "IC 設計"
            },
            {
              "type": "text",
              "text": "公司。公司主力產品為 "
            },
            {
              "type": "wikilink",
              "text": "MCU"
            },
            {
              "type": "text",
              "text": " (占 2024 年營收 65%) 及 "
            },
            {
              "type": "wikilink",
              "text": "MPU"
            },
            {
              "type": "text",
              "text": "，涵蓋 16/32/64 位元微控制器、"
            },
            {
              "type": "wikilink",
              "text": "工業電腦"
            },
            {
              "type": "text",
              "text": " SoC 及網路控制處理器 (Emkore 平台)。產品廣泛應用於"
            },
            {
              "type": "wikilink",
              "text": "工業控制"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "CNC"
            },
            {
              "type": "text",
              "text": " 控制器、工業平板、無風扇電腦及"
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "儲存系統。台灣市場占 41%、亞洲占 58%。"
            }
          ]
        }
      ],
      "groups": []
    },
