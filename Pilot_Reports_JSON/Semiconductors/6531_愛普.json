  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "愛普科技股份有限公司 (6531，AP Memory，愛普*) 是一家專注於客製化與非標準型"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "text",
              "text": "IC設計的台灣"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "矽智財(IP)與晶片供應商。愛普的業務分為兩大引擎："
            },
            {
              "type": "wikilink",
              "text": "物聯網"
            },
            {
              "type": "text",
              "text": "事業群提供廣泛應用於穿戴式裝置的低功耗、小體積虛擬靜態隨機存取"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "text",
              "text": "(PSRAM)；而高成長的"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "事業群則專注於3D高頻寬客製化"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "text",
              "text": "(VHM)及高階矽電容(Silicon Capacitor)。其矽電容及VHM技術透過先進封裝(如"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "wikilink",
              "text": "CoWoS"
            },
            {
              "type": "text",
              "text": ")與邏輯晶片異質整合，能巨幅提升頻寬並降低功耗，是"
            },
            {
              "type": "wikilink",
              "text": "AI[[伺服器"
            },
            {
              "type": "text",
              "text": "]]與高階ASIC晶片的關鍵突破口。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "wikilink",
              "text": "矽晶圓"
            },
            {
              "type": "text",
              "text": "、晶圓代工製造服務、IC封裝測試服務及EDA(電子設計"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": ")軟體。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": **愛普科技(愛普*)** ("
            },
            {
              "type": "wikilink",
              "text": "物聯網"
            },
            {
              "type": "text",
              "text": "穿戴用PSRAM、"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "text",
              "text": "運算客製化"
            },
            {
              "type": "wikilink",
              "text": "記憶體"
            },
            {
              "type": "text",
              "text": "VHM及高階矽電容之設計與IP授權)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 無晶圓廠IC設計公司(Fabless)、"
            },
            {
              "type": "wikilink",
              "text": "雲端服務"
            },
            {
              "type": "text",
              "text": "供應商("
            },
            {
              "type": "wikilink",
              "text": "CSP"
            },
            {
              "type": "text",
              "text": "，開發自研晶片)、"
            },
            {
              "type": "wikilink",
              "text": "網通"
            },
            {
              "type": "text",
              "text": "廠及消費性系統廠。"
            }
          ]
        }
      ],
      "groups": []
    },
