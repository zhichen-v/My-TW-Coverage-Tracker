  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "裕隆汽車 (2201，Yulon Motor) 為台灣歷史最悠久之汽車集團，與"
            },
            {
              "type": "wikilink",
              "text": "日產汽車"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "Nissan"
            },
            {
              "type": "text",
              "text": ") 長期合資合作。核心業務涵蓋：(1) 整車組裝 — 苗栗三義廠為台灣主要汽車組裝基地；(2) 電動車合資 — 與"
            },
            {
              "type": "wikilink",
              "text": "鴻海集團"
            },
            {
              "type": "text",
              "text": "共同創立"
            },
            {
              "type": "wikilink",
              "text": "鴻華先進"
            },
            {
              "type": "text",
              "text": " (2258，"
            },
            {
              "type": "wikilink",
              "text": "鴻海"
            },
            {
              "type": "text",
              "text": "持股 45.62%、"
            },
            {
              "type": "wikilink",
              "text": "裕隆"
            },
            {
              "type": "text",
              "text": " 43.83%)，開發 Model C/B/E/T 等"
            },
            {
              "type": "wikilink",
              "text": "MIH"
            },
            {
              "type": "text",
              "text": "平台電動車；(3) 品牌轉讓 — 已將自有品牌"
            },
            {
              "type": "wikilink",
              "text": "納智捷"
            },
            {
              "type": "text",
              "text": " (LUXGEN) 100% 股權以 7.876 億元轉讓予"
            },
            {
              "type": "wikilink",
              "text": "鴻華先進"
            },
            {
              "type": "text",
              "text": "。集團版圖涵蓋"
            },
            {
              "type": "wikilink",
              "text": "裕隆日產"
            },
            {
              "type": "text",
              "text": " (2227)、"
            },
            {
              "type": "wikilink",
              "text": "中華汽車"
            },
            {
              "type": "text",
              "text": " (2204)、"
            },
            {
              "type": "wikilink",
              "text": "裕融"
            },
            {
              "type": "text",
              "text": " (9941，"
            },
            {
              "type": "wikilink",
              "text": "格上租車"
            },
            {
              "type": "text",
              "text": ")，另開發"
            },
            {
              "type": "wikilink",
              "text": "裕隆城"
            },
            {
              "type": "text",
              "text": "新店大型商場。"
            }
          ]
        }
      ],
      "groups": []
    },
