  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "中華汽車"
            },
            {
              "type": "text",
              "text": " (2204，China Motor Corporation) 為"
            },
            {
              "type": "wikilink",
              "text": "裕隆集團"
            },
            {
              "type": "text",
              "text": "核心製造企業，台灣輕型商用車龍頭。主要合作夥伴包含"
            },
            {
              "type": "wikilink",
              "text": "三菱汽車"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "Mitsubishi"
            },
            {
              "type": "text",
              "text": " Motors) 及"
            },
            {
              "type": "wikilink",
              "text": "三菱扶桑"
            },
            {
              "type": "text",
              "text": " (FUSO)。近年成功引進"
            },
            {
              "type": "wikilink",
              "text": "上汽集團"
            },
            {
              "type": "text",
              "text": "旗下"
            },
            {
              "type": "wikilink",
              "text": "MG"
            },
            {
              "type": "text",
              "text": "品牌，MG HS 車款銷售亮眼。產品線涵蓋：(1) 乘用車 — "
            },
            {
              "type": "wikilink",
              "text": "MG"
            },
            {
              "type": "text",
              "text": " HS、"
            },
            {
              "type": "wikilink",
              "text": "Outlander"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Eclipse Cross"
            },
            {
              "type": "text",
              "text": " PHEV；(2) 商用車 — "
            },
            {
              "type": "wikilink",
              "text": "Delica"
            },
            {
              "type": "text",
              "text": " (得利卡)、FUSO "
            },
            {
              "type": "wikilink",
              "text": "Canter"
            },
            {
              "type": "text",
              "text": " (堅達) 系列；(3) 電動商用車 — ET35 電動貨卡，已導入"
            },
            {
              "type": "wikilink",
              "text": "新竹物流"
            },
            {
              "type": "text",
              "text": "車隊；(4) 電動二輪 — 自有品牌"
            },
            {
              "type": "wikilink",
              "text": "eMOVING"
            },
            {
              "type": "text",
              "text": " iE125 自主充電系統。楊梅廠為主要生產基地。"
            }
          ]
        }
      ],
      "groups": []
    },
