    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "嘉裕股份有限公司 (1417) 為"
            },
            {
              "type": "wikilink",
              "text": "裕隆集團"
            },
            {
              "type": "text",
              "text": "旗下服飾事業，以「嘉裕西服 Carnival」品牌經營男士西服與正式服飾。公司曾為"
            },
            {
              "type": "wikilink",
              "text": "Giorgio Armani"
            },
            {
              "type": "text",
              "text": "台灣獨家代理商長達數十年，2021 年結束代理後轉由關係企業"
            },
            {
              "type": "wikilink",
              "text": "台元紡織"
            },
            {
              "type": "text",
              "text": "承接。近年積極轉型，成功承攬"
            },
            {
              "type": "wikilink",
              "text": "國防部"
            },
            {
              "type": "text",
              "text": "軍服統包標案 (含"
            },
            {
              "type": "wikilink",
              "text": "海軍司令部"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "空軍司令部"
            },
            {
              "type": "text",
              "text": "服裝供售站，金額達 21 億元)，與"
            },
            {
              "type": "wikilink",
              "text": "興采實業"
            },
            {
              "type": "text",
              "text": "子公司"
            },
            {
              "type": "wikilink",
              "text": "神采時尚"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "佳和實業"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "數博整合"
            },
            {
              "type": "text",
              "text": "共同得標。品牌零售通路以百貨專櫃及直營門市為主。"
            }
          ]
        }
      ],
