  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "太普高實業 (3284) 為印刷版材及營建雙主軸。印刷事業以"
            },
            {
              "type": "wikilink",
              "text": "CTP"
            },
            {
              "type": "text",
              "text": "熱敏版為主力，為台灣"
            },
            {
              "type": "wikilink",
              "text": "印刷"
            },
            {
              "type": "text",
              "text": "市場領導者，上游鋁基版材來自"
            },
            {
              "type": "wikilink",
              "text": "中鋁"
            },
            {
              "type": "text",
              "text": "等鋁材廠，感光材料來自日本化學品廠。營建事業受惠熊本"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": "擴廠帶動之日本"
            },
            {
              "type": "wikilink",
              "text": "不動產"
            },
            {
              "type": "text",
              "text": "開發投資效益。另代理"
            },
            {
              "type": "wikilink",
              "text": "Fujifilm"
            },
            {
              "type": "text",
              "text": "印刷相關設備。"
            }
          ]
        }
      ],
      "groups": []
    },
