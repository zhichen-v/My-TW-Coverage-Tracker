  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "廣運機械工程股份有限公司 (6125) 是一家專業的整廠智慧"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "物流系統整合工程服務商。業務涵蓋自動倉儲、輸送分揀系統及無人搬運車(AGV/AMR)。近年來，廣運憑藉強大的集團研發能量，大舉跨足"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "wikilink",
              "text": "資料中心"
            },
            {
              "type": "text",
              "text": "『"
            },
            {
              "type": "wikilink",
              "text": "水冷"
            },
            {
              "type": "wikilink",
              "text": "散熱"
            },
            {
              "type": "text",
              "text": "』領域(如機櫃內CDU與"
            },
            {
              "type": "wikilink",
              "text": "水冷"
            },
            {
              "type": "text",
              "text": "頭)，並成功切入"
            },
            {
              "type": "wikilink",
              "text": "NVIDIA"
            },
            {
              "type": "text",
              "text": "等國際大廠的"
            },
            {
              "type": "wikilink",
              "text": "AI[[伺服器"
            },
            {
              "type": "text",
              "text": "]]液冷供應鏈。同時也供應"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "自動物料搬送系統(AMHS)，從傳統設備商成功轉型為涵蓋"
            },
            {
              "type": "wikilink",
              "text": "AI"
            },
            {
              "type": "wikilink",
              "text": "散熱"
            },
            {
              "type": "text",
              "text": "與高階廠房"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "的綜合解決方案提供者。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "*   "
            },
            {
              "type": "strong",
              "text": "上游"
            },
            {
              "type": "text",
              "text": ": 馬達、減速機、感測器、液冷零組件(幫浦/管線/快接頭)、電控元件供應商。\n*   "
            },
            {
              "type": "strong",
              "text": "中游"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "廣運"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "物流/倉儲設備、液冷"
            },
            {
              "type": "wikilink",
              "text": "散熱"
            },
            {
              "type": "text",
              "text": "CDU系統與"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "自動搬運系統)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ": 各大電商物流中心、大型傳產與科技廠、"
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": "系統代工廠。"
            }
          ]
        }
      ],
      "groups": []
    },
