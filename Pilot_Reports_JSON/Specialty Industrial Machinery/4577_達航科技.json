            {
              "type": "text",
              "text": "達航科技 (4577，Grand Process Technology) 為"
            },
            {
              "type": "wikilink",
              "text": "PCB"
            },
            {
              "type": "text",
              "text": "雷射鑽孔設備與代工服務供應商，自有品牌「VELA」CO2 雷射鑽孔機。同時提供 CO2/UV 雷射代工服務，專攻高階硬板、"
            },
            {
              "type": "wikilink",
              "text": "ABF 載板"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "BT 載板"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "探針卡"
            },
            {
              "type": "text",
              "text": "基板之精密鑽孔/成型加工。下游客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "欣興"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "南亞電路板"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "景碩"
            },
            {
              "type": "text",
              "text": "等載板大廠。"
            }
