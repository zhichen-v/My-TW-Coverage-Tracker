    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "亞崴機電 (1530，AWEA) 隸屬"
            },
            {
              "type": "wikilink",
              "text": "程泰"
            },
            {
              "type": "text",
              "text": "集團 (1583)，有「龍門世家」之稱，為台灣龍門型加工中心機市占領先者。產品涵蓋龍門型/立式/臥式/五面加工中心機，應用於汽車模具、航太零件及風電零組件。另透過"
            },
            {
              "type": "wikilink",
              "text": "YAMA SEIKI"
            },
            {
              "type": "text",
              "text": "品牌行銷北美。上游控制器來自"
            },
            {
              "type": "wikilink",
              "text": "Fanuc"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Siemens"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Heidenhain"
            },
            {
              "type": "text",
              "text": "，傳動來自"
            },
            {
              "type": "wikilink",
              "text": "上銀"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "銀泰"
            },
            {
              "type": "text",
              "text": "。航太客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "漢翔"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
      ],
      "groups": []
    },
