  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "迅得機械股份有限公司 (6438) 是一家深耕"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "設備領域的專業廠商。公司早期從印刷電路板("
            },
            {
              "type": "wikilink",
              "text": "PCB"
            },
            {
              "type": "text",
              "text": ")的"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "設備起家，憑藉深厚的載具傳輸與控制技術，成功跨足"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "封裝測試及IC載板(如"
            },
            {
              "type": "wikilink",
              "text": "ABF"
            },
            {
              "type": "text",
              "text": "載板)的"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "搬運與倉儲系統(AMHS)。近年來，迅得積極配合"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "大廠的智慧工廠建置需求，提供客製化且高無塵等級的"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "物料搬運系統及微型倉儲設備，成為推動"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "產業工業4.0的重要推手。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
