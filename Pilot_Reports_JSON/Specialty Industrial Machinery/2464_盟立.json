    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "盟立"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "股份有限公司 (Mirle Automation Corp.) 成立於 1989 年，總部位於台灣"
            },
            {
              "type": "wikilink",
              "text": "新竹"
            },
            {
              "type": "text",
              "text": "科學園區。公司為台灣最大"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "系統整合商，核心技術涵蓋智慧"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "物流系統 (AS/RS)、"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "製程設備 (OHT/Stocker)、工業控制器及"
            },
            {
              "type": "wikilink",
              "text": "機器人"
            },
            {
              "type": "text",
              "text": "應用。盟立為 "
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": " 及面板廠之重要"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "合作夥伴，近期切入 "
            },
            {
              "type": "wikilink",
              "text": "CoWoS"
            },
            {
              "type": "text",
              "text": " 先進封裝"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "及 EFEM 設備。"
            }
          ]
        }
      ],
      "groups": []
    },
    "supply_chain": {
      "heading": "供應鏈位置",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "盟立位於"
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "設備產業鏈中游系統整合端。\n*   "
            },
            {
              "type": "strong",
              "text": "上游 (組件):"
            },
            {
              "type": "text",
              "text": " 減速機 (轉投資盟英), 馬達, 感測器, 滑軌, 氣壓元件。\n*   "
            },
            {
              "type": "strong",
              "text": "中游 (整合):"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "自動化"
            },
            {
              "type": "text",
              "text": "設備設計、製造、軟體控制 (AS/RS, OHT, AGV)。\n*   "
            },
            {
              "type": "strong",
              "text": "下游 (應用):"
            },
            {
              "type": "text",
              "text": "\n*   "
            },
            {
              "type": "strong",
              "text": "半導體:"
            },
            {
              "type": "text",
              "text": " 晶圓代工 ("
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": ", "
            },
            {
              "type": "wikilink",
              "text": "聯電"
            },
            {
              "type": "text",
              "text": "), 封測 ("
            },
            {
              "type": "wikilink",
              "text": "日月光投控"
            },
            {
              "type": "text",
              "text": ", "
            },
            {
              "type": "wikilink",
              "text": "矽品"
            },
            {
              "type": "text",
              "text": ").\n*   "
            },
            {
              "type": "strong",
              "text": "光電:"
            },
            {
              "type": "text",
              "text": " 面板廠 ("
            },
            {
              "type": "wikilink",
              "text": "友達"
            },
            {
              "type": "text",
              "text": ", "
            },
            {
