    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "福裕事業 (4513) 以自有品牌「Chevalier」行銷全球，專精精密"
            },
            {
              "type": "wikilink",
              "text": "磨床"
            },
            {
              "type": "text",
              "text": "製造，產品涵蓋平面磨床、"
            },
            {
              "type": "wikilink",
              "text": "CNC"
            },
            {
              "type": "text",
              "text": "龍門磨床及圓筒磨床。上游傳動來自"
            },
            {
              "type": "wikilink",
              "text": "上銀"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "線性滑軌"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "滾珠螺桿"
            },
            {
              "type": "text",
              "text": ")，控制器來自"
            },
            {
              "type": "wikilink",
              "text": "Fanuc"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Siemens"
            },
            {
              "type": "text",
              "text": "。產品應用於汽車零件、"
            },
            {
              "type": "wikilink",
              "text": "半導體"
            },
            {
              "type": "text",
              "text": "設備零組件、航太零件及模具研磨。另經營營建不動產。"
            }
          ]
        }
      ],
