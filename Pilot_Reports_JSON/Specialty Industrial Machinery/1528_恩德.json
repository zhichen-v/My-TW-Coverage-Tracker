  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "恩德科技 (1528，Anderson Industrial) 以自有品牌「ANDERSON」行銷全球，為台灣知名 CNC "
            },
            {
              "type": "wikilink",
              "text": "工具機"
            },
            {
              "type": "text",
              "text": "製造商，擅長"
            },
            {
              "type": "wikilink",
              "text": "木工機械"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "PCB"
            },
            {
              "type": "text",
              "text": "加工設備。產品涵蓋五軸加工中心機、大型龍門機、"
            },
            {
              "type": "wikilink",
              "text": "PCB"
            },
            {
              "type": "text",
              "text": "鑽孔機/成型機。德國設有子公司 AEMG 專事研發。上游控制器來自"
            },
            {
              "type": "wikilink",
              "text": "Fanuc"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Siemens"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Heidenhain"
            },
            {
              "type": "text",
              "text": "，傳動元件來自"
            },
            {
              "type": "wikilink",
              "text": "上銀"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "THK"
            },
            {
              "type": "text",
              "text": "。航太客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "Boeing"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Airbus"
            },
            {
              "type": "text",
              "text": "供應鏈之複材加工。"
            }
          ]
        }
      ],
      "groups": []
    },
