    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "中興電工 (1513，Chung-Hsin Electric) 為台灣"
            },
            {
              "type": "wikilink",
              "text": "氣體絕緣開關"
            },
            {
              "type": "text",
              "text": " (GIS) 領導廠，國內高壓 GIS 市佔約七成，唯一取得"
            },
            {
              "type": "wikilink",
              "text": "台電"
            },
            {
              "type": "text",
              "text": " 345kV GIS 認證。業務涵蓋重電設備 (GIS/配電盤)、EPC 統包工程、"
            },
            {
              "type": "wikilink",
              "text": "氫能"
            },
            {
              "type": "wikilink",
              "text": "燃料電池"
            },
            {
              "type": "text",
              "text": "及停車場管理 (嘟嘟房品牌)。受惠"
            },
            {
              "type": "wikilink",
              "text": "台電"
            },
            {
              "type": "text",
              "text": "強韌電網 (未來三年商機逾 500 億)，在手訂單約 401 億元，能見度三至五年。近年與弘鉅汽車合作開發氫"
            },
            {
              "type": "wikilink",
              "text": "燃料電池"
            },
            {
              "type": "text",
              "text": "巴士。"
            }
          ]
        }
      ],
      "groups": []
    },
