    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "天力離岸工程 (6793) 曾為台灣唯一離岸風機巨型"
            },
            {
              "type": "wikilink",
              "text": "碳纖維"
            },
            {
              "type": "text",
              "text": "葉片製造廠。"
            },
            {
              "type": "strong",
              "text": "重大變化:"
            },
            {
              "type": "text",
              "text": " 2025年5月"
            },
            {
              "type": "wikilink",
              "text": "Vestas"
            },
            {
              "type": "text",
              "text": "宣布退出台灣，天力完成最後葉片 (累計309片) 後產線全面停產裁員470人。"
            },
            {
              "type": "wikilink",
              "text": "Vestas"
            },
            {
              "type": "text",
              "text": "佔2023/2024營收達98%/94%。前景高度不確定。風場客戶含"
            },
            {
              "type": "wikilink",
              "text": "CIP"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Ørsted"
            },
            {
              "type": "text",
              "text": "。上游含"
            },
            {
              "type": "wikilink",
              "text": "台塑"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "上緯投控"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
      ],
