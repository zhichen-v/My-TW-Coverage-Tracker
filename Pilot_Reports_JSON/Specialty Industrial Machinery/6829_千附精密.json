            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "CVD"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "PVD"
            },
            {
              "type": "text",
              "text": "機台真空腔體，供應"
            },
            {
              "type": "wikilink",
              "text": "Applied Materials"
