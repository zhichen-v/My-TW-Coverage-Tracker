      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "為昇科技 (2252) 為"
            },
            {
              "type": "wikilink",
              "text": "為升電裝"
            },
            {
              "type": "text",
              "text": " (2231) 子公司，專注於 24/60/77/79 GHz "
            },
            {
              "type": "wikilink",
              "text": "毫米波雷達"
            },
            {
              "type": "text",
              "text": "開發，應用於"
            },
            {
              "type": "wikilink",
              "text": "ADAS"
            },
            {
              "type": "text",
              "text": "先進駕駛輔助系統。核心產品涵蓋"
            },
            {
              "type": "wikilink",
              "text": "AEB"
            },
            {
              "type": "text",
              "text": " (自動緊急煞車)、"
            },
            {
              "type": "wikilink",
              "text": "BSD"
            },
            {
              "type": "text",
              "text": " (盲點偵測)、"
            },
            {
              "type": "wikilink",
              "text": "RCTA"
            },
            {
              "type": "text",
              "text": " (後方交叉警示) 及"
            },
            {
              "type": "wikilink",
              "text": "4D成像雷達"
            },
            {
              "type": "text",
              "text": "。自主設計 77GHz "
            },
            {
              "type": "wikilink",
              "text": "CMOS"
            },
            {
              "type": "text",
              "text": " 雷達晶片，從天線設計到"
            },
            {
              "type": "wikilink",
              "text": "SMT"
            },
            {
              "type": "text",
              "text": "製造垂直整合。在中國商用車市場為前五大 OEM 中兩家之獨家供應商。正拓展北美校車及歐日 Tier 1 ("
            },
            {
              "type": "wikilink",
              "text": "Bosch"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Continental"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Denso"
            },
            {
              "type": "text",
              "text": ") 合作。"
            }
          ]
        }
      ],
