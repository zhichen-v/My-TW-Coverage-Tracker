            },
            {
              "type": "wikilink",
              "text": "吉利汽車"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "長城汽車"
            },
            {
              "type": "text",
              "text": "，新能源品牌客戶包含"
            },
            {
              "type": "wikilink",
              "text": "Tesla"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "蔚來"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "理想汽車"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "小鵬汽車"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "零跑汽車"
            },
            {
              "type": "text",
              "text": "。與 OEM 共同設計氛圍燈方案。墨西哥、泰國設有工廠，美國底特律設有子公司。"
            }
