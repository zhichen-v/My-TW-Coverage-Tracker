    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "華勝-KY (2248) 為汽車 LED 氛圍燈、閱讀燈及內外飾電子件之 Tier 1 供應商，2007 年起成為"
            },
            {
              "type": "wikilink",
              "text": "General Motors"
            },
            {
              "type": "text",
              "text": "全球供應商。主要客戶涵蓋傳統車廠"
            },
            {
              "type": "wikilink",
              "text": "General Motors"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Toyota"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Ford"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "BMW"
            },
            {
              "type": "text",
              "text": "及中國車廠"
            },
            {
              "type": "wikilink",
              "text": "上汽"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "北汽"
