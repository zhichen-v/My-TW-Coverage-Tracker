  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "怡利電子 (2497，E-Lead Electronic) 為車用抬頭顯示器 ("
            },
            {
              "type": "wikilink",
              "text": "HUD"
            },
            {
              "type": "text",
              "text": ") 及"
            },
            {
              "type": "wikilink",
              "text": "AR-HUD"
            },
            {
              "type": "text",
              "text": "之 Tier 1 供應商，中國 HUD 市場排名前三。核心產品涵蓋"
            },
            {
              "type": "wikilink",
              "text": "HUD"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "AR-HUD"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "3D HUD"
            },
            {
              "type": "text",
              "text": "及車載資通訊系統。主要 OEM 客戶涵蓋"
            },
            {
              "type": "wikilink",
              "text": "吉利汽車"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "一汽紅旗"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "長城汽車"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "奇瑞汽車"
            },
            {
              "type": "text",
              "text": "。印度市場拓展中，已取得"
            },
            {
              "type": "wikilink",
              "text": "Tata Motors"
            },
            {
              "type": "text",
              "text": " C-HUD 訂單。正與歐系"
            },
            {
              "type": "wikilink",
              "text": "Volkswagen"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Mercedes-Benz"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "BMW"
            },
            {
              "type": "text",
              "text": "洽談 3D HUD 專案。2024 年出貨約 50 萬台 HUD (年增 67%)。泰國設有工廠服務非中國市場。"
            }
          ]
        }
      ],
      "groups": []
    },
