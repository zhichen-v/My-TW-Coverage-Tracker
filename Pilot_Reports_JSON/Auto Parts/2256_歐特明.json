  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "歐特明智能科技 (2256，oToBrite) 為視覺 AI 演算法與車規相機模組之 Tier 1 供應商，專精 L2+ 至 L4 自動駕駛技術。核心產品涵蓋"
            },
            {
              "type": "wikilink",
              "text": "ADAS"
            },
            {
              "type": "text",
              "text": "視覺系統、"
            },
            {
              "type": "wikilink",
              "text": "自動停車"
            },
            {
              "type": "text",
              "text": " ("
            },
            {
              "type": "wikilink",
              "text": "APA"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "AVP"
            },
            {
              "type": "text",
              "text": ")、"
            },
            {
              "type": "wikilink",
              "text": "域控制器"
            },
            {
              "type": "text",
              "text": "及車規相機模組。最大客戶為"
            },
            {
              "type": "wikilink",
              "text": "小鵬汽車"
            },
            {
              "type": "text",
              "text": " (XPeng，歷史營收佔比逾 80%，目標降至 50%)。另供應"
            },
            {
              "type": "wikilink",
              "text": "納智捷"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "裕隆集團"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "鴻華先進"
            },
            {
              "type": "text",
              "text": "("
            },
            {
              "type": "wikilink",
              "text": "MIH"
            },
            {
              "type": "text",
              "text": "電動車平台)。影像感測器採用"
            },
            {
              "type": "wikilink",
              "text": "Sony"
            },
            {
              "type": "text",
              "text": " IMX623 及"
            },
            {
              "type": "wikilink",
              "text": "OmniVision"
            },
            {
              "type": "text",
              "text": "，運算平台整合"
            },
            {
              "type": "wikilink",
              "text": "indie Semiconductor"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "NVIDIA"
            },
            {
              "type": "text",
              "text": " Jetson。積極拓展日本、澳洲、歐美市場。"
            }
          ]
        }
      ],
      "groups": []
    },
