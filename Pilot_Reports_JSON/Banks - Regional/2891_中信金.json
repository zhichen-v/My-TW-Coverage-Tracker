  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "中國信託金融控股"
            },
            {
              "type": "text",
              "text": " (2891) 為台灣獲利能力最強之頂級民營金控。核心子公司"
            },
            {
              "type": "wikilink",
              "text": "中國信託商業銀行"
            },
            {
              "type": "text",
              "text": "長期穩坐「銀行獲利王」與「信用卡發卡王」龍頭，全台逾 150 家分行及近七千台 ATM (與"
            },
            {
              "type": "wikilink",
              "text": "統一超商"
            },
            {
              "type": "text",
              "text": "合作佈建)。旗下"
            },
            {
              "type": "wikilink",
              "text": "台灣人壽"
            },
            {
              "type": "text",
              "text": "為集團第二大獲利引擎。其他子公司涵蓋"
            },
            {
              "type": "wikilink",
              "text": "中國信託綜合證券"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "中國信託投信"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "台灣彩券"
            },
            {
              "type": "text",
              "text": "等。消費金融端與 "
            },
            {
              "type": "wikilink",
              "text": "LINE"
            },
            {
              "type": "text",
              "text": " 深度戰略合作，"
            },
            {
              "type": "wikilink",
              "text": "LINE Pay"
            },
            {
              "type": "text",
              "text": " 聯名卡發卡量領先市場。"
            }
          ]
        }
      ],
      "groups": []
    },
