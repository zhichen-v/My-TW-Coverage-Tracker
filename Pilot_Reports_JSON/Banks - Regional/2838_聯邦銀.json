    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "wikilink",
              "text": "聯邦商業銀行"
            },
            {
              "type": "text",
              "text": " (2838) 成立於 1989 年，隸屬泛"
            },
            {
              "type": "wikilink",
              "text": "聯邦集團"
            },
            {
              "type": "text",
              "text": "。全台設有約 50 家分行。該行在信用卡領域表現突出，與 "
            },
            {
              "type": "wikilink",
              "text": "LINE Bank"
            },
            {
              "type": "text",
              "text": " 聯名發行之信用卡深受市場歡迎。數位帳戶「New New Bank」已突破 50 萬戶。集團關聯"
            },
            {
              "type": "wikilink",
              "text": "瓏山林實業"
            },
            {
              "type": "text",
              "text": "從事不動產開發與飯店經營，為聯邦銀在建築融資領域提供穩定利基客源。"
            }
          ]
        }
      ],
      "groups": []
    },
