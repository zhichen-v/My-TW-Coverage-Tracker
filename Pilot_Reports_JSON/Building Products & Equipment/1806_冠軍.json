                  "segments": [
                    {
                      "type": "strong",
                      "text": "營建工程:"
                    },
                    {
                      "type": "text",
                      "text": " 一般住宅、公共工程、豪宅建案之內外牆與地坪鋪設"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "經銷通路:"
                    },
                    {
                      "type": "text",
                      "text": " 透過遍布全台之簽約經銷商與建材行，服務終端泥作師傅與設計師"
                    }
                  ]
                }
              ]
            }
          ]
