  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "中國電視公司 (9928，簡稱中視，CTV) 是台灣歷史悠久的無線電視廣播機構，成立於 1968 年。2008 年隨"
            },
            {
              "type": "wikilink",
              "text": "中國時報"
            },
            {
              "type": "text",
              "text": "集團易主，中視成為"
            },
            {
              "type": "wikilink",
              "text": "旺旺中時媒體集團"
            },
            {
              "type": "text",
              "text": "旗下核心媒體事業，與"
            },
            {
              "type": "wikilink",
              "text": "中天電視"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "中國時報"
            },
            {
              "type": "text",
              "text": "並列為集團「三中」媒體。中視目前經營四大高畫質頻道。中視新聞台於"
            },
            {
              "type": "wikilink",
              "text": "中華電信"
            },
            {
              "type": "text",
              "text": " "
            },
            {
              "type": "wikilink",
              "text": "MOD"
            },
            {
              "type": "text",
              "text": " 平台發送高清訊號。公司積極發展數位內容，於 "
            },
            {
              "type": "wikilink",
              "text": "YouTube"
            },
            {
              "type": "text",
              "text": " 經營 CTV 官方頻道，並透過 "
            },
            {
              "type": "wikilink",
              "text": "Facebook"
            },
            {
              "type": "text",
              "text": " 等社群平台進行內容分潤。"
            }
          ]
        }
      ],
      "groups": []
    },
