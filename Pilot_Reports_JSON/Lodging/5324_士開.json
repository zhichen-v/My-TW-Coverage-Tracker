    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "士林開發 (5324) 為"
            },
            {
              "type": "wikilink",
              "text": "仰德集團"
            },
            {
              "type": "text",
              "text": "旗下營建開發與飯店餐飲雙引擎企業。營建事業專注大台北地區之都市更新與住宅建案，代表作與建築師"
            },
            {
              "type": "wikilink",
              "text": "郭旭原"
            },
            {
              "type": "text",
              "text": "、日本建築大師"
            },
            {
              "type": "wikilink",
              "text": "山本理顯"
            },
            {
              "type": "text",
              "text": "合作。飯店事業經營集團內"
            },
            {
              "type": "wikilink",
              "text": "國賓大飯店"
            },
            {
              "type": "text",
              "text": "旗下創意潮牌 "
            },
            {
              "type": "wikilink",
              "text": "amba 意舍酒店"
            },
            {
              "type": "text",
              "text": "，於台北設有 "
            },
            {
              "type": "wikilink",
              "text": "amba 西門町"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "amba 中山"
            },
            {
              "type": "text",
              "text": "及 "
            },
            {
              "type": "wikilink",
              "text": "amba 松山"
            },
            {
              "type": "text",
              "text": " 三處據點。"
            },
            {
              "type": "wikilink",
              "text": "仰德集團"
            },
            {
              "type": "text",
              "text": "關係企業包括"
            },
            {
              "type": "wikilink",
              "text": "士林電機"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "國賓大飯店"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "新竹物流"
            },
            {
              "type": "text",
              "text": "等。"
            }
          ]
        }
      ],
