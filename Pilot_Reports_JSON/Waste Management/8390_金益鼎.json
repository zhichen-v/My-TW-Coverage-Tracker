                    {
                      "type": "wikilink",
                      "text": "AI 伺服器"
                    },
                    {
                      "type": "text",
                      "text": "與記憶體產業之鍍金材料"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "再生金屬："
                    },
                    {
                      "type": "text",
                      "text": " 廢鐵、銅、鋁、錫等混合金屬與單一金屬銷售"
                    }
                  ]
                }
              ]
            }
          ]
        }
