                      "type": "text",
                      "text": " 金、銀、鉑、鈀等高純度貴金屬銷售"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "電鍍材料："
                    },
                    {
                      "type": "text",
                      "text": " "
