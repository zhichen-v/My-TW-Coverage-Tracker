  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "德記洋行 (5902) 為隸屬"
            },
            {
              "type": "wikilink",
              "text": "統一集團"
            },
            {
              "type": "text",
              "text": " (母公司"
            },
            {
              "type": "wikilink",
              "text": "統一"
            },
            {
              "type": "text",
              "text": ")之行銷代理及物流企業，創立於 1867 年台南安平。核心業務涵蓋國際知名食品飲料與酒類品牌之代理進口銷售，代理品牌包括 "
            },
            {
              "type": "wikilink",
              "text": "Starbucks"
            },
            {
              "type": "text",
              "text": " 瓶裝咖啡、"
            },
            {
              "type": "wikilink",
              "text": "OATLY"
            },
            {
              "type": "text",
              "text": " 燕麥奶、"
            },
            {
              "type": "wikilink",
              "text": "森永製菓"
            },
            {
              "type": "text",
              "text": " 冰品與糖餅、"
            },
            {
              "type": "wikilink",
              "text": "Jeju 三多水"
            },
            {
              "type": "text",
              "text": "等。自有品牌擁有「"
            },
            {
              "type": "wikilink",
              "text": "開喜烏龍茶"
            },
            {
              "type": "text",
              "text": "」等產品線。酒類代理包括 "
            },
            {
              "type": "wikilink",
              "text": "Singha"
            },
            {
              "type": "text",
              "text": " 啤酒、"
            },
            {
              "type": "wikilink",
              "text": "Beck's"
            },
            {
              "type": "text",
              "text": " 啤酒及"
            },
            {
              "type": "wikilink",
              "text": "馬祖東引高粱"
            },
            {
              "type": "text",
              "text": "等。"
            }
          ]
        }
      ],
      "groups": []
    },
