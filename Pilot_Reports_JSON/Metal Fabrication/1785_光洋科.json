    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "光洋應用材料 (1785，Solar "
            },
            {
              "type": "wikilink",
              "text": "Applied Materials"
            },
            {
              "type": "text",
              "text": ") 為全球"
            },
            {
              "type": "wikilink",
              "text": "濺鍍靶材"
            },
            {
              "type": "text",
              "text": "領導廠商，以貴稀金屬回收精煉為平台。全球最大硬碟儲存媒體靶材廠 (市佔35%)，唯一具硬碟全膜層靶材供應能力。已切入"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": "3nm/5nm前段製程"
            },
            {
              "type": "wikilink",
              "text": "PVD"
            },
            {
              "type": "text",
              "text": "靶材 (台灣首家國產化)。另生產"
            },
            {
              "type": "wikilink",
              "text": "鍵合線"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "探針"
            },
            {
              "type": "text",
              "text": "材料及"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "特化品。VAS營收：儲存42%、半導體36%、顯示10%。靶材客戶含"
            },
            {
              "type": "wikilink",
              "text": "Seagate"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Western Digital"
            },
            {
              "type": "text",
              "text": "。面板含"
            },
            {
              "type": "wikilink",
              "text": "友達"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "群創"
            },
            {
              "type": "text",
              "text": "。封裝含"
            },
            {
              "type": "wikilink",
              "text": "日月光投控"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
      ],
