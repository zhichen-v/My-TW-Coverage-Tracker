            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "strong",
              "text": "鑫科 (3663)"
            },
            {
              "type": "text",
              "text": " - 濺鍍靶材研發製造、金屬載板開發、貴金屬回收。\n*   "
            },
            {
              "type": "strong",
              "text": "下游"
            },
            {
              "type": "text",
              "text": ":\n*   "
            },
            {
              "type": "strong",
              "text": "面板廠"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "wikilink",
              "text": "群創"
            },
            {
              "type": "text",
              "text": ", "
            },
            {
              "type": "wikilink",
              "text": "友達"
            },
            {
              "type": "text",
              "text": ", 一線 "
            },
            {
              "type": "wikilink",
              "text": "OLED"
            },
            {
              "type": "text",
              "text": " 品牌。\n*   "
            },
            {
              "type": "strong",
              "text": "半導體封測"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "wikilink",
              "text": "日月光投控"
            },
            {
              "type": "text",
              "text": ", 具備 "
            },
            {
              "type": "wikilink",
              "text": "FOPLP"
            },
            {
              "type": "text",
              "text": " 產線之系統廠與 IDM 客戶。\n*   "
            },
            {
              "type": "strong",
              "text": "生醫與特殊應用"
            },
            {
              "type": "text",
              "text": ": 硼中子捕獲治療 (BNCT) 設備材料。"
            }
          ]
        }
      ],
