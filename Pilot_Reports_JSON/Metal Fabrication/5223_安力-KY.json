          "segments": [
            {
              "type": "text",
              "text": "安力-KY (Anli) 為專業 "
            },
            {
              "type": "strong",
              "text": "金屬機構件"
            },
            {
              "type": "text",
              "text": " 製造商，以 "
            },
            {
              "type": "strong",
              "text": "散熱模組機構件"
            },
            {
              "type": "text",
              "text": " 為主力。\n核心工藝包含沖壓、壓鑄、CNC 加工。\n主要產品應用：\n1.  "
            },
            {
              "type": "strong",
              "text": "散熱零組件 (Thermal)"
            },
            {
              "type": "text",
              "text": ": 風扇框架、"
            },
            {
              "type": "wikilink",
              "text": "散熱"
            },
            {
              "type": "text",
              "text": "鰭片 (主要營收來源，應用於筆電/"
            },
            {
              "type": "wikilink",
              "text": "伺服器"
            },
            {
              "type": "text",
              "text": ")。\n2.  "
            },
            {
              "type": "strong",
              "text": "機構件"
            },
            {
              "type": "text",
              "text": ": 筆電外殼、支架。\n3.  "
            },
            {
              "type": "strong",
              "text": "車用"
            },
            {
              "type": "text",
              "text": ": "
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "零部件、LED 車燈"
            },
            {
              "type": "wikilink",
              "text": "散熱"
            },
            {
              "type": "text",
              "text": "。\n4.  "
            },
            {
