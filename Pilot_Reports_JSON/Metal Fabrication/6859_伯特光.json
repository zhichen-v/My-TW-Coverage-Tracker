    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "伯特光電 (6859) 專精高階光學鏡頭模具及精密金屬零組件。核心為超精密奈米微細加工與非球面鏡片成型模具。客戶含"
            },
            {
              "type": "wikilink",
              "text": "大立光"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "玉晶光"
            },
            {
              "type": "text",
              "text": "，間接進入"
            },
            {
              "type": "wikilink",
              "text": "Apple"
            },
            {
              "type": "text",
              "text": "供應鏈。模具精度決定手機/車載/"
            },
            {
              "type": "wikilink",
              "text": "VR"
            },
            {
              "type": "text",
              "text": "/"
            },
            {
              "type": "wikilink",
              "text": "AR"
            },
            {
              "type": "text",
              "text": "鏡片良率。上游設備含"
            },
            {
              "type": "wikilink",
              "text": "Nikon"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Carl Zeiss"
            },
            {
              "type": "text",
              "text": "量測儀器。2025年營收9.23億 (年增35%)。"
            }
          ]
        }
      ],
      "groups": []
    },
