                    },
                    {
                      "type": "wikilink",
                      "text": "LONGi"
                    },
                    {
                      "type": "text",
                      "text": "（隆基綠能）、"
                    },
                    {
                      "type": "wikilink",
                      "text": "晶澳"
                    },
                    {
                      "type": "text",
                      "text": " (JA Solar) 等國際一線電池大廠"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "[[AI 伺服器]]："
                    },
                    {
                      "type": "text",
                      "text": " 台灣主要ODM廠及散熱廠，需要液冷零組件"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "自營電廠："
                    },
                    {
                      "type": "text",
                      "text": " 菲律賓及台日太陽能電站"
                    }
                  ]
                }
              ]
            }
          ]
        }
