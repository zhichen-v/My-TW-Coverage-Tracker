                      "type": "strong",
                      "text": "營建機電:"
                    },
                    {
                      "type": "text",
                      "text": " 自來水管、消防管、電線導管 (EMT)。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "公共工程:"
                    },
                    {
                      "type": "text",
                      "text": " 捷運、機場航廈、大型場館結構。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "機械/傢俱:"
                    },
                    {
                      "type": "text",
                      "text": " 運動器材、辦公傢俱管件、汽機車零件。"
                    }
                  ]
                }
              ]
