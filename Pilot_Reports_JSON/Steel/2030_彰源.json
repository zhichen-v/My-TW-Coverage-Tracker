            {
              "type": "strong",
              "text": "不鏽鋼管"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "strong",
              "text": "不鏽鋼板"
            },
            {
              "type": "text",
              "text": "製造廠。主要產品包括"
            },
