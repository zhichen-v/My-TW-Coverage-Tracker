              "type": "wikilink",
              "text": "扣件"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "軌道扣件"
            },
            {
              "type": "text",
              "text": "及特殊扣件。上游盤元/線材來自"
            },
            {
              "type": "wikilink",
              "text": "中鋼"
            },
            {
              "type": "text",
              "text": "。下游外銷北美工業通路如"
            },
            {
              "type": "wikilink",
              "text": "Fastenal"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Grainger"
            },
            {
              "type": "text",
              "text": "。另拓展"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "用高強度扣件。"
            }
