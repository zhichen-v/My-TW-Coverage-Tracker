                  "segments": [
                    {
                      "type": "strong",
                      "text": "營建/建材:"
                    },
                    {
                      "type": "text",
                      "text": " 鐵皮屋頂、牆板、捲門、烤漆板 (主要應用)。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "家電:"
                    },
                    {
                      "type": "text",
                      "text": " 冰箱、冷氣機外殼 (抗指紋、環保鋼板)。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "汽車:"
                    },
                    {
                      "type": "text",
                      "text": " 車體鈑金部件。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "綠能:"
                    },
                    {
                      "type": "text",
                      "text": " 太陽能光電支架 (高耐蝕鋼材)。"
                    }
                  ]
                }
              ]
            }
