    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "燁輝企業 (2023) 隸屬"
            },
            {
              "type": "wikilink",
              "text": "義聯集團"
            },
            {
              "type": "text",
              "text": "，為台灣領先之鍍面鋼品製造商。產品以"
            },
            {
              "type": "wikilink",
              "text": "鍍鋅鋼捲"
            },
            {
              "type": "text",
              "text": " (佔約53%) 及"
            },
            {
              "type": "wikilink",
              "text": "烤漆鋼捲"
            },
            {
              "type": "text",
              "text": " (佔約40%) 為主。上游熱軋鋼捲來自"
            },
            {
              "type": "wikilink",
              "text": "中鋼"
            },
            {
              "type": "text",
              "text": "及關聯企業"
            },
            {
              "type": "wikilink",
              "text": "燁聯"
            },
            {
              "type": "text",
              "text": " (9957)。下游供應建材/家電/汽車。客戶含日系"
            },
            {
              "type": "wikilink",
              "text": "日立"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Panasonic"
            },
            {
              "type": "text",
              "text": "等家電品牌。子公司含"
            },
            {
              "type": "wikilink",
              "text": "燁興"
            },
            {
              "type": "text",
              "text": " (2007)。"
            }
          ]
        }
      ],
      "groups": []
    },
