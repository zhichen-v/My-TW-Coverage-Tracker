                      "text": "中鋼"
                    },
                    {
                      "type": "text",
                      "text": " (CSC) 及"
                    },
                    {
                      "type": "wikilink",
                      "text": "日本製鐵"
                    },
                    {
                      "type": "text",
                      "text": " (Nippon Steel) 採購，部分來自"
                    },
                    {
                      "type": "wikilink",
                      "text": "中龍鋼鐵"
                    },
                    {
                      "type": "text",
                      "text": "。"
                    }
