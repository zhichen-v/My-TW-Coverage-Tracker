                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "熱軋鋼捲:"
                    },
                    {
                      "type": "text",
                      "text": " 部分作為冷軋及製管原料。"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "下游應用",
          "blocks": [
            {
              "type": "list",
              "items": [
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "鋼管/五金:"
                    },
                    {
                      "type": "text",
                      "text": " 石油天然氣輸送管 (API 管)、結構用管、傢俱五金。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "建材:"
                    },
                    {
                      "type": "text",
                      "text": " 鍍鋅鋼捲用於屋頂、烤漆板底材。"
                    }
                  ]
                },
                {
                  "segments": [
                    {
                      "type": "strong",
                      "text": "汽車/家電:"
                    },
                    {
                      "type": "text",
                      "text": " 冷軋鋼板用於車體鈑金、家電外殼。"
                    }
                  ]
                }
              ]
            }
