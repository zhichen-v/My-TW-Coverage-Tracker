          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "華新麗華 (1605，Walsin Lihwa) 為大中華區"
            },
            {
              "type": "wikilink",
              "text": "電線電纜"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "不鏽鋼"
            },
            {
              "type": "text",
              "text": "領導廠商。收購義大利"
            },
            {
              "type": "wikilink",
              "text": "Cogne"
            },
            {
              "type": "text",
              "text": "切入歐洲高端不鏽鋼。投資印尼鎳礦 (與"
            },
            {
              "type": "wikilink",
              "text": "青山集團"
            },
            {
              "type": "text",
              "text": "合作) 掌握"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "電池材料。佈局"
            },
            {
              "type": "wikilink",
              "text": "離岸風電"
            },
            {
              "type": "wikilink",
              "text": "海底電纜"
            },
            {
              "type": "text",
              "text": "。客戶含"
            },
            {
              "type": "wikilink",
              "text": "台電"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "沃旭能源"
            },
            {
              "type": "text",
              "text": "。銅料來自"
            },
            {
              "type": "wikilink",
              "text": "Freeport-McMoRan"
            },
            {
              "type": "text",
              "text": "、"
