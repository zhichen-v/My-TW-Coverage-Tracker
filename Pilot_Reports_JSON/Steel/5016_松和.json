          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "松和工業 (5016) 為專業"
            },
            {
              "type": "wikilink",
              "text": "鋼索"
            },
            {
              "type": "text",
              "text": " (Wire Rope) 製造商，產品涵蓋各式"
            },
            {
              "type": "wikilink",
              "text": "不鏽鋼"
            },
            {
              "type": "text",
              "text": "鋼索、碳鋼鋼索及鋼纜，應用於"
            },
            {
              "type": "wikilink",
              "text": "電梯"
            },
            {
              "type": "text",
              "text": "升降、吊車起重、"
            },
            {
              "type": "wikilink",
              "text": "離岸風電"
            },
            {
              "type": "text",
              "text": "吊裝及橋樑結構。為國內電梯用鋼索主要供應商，客戶含"
            },
            {
              "type": "wikilink",
              "text": "崇友"
            },
            {
              "type": "text",
              "text": " (4506)、"
            },
            {
              "type": "wikilink",
              "text": "永大"
            },
            {
              "type": "text",
              "text": "等電梯廠。另供應營建起重及工業用鋼索。上游鋼線來自"
            },
            {
              "type": "wikilink",
              "text": "中鋼"
            },
            {
              "type": "text",
              "text": "。"
            }
          ]
        }
      ],
