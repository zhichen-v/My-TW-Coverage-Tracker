    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "大甲永和機械 (2221) 為台灣領先之"
            },
            {
              "type": "wikilink",
              "text": "不鏽鋼"
            },
            {
              "type": "text",
              "text": "焊接管件製造商。雙事業：潔淨級 (U"
            },
            {
              "type": "wikilink",
              "text": "HP"
            },
            {
              "type": "text",
              "text": "，佔約50%) 供應半導體/光電製程管路，為"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": "合格供應商；化工級 (佔約50%) 主要外銷日本石化業。與日本"
            },
            {
              "type": "wikilink",
              "text": "MIE"
            },
            {
              "type": "text",
              "text": "株式會社資本及業務合作。上游"
            },
            {
              "type": "wikilink",
              "text": "不鏽鋼"
            },
            {
              "type": "text",
              "text": "管板來自"
            },
            {
              "type": "wikilink",
              "text": "華新麗華"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "燁聯"
            },
            {
              "type": "text",
              "text": "及日本進口。另供"
            },
            {
              "type": "wikilink",
              "text": "聯電"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "力積電"
            },
            {
              "type": "text",
              "text": "、"
