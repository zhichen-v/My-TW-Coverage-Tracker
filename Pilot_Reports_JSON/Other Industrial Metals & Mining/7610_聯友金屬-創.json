  "sections": {
    "overview": {
      "heading": "業務簡介",
      "blocks": [
        {
          "type": "paragraph",
          "segments": [
            {
              "type": "text",
              "text": "聯友金屬科技 (7610) 成立於 2018 年，是全球領先的稀有戰略金屬回收再製企業，以獨創濕法冶金還原專利技術，從報廢"
            },
            {
              "type": "wikilink",
              "text": "碳化鎢"
            },
            {
              "type": "text",
              "text": "切削刀具等二次資源廢料中，提煉高純度"
            },
            {
              "type": "wikilink",
              "text": "鎢酸鈉"
            },
            {
              "type": "text",
              "text": "與電池級"
            },
            {
              "type": "wikilink",
              "text": "硫酸鈷"
            },
            {
              "type": "text",
              "text": "。公司為全球最大「再製」"
            },
            {
              "type": "wikilink",
              "text": "鎢酸鈉"
            },
            {
              "type": "text",
              "text": "製造商，年出口量約 2,500 噸。聯友為"
            },
            {
              "type": "wikilink",
              "text": "台積電"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "Apple"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "Tesla"
            },
            {
              "type": "text",
              "text": "在台灣唯一的"
            },
            {
              "type": "wikilink",
              "text": "鎢"
            },
            {
              "type": "text",
              "text": "金屬合格供應商。子公司聯友能源負責電池級"
            },
            {
              "type": "wikilink",
              "text": "硫酸鈷"
            },
            {
              "type": "text",
              "text": "精煉，切入"
            },
            {
              "type": "wikilink",
              "text": "電動車"
            },
            {
              "type": "text",
              "text": "電池材料供應鏈。日本"
            },
            {
              "type": "wikilink",
              "text": "Alconix"
            },
            {
              "type": "text",
              "text": "為策略性股東，"
            },
            {
              "type": "wikilink",
              "text": "住友商事"
            },
            {
              "type": "text",
              "text": "、"
            },
            {
              "type": "wikilink",
              "text": "三菱商事"
            },
            {
              "type": "text",
              "text": "及"
            },
            {
              "type": "wikilink",
              "text": "春保森拉天時鎢鋼集團"
            },
            {
              "type": "text",
              "text": "皆曾到訪尋求合作。"
            }
          ]
        }
      ],
      "groups": []
    },
